      <div class="controls">
        <div class="controls-left">
          <button class="ctrl-btn" id="favBtn" title="縺頑ｰ励↓入めE>
            <svg viewBox="0 0 24 24"><path d="M20.84 4.61a5.5 5.5 0 00-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 00-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 000-7.78z"/></svg>
          </button>
          <button class="ctrl-btn" id="loopBtn" title="再生モーチE aria-label="蜀咲函繝｢繝ｼ繝牙・譖ｿ">
            <svg viewBox="0 0 24 24" id="loopBtnIcon"><path d="M17 1l4 4-4 4M3 11V9a4 4 0 014-4h14M7 23l-4-4 4-4M21 13v2a4 4 0 01-4 4H3"/></svg>
          </button>
        </div>
        <div class="controls-center">
          <button class="ctrl-btn" id="prevTrackBtn" title="蜑阪・諠・勹">
            <svg viewBox="0 0 24 24" class="filled"><path d="M19 20L9 12l10-8v16zM5 19V5h2v14H5z"/></svg>
          </button>
          <button class="play-btn" id="playBtn" title="再生">
            <svg viewBox="0 0 24 24" id="playIcon"><path d="M8 5v14l11-7L8 5z"/></svg>
          </button>
          <button class="ctrl-btn" id="nextTrackBtn" title="谺｡縺ｮ諠・勹">
            <svg viewBox="0 0 24 24" class="filled"><path d="M5 4l10 8-10 8V4zm12 0h2v16h-2V4z"/></svg>
          </button>
        </div>
        <div class="controls-right">
          <button class="ctrl-btn" id="dlBtn" title="繝ウンローチE>
            <svg viewBox="0 0 24 24"><path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4M7 10l5 5 5-5M12 15V3"/></svg>
          </button>
          <button class="ctrl-btn" id="shareBtn" title="シェア">
            <svg viewBox="0 0 24 24"><circle cx="18" cy="5" r="3"/><circle cx="6" cy="12" r="3"/><circle cx="18" cy="19" r="3"/><path d="M8.59 13.51l6.83 3.98M15.41 6.51l-6.82 3.98"/></svg>
          </button>
          <div class="volume-wrap">
            <button class="ctrl-btn" id="muteBtn" title="繝溘Η繝ｼ繝亥・譖ｿ">
              <svg viewBox="0 0 24 24" id="volIconOn"><path d="M11 5L6 9H2v6h4l5 4V5z"/><path d="M15.54 8.46a5 5 0 010 7.07M19.07 4.93a10 10 0 010 14.14"/></svg>
              <svg viewBox="0 0 24 24" id="volIconOff" style="display:none"><path d="M11 5L6 9H2v6h4l5 4V5z"/><path d="M23 9l-6 6M17 9l6 6"/></svg>
            </button>
            <input type="range" id="volumeSlider" class="volume-slider" min="0" max="100" value="80" title="音釁E>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<audio id="audio" preload="metadata" crossorigin="anonymous"></audio>

<script>
const scenes = [
  { id:'japanese', jp:'神域',   jpSub:'和風・神社',     en:'The Sacred Gate',          enSub:'Shrine · Tradition',     image:'japanese_mid.webp',  hires:'japanese.webp',  thumb:'japanese_thumb.webp',  auraRGB:'255, 190, 130', pos:{x:50, y:48} },
  { id:'forest',   jp:'翠霊',   jpSub:'森・癒し',       en:'Emerald Woodland',         enSub:'Forest · Rest',          image:'forest_mid.webp',    hires:'forest.webp',    thumb:'forest_thumb.webp',    auraRGB:'150, 220, 140', pos:{x:46, y:52} },
  { id:'battle',   jp:'剣跡',   jpSub:'バトル・冒険',   en:'Sword of Ember',           enSub:'Battle · Heroism',       image:'battle_mid.webp',    hires:'battle.webp',    thumb:'battle_thumb.webp',    auraRGB:'255, 110, 80',  pos:{x:48, y:50} },
  { id:'farewell', jp:'雨花',   jpSub:'切ない・悲しい', en:'Rain Upon a Single Flower',enSub:'Sorrow · Farewell',      image:'farewell_mid.webp',  hires:'farewell.webp',  thumb:'farewell_thumb.webp',  auraRGB:'130, 170, 220', pos:{x:54, y:52} },
  { id:'horror',   jp:'月蝕',   jpSub:'ホラー・恐怖',   en:'Eclipse Hollow',           enSub:'Horror · Curse',         image:'horror_mid.webp',    hires:'horror.webp',    thumb:'horror_thumb.webp',    auraRGB:'180, 130, 220', pos:{x:52, y:55} },
  { id:'festival', jp:'燈祭',   jpSub:'楽しい・明るい', en:'The Lantern Festival',     enSub:'Joy · Celebration',      image:'festival_mid.webp',  hires:'festival.webp',  thumb:'festival_thumb.webp',  auraRGB:'255, 180, 100', pos:{x:55, y:48} },
  { id:'night',    jp:'星宿',   jpSub:'夜・静寂',       en:'Stardust Meadow',          enSub:'Night · Solitude',       image:'night_mid.webp',     hires:'night.webp',     thumb:'night_thumb.webp',     auraRGB:'160, 200, 255', pos:{x:45, y:51} },
  { id:'fantasy',  jp:'天穹',   jpSub:'旅・出発',       en:'Castle in the Sky',        enSub:'Journey · Departure',    image:'fantasy_mid.webp',   hires:'fantasy.webp',   thumb:'fantasy_thumb.webp',   auraRGB:'170, 220, 240', pos:{x:52, y:49} },
];

// ============ 螳滓･ｽ譖ｲ繝・・繧ｿ邨ｱ蜷・(tracks.js 連携) ============
// scene.id 竊・tracks.js の feeling/style/scene タグフィルター (遘句ｱｱ縺輔ｓ謖・ｮ・
// OR論理: 縺・★繧後°縺ｮ繝舌こ繝・ヨ蜀・・繧ｿ繧ｰ縺ｫ繝槭ャ繝√☆繧後・蛟呵｣懷・繧・
const SCENE_TAGS = {
  japanese: { style:   ['japanese'] },                                      // 和風
  forest:   { scene:   ['forest']   },                                      // 森
  battle:   { scene:   ['battle']   },                                      // 戦闁E
farewell: { feeling: ['sad']      },                                      // 蜩しい
  horror:   { feeling: ['scary']    },                                      // 怖い
  festival: { feeling: ['happy']    },                                      // 楽しい
  night:    { scene:   ['night']    },                                      // 夁E
fantasy:  { scene:   ['opening','ending','travel','field'] }              // 譌・・蜃ｺ逋ｺ邉ｻ
};

// 蜷・す繝ｼ繝ｳ縺ｮ縲檎ｲｾ驪ｭ縲肴･ｽ譖ｲ繝ｪ繧ｹ繝・(遘句ｱｱ縺輔ｓ謖・ｮ壹・繝悶Λ繝ｳ繝・ぅ繝ｳ繧ｰ諡・ｽ・
// 繧ｷ繝ｼ繝ｳ蛻晏屓繧ｯ繝ｪ繝・け縺九ｉ鬆・分縺ｫ蜀咲函縲∽ｽｿ縺・・縺｣縺溘ｉ繧ｿ繧ｰ繝励・繝ｫ縺九ｉ繝ｩ繝ｳ繝ム
const SCENE_PRIORITY_TRACKS = {
  japanese: ['n103','n72','n74','n127'],            // 蠢励・豁ｻ縺ｪ縺ｪ縺・螳ｵ逾ｭ繧翫・鬚ｨ/Moment/アメノフトツハシラ
  forest:   ['n123','n120','n51','n130'],           // ぁE▽縺九・螟ｧ蝨ｰ縺ｸ/譛幃・縺ｮ荳・莨晄価縺ｮ荳・螟ｧ讓ｹ
  battle:   ['n65','n136','n82','n36'],             // 遐ょ｡ｵ縺ｮ蝓主｡・邊ｾ髴願・縺・闖ｯ蠢励・闊・菴懈姶莨夊ｭｰ
  farewell: ['n74','n34','n131','n16'],             // Moment/蜿励￠邯吶′繧後◆諠ｳ縺・螢翫ｌ繧・￥蠢・Paradiso
  horror:   ['n80','n44','n129'],                   // 殺戮マシン/谿ｺ縺励◆/髀｡縺ｮ荳也阜縺ｯ逵繧峨↑ぁE
festival: ['n140','c2','n99','n114','n113'],      // 縺・＆縺守ｴｳ螢ｫ/譌･譎りｨ医・荳・譛ｪ譚･縺ｮ遞ｮ/Days/霈昴″縺ｫ貅ちて
  night:    ['c7','n23','n64'],                     // 譏溷ｯゅ・謨｣豁ｩ驕・螟懊→蜈ｱ縺ｫ閠ｽ繧・譛亥､懊・闊ｪ霍ｯ
  fantasy:  ['n18','m2','n21','n78','n112']         // 輝ける大地の物誁Eホシノキセキ/邏・據縺ｮ蝨ｰ縺ｸ/伝承の語り部/聖戦の英雁E
};

// 迴ｾ蝨ｨ蜀咲函荳ｭ縺ｮ螳溘ヨ繝ｩ繝・け (TRACKS驟榊・縺ｮ隕∫ｴ)
let currentTrackData = null;

// シーンごとの再生カウンタ (繧ｻ繝・す繝ｧ繝ｳ蜀・・蜆ｪ蜈医Μ繧ｹ繝磯ｲ陦檎畑)
const _scenePlayCount = {};

// 繧ｷ繝ｼ繝ｳ蜀・・譖ｲ螻･豁ｴ (蜑榊ｾ後・繧ｿ繝ｳ縺ｧ迴ｾ繧ｷ繝ｼ繝ｳ蜀・・譖ｲ繧定ｾｿ繧九◆めE
// _sceneHistory[sceneId] = [track, track, ...]
// _sceneCursor[sceneId]  = 現在位置 index (-1=未再生)
const _sceneHistory = {};
const _sceneCursor = {};

// 謖・ｮ壹す繝ｼ繝ｳ縺ｮ繧ｿ繧ｰ縺ｫ繝槭ャ繝√☆繧区･ｽ譖ｲ繧定ｿ斐☆
function findTracksForScene(sceneId) {
  const f = SCENE_TAGS[sceneId];
  if (!f || typeof TRACKS === 'undefined') return [];
  return TRACKS.filter(t => {
    if (f.feeling && t.feeling && f.feeling.some(x => t.feeling.includes(x))) return true;
    if (f.style   && t.style   && f.style.some(x   => t.style.includes(x)))   return true;
    if (f.scene   && t.scene   && f.scene.some(x   => t.scene.includes(x)))   return true;
    return false;
  });
}

// シーン選曲: 邊ｾ驪ｭ繝ｪ繧ｹ繝医°繧蛾・分縺ｫ 竊・菴ｿ縺・・縺｣縺溘ｉ繧ｿ繧ｰ繝励・繝ｫ縺九ｉ繝ｩ繝ｳ繝ム
function pickTrackForScene(sceneId) {
  if (typeof TRACKS === 'undefined') return null;
  const priority = SCENE_PRIORITY_TRACKS[sceneId] || [];
  const count = _scenePlayCount[sceneId] || 0;
  _scenePlayCount[sceneId] = count + 1;

  // 邊ｾ驪ｭ繝ｪ繧ｹ繝医ｒ鬆・分縺ｫ
  if (count < priority.length) {
    const hit = TRACKS.find(t => t.id === priority[count]);
    if (hit) return hit;
    // 隕九▽からなければフォールスルー
  }

  // 繧ｿ繧ｰ繝励・繝ｫ縺九ｉ繝ｩ繝ｳ繝ム (逶ｴ蜑阪→蜷後§曲は避ける)
  const candidates = findTracksForScene(sceneId);
  if (!candidates.length) return null;
  if (candidates.length === 1) return candidates[0];
  let picked, tries = 0;
  do {
    picked = candidates[Math.floor(Math.random() * candidates.length)];
    tries++;
  } while (currentTrackData && picked.id === currentTrackData.id && tries < 20);
  return picked;
}

// 謖・ｮ壹ち繧ｰ・医Μ繝ｳ繧ｰ驕ｸ謚樊凾・峨↓繝槭ャ繝√☆繧区･ｽ譖ｲ繧定ｿ斐☆
function findTracksForTag(tagId) {
  if (typeof TRACKS === 'undefined') return [];
  return TRACKS.filter(t =>
    (t.feeling && t.feeling.includes(tagId)) ||
    (t.style   && t.style.includes(tagId))   ||
    (t.scene   && t.scene.includes(tagId))   ||
    (t.story   && t.story.includes(tagId))
  );
}

function pickTrackForTag(tagId) {
  const candidates = findTracksForTag(tagId);
  if (!candidates.length) return null;
  if (candidates.length === 1) return candidates[0];
  // 逶ｴ蜑阪→蜷後§譖ｲ繧帝∩ける (2連続防止)
  let picked, tries = 0;
  do {
    picked = candidates[Math.floor(Math.random() * candidates.length)];
    tries++;
  } while (currentTrackData && picked.id === currentTrackData.id && tries < 20);
  return picked;
}

// tracks.js のMP3繝代せ・・music/n/n1.mp3 蠖｢蠑擾ｼ峨ｒ繝輔Ν解決
function resolveTrackUrl(track) {
  if (!track || !track.mp3) return null;
  // tracks.js の HMIX_BASE_PATH 繧定・・
  const base = (typeof HMIX_BASE_PATH !== 'undefined') ? HMIX_BASE_PATH : '';
  return base + track.mp3;
}

// ============ タグ画像差し替ぁE(本サイチE/assets/images/scenes/ 連携) ============
// 繧ｿ繧ｰ蝗ｺ譛臥判蜒上′蟄伜惠縺吶ｌ縺ｰ繧｢繧ｯ繝・ぅ繝悶↑讌募・遯薙↓蟾ｮ縺玲崛縺医√↑縺代ｌ縺ｰ繧ｷ繝ｼ繝ｳ逕ｻ蜒上・縺ｾ縺ｾ
const TAG_IMAGE_BASE = '/assets/images/scenes/';
const _tagImageCache = {};   // tagId 竊・'ok' | 'missing' (繝励Μロード結果)
let _currentTagOverride = null;  // 迴ｾ蝨ｨ繧ｪ繝ｼ繝舌・繝ｩ繧､繝我ｸｭ縺ｮ繧ｿ繧ｰID

function _getTagImageUrl(tagId) {
  if (!tagId) return null;
  return TAG_IMAGE_BASE + tagId + '.webp';
}

// 繧｢繧ｯ繝・ぅ繝匁･募・遯薙・逕ｻ蜒上ｒ繧ｿ繧ｰ逕ｻ蜒上↓差し替ぁE(蟄伜惠縺励↑縺代ｌ縺ｰ菴輔ｂ縺励↑ぁE
function overrideSceneImageForTag(tagId) {
  if (!tagId) return;
  const url = _getTagImageUrl(tagId);
  _currentTagOverride = tagId;

  const apply = () => {
    // 繝ｭ繝ｼ繝牙ｮ御ｺ・凾縺ｫ縺ｾ縺蜷後§繧ｿ繧ｰ縺碁∈択中か確誁E(繝ｬ繝ｼ繧ｹ蝗樣∩)
    if (_currentTagOverride !== tagId) return;
    document.querySelectorAll('.scene-layer.active .scene-image').forEach(el => {
      el.style.backgroundImage = `url(${url})`;
    });
    // 没入中なめEhires レイヤーも差し替ぁE(タグ画像を代用)
    if (document.body.classList.contains('immersed')) {
      document.querySelectorAll('.scene-hires.active').forEach(el => {
        el.style.backgroundImage = `url(${url})`;
      });
    }
  };

  // 繧ｭ繝｣繝・す繝･貂医∩判宁E
if (_tagImageCache[tagId] === 'ok') { apply(); return; }
  if (_tagImageCache[tagId] === 'missing') return;

  // 繝励Μロードして存在確誁E
const img = new Image();
  img.onload  = () => { _tagImageCache[tagId] = 'ok'; apply(); };
  img.onerror = () => { _tagImageCache[tagId] = 'missing'; };
  img.src = url;
}

// 繧ｷ繝ｼ繝ｳ驕ｸ謚樊凾縺ｫ繧ｿ繧ｰ繧ｪ繝ｼ繝舌・繝ｩ繧､繝峨ｒ繧ｯ繝ｪ繧｢縺励《cenes驟榊・縺ｮ逕ｻ蜒上↓戻ぁE
function clearSceneImageOverride() {
  if (_currentTagOverride === null) return;
  _currentTagOverride = null;
  const layers = document.querySelectorAll('.scene-layer');
  scenes.forEach((s, i) => {
    const sceneImg = layers[i]?.querySelector('.scene-image');
    if (sceneImg) sceneImg.style.backgroundImage = `url(${s.image})`;
    // hires layer も復允E
if (typeof hiresLayers !== 'undefined' && hiresLayers[s.id]) {
      hiresLayers[s.id].style.backgroundImage = `url(${s.hires})`;
    }
  });
}

// ============ 繧ｿ繧ｰ繝・・繧ｿ (チEΔ用) ============
// 本番では tracks.js の TAGS_META 縺九ｉ蠑輔￥縲ゅ％縺薙〒縺ｯ荳ｻ隕√ち繧ｰ繧呈栢邊九＠縺ｦ繝・Δ、E// 蜷・ち繧ｰ縺ｫ: 該当シーン (諠・勹蛻・崛逕ｨ)縲√ョ繝｢逕ｨ譖ｲ縲∵峇謨ｰ
// ============ タグで旁E☆めE 全タグ対忁E============
// 蜀・ｼｪ (感情/物誁E  Efeeling 9 + story 17 = 26
const TAGS_FEELING = [
  // Feeling  E9
  { id:'gentle',     jp:'優しい',   en:'Gentle',      sceneId:'forest',   type:'feeling' },
  { id:'happy',      jp:'楽しい',   en:'Happy',       sceneId:'festival', type:'feeling' },
  { id:'epic',       jp:'蜍・｣ｮ',     en:'Epic',        sceneId:'battle',   type:'feeling' },
  { id:'mysterious', jp:'神私E',     en:'Mysterious',  sceneId:'night',    type:'feeling' },
  { id:'sad',        jp:'悲しい',   en:'Sad',         sceneId:'farewell', type:'feeling' },
  { id:'suspense',   jp:'緊迫',     en:'Suspense',    sceneId:'battle',   type:'feeling' },
  { id:'scary',      jp:'怖い',     en:'Scary',       sceneId:'horror',   type:'feeling' },
  { id:'dark',       jp:'暗い',     en:'Dark',        sceneId:'horror',   type:'feeling' },
  { id:'cute',       jp:'縺九ｏ縺・＞', en:'Cute',        sceneId:'festival', type:'feeling' },
  // Story (物誁E  E17
  { id:'hope',       jp:'希望',     en:'Hope',        sceneId:'fantasy',  type:'story' },
  { id:'memory',     jp:'思い出',   en:'Memory',      sceneId:'farewell', type:'story' },
  { id:'reunion',    jp:'再企E',     en:'Reunion',     sceneId:'farewell', type:'story' },
  { id:'farewell',   jp:'別めE',     en:'Farewell',    sceneId:'farewell', type:'story' },
  { id:'victory',    jp:'勝利',     en:'Victory',     sceneId:'battle',   type:'story' },
  { id:'defeat',     jp:'敗北',     en:'Defeat',      sceneId:'horror',   type:'story' },
  { id:'peaceful',   jp:'平咁E',     en:'Peaceful',    sceneId:'forest',   type:'story' },
  { id:'dream',      jp:'夢',       en:'Dream',       sceneId:'fantasy',  type:'story' },
  { id:'dailylife',  jp:'日常',     en:'Daily Life',  sceneId:'festival', type:'story' },
  { id:'destiny',    jp:'運命',     en:'Destiny',     sceneId:'fantasy',  type:'story' },
  { id:'omen',       jp:'莠亥・',     en:'Omen',        sceneId:'horror',   type:'story' },
  { id:'resolve',    jp:'決愁E',     en:'Resolve',     sceneId:'battle',   type:'story' },
  { id:'bonds',      jp:'絁E',       en:'Bonds',       sceneId:'farewell', type:'story' },
  { id:'pursuit',    jp:'追跡',     en:'Pursuit',     sceneId:'battle',   type:'story' },
  { id:'conspiracy', jp:'髯ｰ隰',     en:'Conspiracy',  sceneId:'horror',   type:'story' },
  { id:'flashback',  jp:'蝗樊Φ',     en:'Flashback',   sceneId:'farewell', type:'story' },
  { id:'despair',    jp:'絶朁E',     en:'Despair',     sceneId:'horror',   type:'story' },
];

// 外輪 (諠・勹/スタイル)  Escene 21 + style 11 = 32
const TAGS_SCENE = [
  // Scene (諠・勹)  E21
  { id:'shrine',    jp:'神社',       en:'Shrine',      sceneId:'japanese', type:'scene' },
  { id:'forest',    jp:'森',         en:'Forest',      sceneId:'forest',   type:'scene' },
  { id:'night',     jp:'夁E',         en:'Night',       sceneId:'night',    type:'scene' },
  { id:'battle',    jp:'戦闁E',       en:'Battle',      sceneId:'battle',   type:'scene' },
  { id:'boss',      jp:'ボス',       en:'Boss',        sceneId:'battle',   type:'scene' },
  { id:'town',      jp:'衁E',         en:'Town',        sceneId:'festival', type:'scene' },
  { id:'village',   jp:'杁E',         en:'Village',     sceneId:'forest',   type:'scene' },
  { id:'field',     jp:'フィールチE', en:'Field',       sceneId:'fantasy',  type:'scene' },
  { id:'dungeon',   jp:'繝ンジョン', en:'Dungeon',     sceneId:'horror',   type:'scene' },
  { id:'ruins',     jp:'遺跡',       en:'Ruins',       sceneId:'horror',   type:'scene' },
  { id:'cave',      jp:'洞突E',       en:'Cave',        sceneId:'horror',   type:'scene' },
  { id:'festival',  jp:'祭めE',       en:'Festival',    sceneId:'festival', type:'scene' },
  { id:'opening',   jp:'オープニング',en:'Opening',    sceneId:'fantasy',  type:'scene' },
  { id:'ending',    jp:'繧ｨ繝ｳ繝・ぅ繝ｳ繧ｰ',en:'Ending',    sceneId:'farewell', type:'scene' },
  { id:'travel',    jp:'旁E',         en:'Travel',      sceneId:'fantasy',  type:'scene' },
  { id:'morning',   jp:'朁E',         en:'Morning',     sceneId:'fantasy',  type:'scene' },
  { id:'samurai',   jp:'サムライ',   en:'Samurai',     sceneId:'japanese', type:'scene' },
  { id:'snow',      jp:'雪',         en:'Snow',        sceneId:'farewell', type:'scene' },
  { id:'mansion',   jp:'洋館',       en:'Mansion',     sceneId:'horror',   type:'scene' },
  { id:'church',    jp:'教企E',       en:'Church',      sceneId:'japanese', type:'scene' },
  { id:'onsen',     jp:'温況E',       en:'Hot Spring',  sceneId:'forest',   type:'scene' },
  // Style (スタイル)  E11
  { id:'fantasy',         jp:'ファンタジー', en:'Fantasy',          sceneId:'fantasy',  type:'style' },
  { id:'japanese',        jp:'和風',         en:'Japanese',         sceneId:'japanese', type:'style' },
  { id:'celtic',          jp:'ケルチE',       en:'Celtic',           sceneId:'forest',   type:'style' },
  { id:'medieval',        jp:'中丁E',         en:'Medieval',         sceneId:'battle',   type:'style' },
  { id:'oriental',        jp:'アジアン',     en:'Asian',            sceneId:'japanese', type:'style' },
  { id:'futuristic',      jp:'近未来',       en:'Futuristic',       sceneId:'night',    type:'style' },
  { id:'electronic',      jp:'電子音',       en:'Electronic',       sceneId:'night',    type:'style' },
  { id:'modern',          jp:'現代皁E',       en:'Modern',           sceneId:'festival', type:'style' },
  { id:'musicbox',        jp:'オルゴール',   en:'Music Box',        sceneId:'farewell', type:'style' },
  { id:'japanese_horror', jp:'和風ホラー',   en:'Japanese Horror',  sceneId:'horror',   type:'style' },
  { id:'western_horror',  jp:'洋風ホラー',   en:'Western Horror',   sceneId:'horror',   type:'style' },
];

// count めETRACKS 縺九ｉ蜍慕噪邂怜・ (楽曲追加時も自動で反映)
(function _computeTagCounts() {
  if (typeof TRACKS === 'undefined') { return; }
  const countFor = (category, id) => TRACKS.filter(t => (t[category] || []).includes(id)).length;
  TAGS_FEELING.forEach(t => { t.count = countFor(t.type, t.id); });
  TAGS_SCENE.forEach(t => { t.count = countFor(t.type, t.id); });
})();

const $ = id => document.getElementById(id);
const sceneStage = $('sceneStage');
const sceneGrid = $('sceneGrid');
const audio = $('audio');
const playBtn = $('playBtn');
const playIcon = $('playIcon');
const trackName = $('trackName');
const imName = $('imName');
const seekbar = $('seekbar');
const seekbarFill = $('seekbarFill');
const seekbarHandle = $('seekbarHandle');
const tCurrent = $('tCurrent');
const tTotal = $('tTotal');

let currentSceneIndex = -1; // -1 = 未選抁E(譛蛻昴・諠・勹縺碁∈縺ｰ繧後※ぁE↑ぁE
// 蜿梧婿蜷代・繝舌・騾｣蜍慕畑
let hoveredSceneId = null;

scenes.forEach((s, i) => {
  const layer = document.createElement('div');
  layer.className = 'scene-layer';
  const img = document.createElement('div');
  img.className = 'scene-image';
  img.style.backgroundImage = `url(${s.image})`;
  // 蜷・ュ譎ｯ縺ｮ蝗ｺ譛峨・蜃ｺ迴ｾ菴咲ｽｮ (CSS螟画焚縺ｧ縲√ぐ繝｣繝ｩ繝ｪ繝ｼ繝｢繝ｼ繝画凾縺ｫ菴ｿ繧上ｌ繧・
  if (s.pos) {
    img.style.setProperty('--scene-pos-x', s.pos.x + '%');
    img.style.setProperty('--scene-pos-y', s.pos.y + '%');
  }
  layer.appendChild(img);
  sceneStage.appendChild(layer);

  const idxStr = String(i + 1).padStart(2, '0');
  const item = document.createElement('div');
  item.className = 'scene-item';
  item.dataset.sceneId = s.id;
  item.innerHTML = `
    <span class="idx">${idxStr}</span>
    <div class="scene-text">
      <div class="scene-jp">${s.jp}<span class="scene-jp-sub">${s.jpSub}</span></div>
      <div class="scene-en">${s.en}</div>
    </div>`;
  item.addEventListener('click', () => selectScene(i));

  // ホバー: 蟇ｾ蠢懊☆る浮遊窓を光らせる
  item.addEventListener('mouseenter', () => {
    hoveredSceneId = s.id;
    // windows驟榊・縺九ｉ隧ｲ蠖薙☆繧九え繧｣繝ｳ繝峨え繧呈爾縺励※螟夜Κホバーを設宁E
if (typeof windows !== 'undefined') {
      windows.forEach(w => {
        if (w.sceneId === s.id) w.externalHoverBoost = 1;
      });
    }
  });
  item.addEventListener('mouseleave', () => {
    hoveredSceneId = null;
    // 螟夜Κ繝帙ヰ繝ｼ縺ｯ譎る俣邨碁℃縺ｧ閾ｪ蜍輔Μ繧ｻ繝・ヨ縺輔ｌ繧・
});

  sceneGrid.appendChild(item);
});

// サムネイル事前読み込み (浮遊窓用)
const thumbImages = {};
scenes.forEach(s => {
  const img = new Image();
  img.src = s.thumb;
  thumbImages[s.id] = img;
});

// 荳ｭ隗｣蜒丞ｺｦ縺ｮ諠・勹逕ｻ蜒上ｒ驕・ｻｶ蜈郁ｪｭ縺ｿ (繧ｷ繝ｼ繝ｳ蛻・崛縺ｮ鬮倬溷喧)
setTimeout(() => {
  scenes.forEach((s, i) => {
    setTimeout(() => {
      const preload = new Image();
      preload.src = s.image;
    }, i * 300);
  });
}, 3000);

// ============ 繝代ヵ繧ｩ繝ｼ繝槭Φ繧ｹ繝｢繝ｼ繝画､懷・ ============
// Safari 縺ｯ隍・焚 Canvas + 髁EDPR 縺ｧ驥阪￥縺ｪ繧句だ蜷代３etina 迺ｰ蠅・〒縺ｯ dpr めE1 縺ｫ關ｽ縺ｨ縺吶・// 菴取ｧ閭ｽ GPU 蛻､螳壹・ UA + 繝上・繝峨え繧ｧ繧｢蜷梧凾螳溯｡梧焚縺ｧ邁｡譏捺耳螳壹・
const _isSafari = /^((?!chrome|android).)*safari/i.test(navigator.userAgent);
const _isLowPower = (navigator.hardwareConcurrency || 4) <= 4;
// 陬・｣ｾ Canvas 用 dpr (邊貞ｭ舌・豕｡繝ｻ豌ｴ邏九・譏滄峇繝ｻ雜ｳ霍｡)。Safari/菴取ｧ閭ｽ讖溘・ 1 に制陁E
const DECOR_DPR = (_isSafari || _isLowPower) ? 1 : Math.min(window.devicePixelRatio || 1, 2);
// UI Canvas 用 dpr (mainCanvas 縺ｮ繧ｿ繧ｰ譁・ｭ励・豬ｮ驕翫き繝ｼ繝・縲よ怙螟ｧ 2 のまま
const UI_DPR = Math.min(window.devicePixelRatio || 1, 2);
window._HMIX_PERF_MODE = (_isSafari || _isLowPower) ? 'low' : 'high';

// Canvas
const canvas = $('mainCanvas');
const ctx = canvas.getContext('2d', { alpha: true });
let cw = 0, ch = 0, dpr = 1;
function resizeCanvas() {
  // mainCanvas 縺ｯ豬ｮ驕翫き繝ｼ繝峨・譁・ｭ励ｒ謠冗判縺吶ｋ縺溘ａ縲∵枚蟄苓ｧ｣蜒丞ｺｦ蜆ｪ蜈医〒 UI_DPR 採用
  // 縺溘□ぁESafari なめEDECOR_DPR (=1) 縺ｫ縺励※ 4蛟阪・蝪励ｊ貎ｰ縺励さ繧ｹ繝医ｒ蜑頑ｸ・  dpr = (_isSafari || _isLowPower) ? DECOR_DPR : UI_DPR;
  cw = innerWidth;
  ch = innerHeight;
  canvas.width = cw * dpr;
  canvas.height = ch * dpr;
  canvas.style.width = cw + 'px';
  canvas.style.height = ch + 'px';
  ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
}
resizeCanvas();
addEventListener('resize', resizeCanvas);

// 浮遊窓クラス
class FloatingWindow {
  constructor(idx, sceneId, gridX, gridY, cols = 4, rows = 3) {
    this.id = idx;
    this.sceneId = sceneId;
    this.depth = Math.random();
    // 8蛟九↓蠅励∴縺溘・縺ｧ縲・蛟九≠たりのサイズを少し小さぁE
const baseSize = 100 + this.depth * 85;
    this.w = baseSize * (1.55 + Math.random() * 0.2);
    this.h = baseSize * (0.92 + Math.random() * 0.1);
    this.baseNX = (gridX + 0.5) / cols;
    this.baseNY = (gridY + 0.5) / rows;
    // 繧ｰ繝ｪ繝・ラ蜀・〒繝ｩ繝ｳ繝ム配置 (驥崎､・ｒ譛蟆丞喧縺吶ｋ縺溘ａ蟆代＠迢ｭ繧√↓)
    this.offsetNX = (Math.random() - 0.5) * 0.08;
    this.offsetNY = (Math.random() - 0.5) * 0.1;
    this.phase = Math.random() * Math.PI * 2;
    this.speed = 0.15 + Math.random() * 0.25;
    this.rotBase = (Math.random() - 0.5) * 0.18;
    this.rotAmp = 0.05 + Math.random() * 0.05;
    this.opacity = 0;
    this.targetOpacity = 0.28 + this.depth * 0.12;
    this.hoverBoost = 0;
    this.glowPulse = 0;
    this.x = 0; this.y = 0;
    this.scale = 1;
    this.rot = 0;
    this.hovering = false;
    this.externalHoverBoost = 0; // 繧ｷ繝ｼ繝ｳ繝｡繝九Ηーからのホバー連動用
  }

  update(dt, time, mx, my, audioLevel) {
    const nx = this.baseNX + this.offsetNX + Math.sin(time * this.speed + this.phase) * 0.02;
    const ny = this.baseNY + this.offsetNY + Math.cos(time * this.speed * 0.7 + this.phase) * 0.018;

    const parallaxX = -mx * (6 + this.depth * 14);
    const parallaxY = -my * (4 + this.depth * 10);

    this.x = nx * cw + parallaxX;
    this.y = ny * ch + parallaxY;
    this.rot = this.rotBase + Math.sin(time * this.speed * 0.5 + this.phase) * this.rotAmp;

    // 繝帙ヰ繝ｼ繝悶・繧ｹ繝・ 直接ホバー + 螟夜Κホバー (繧ｷ繝ｼ繝ｳ繝｡繝九Ηー連勁E 縺ｮ譛大値
    const hoverTarget = Math.max(this.hovering ? 1 : 0, this.externalHoverBoost);
    this.hoverBoost += (hoverTarget - this.hoverBoost) * 0.15;
    // 螟夜Κ繝帙ヰ繝ｼ縺ｯ譎る俣邨碁℃縺ｧ繝ｪ繧ｻ繝・ヨ
    this.externalHoverBoost *= 0.85;
    this.glowPulse *= 0.94;
    this.opacity += (this.targetOpacity - this.opacity) * 0.05;

    // 繝帙ヰ繝ｼ譎ゅ・繧ｹ繧ｱ繝ｼ繝ｫ蠅怜刈繧貞､ｧ縺阪￥(蜈峨▲縺ｦ螟ｧ縺阪￥縺ｪ繧区ｼ泌・)
    this.scale = 1 + Math.sin(time * this.speed * 0.4 + this.phase) * 0.015
      + audioLevel * 0.03 * (0.5 + this.depth)
      + this.hoverBoost * 0.15  // 0.06 竊・0.15 (より顕著に)
      + this.glowPulse * 0.1;
  }

  draw(ctx, auraRGB) {
    if (this.opacity < 0.01) return;
    const img = thumbImages[this.sceneId];
    if (!img || !img.complete || !img.naturalWidth) return;

    ctx.save();
    ctx.translate(this.x, this.y);
    ctx.rotate(this.rot);
    ctx.scale(this.scale, this.scale);

    const halfW = this.w / 2, halfH = this.h / 2;
    const totalOp = Math.min(1, this.opacity * (1 + this.hoverBoost * 1.8 + this.glowPulse * 2));

    // 【NEW縲大ｸｸ譎ゅラ繝ｭ繝・・繧ｷ繝｣繝峨え縺ｧ遶倶ｽ捺─ (譏弱ｋ縺・レ譎ｯ縺ｧ繧よｵｮ縺堺ｸ翫′めE
    ctx.save();
    ctx.shadowColor = `rgba(0, 0, 0, ${0.55 + this.hoverBoost * 0.2})`;
    ctx.shadowBlur = 18 + this.depth * 8;
    ctx.shadowOffsetX = 0;
    ctx.shadowOffsetY = 6 + this.depth * 4;
    // 繧ｷ繝｣繝峨え縺縺第緒逕ｻ縺吶ｋ縺溘ａ縺ｮ荳榊庄隕悶↑矩形
    ctx.fillStyle = 'rgba(0,0,0,0.01)';
    ctx.beginPath();
    const rr = 4;
    ctx.moveTo(-halfW + rr, -halfH);
    ctx.lineTo(halfW - rr, -halfH);
    ctx.arcTo(halfW, -halfH, halfW, -halfH + rr, rr);
    ctx.lineTo(halfW, halfH - rr);
    ctx.arcTo(halfW, halfH, halfW - rr, halfH, rr);
    ctx.lineTo(-halfW + rr, halfH);
    ctx.arcTo(-halfW, halfH, -halfW, halfH - rr, rr);
    ctx.lineTo(-halfW, -halfH + rr);
    ctx.arcTo(-halfW, -halfH, -halfW + rr, -halfH, rr);
    ctx.closePath();
    ctx.fill();
    ctx.restore();

    // 螟門・縺ｮ繧ｰ繝ｭ繝ｼ (ホバー/繧ｯ繝ｪ繝・け譎・ - 螟ｧ縺阪↑蜀・〒蠎・ｯ・峇縺ｫ
    if (this.hoverBoost > 0.02 || this.glowPulse > 0.01) {
      const glowIntensity = this.hoverBoost * 0.7 + this.glowPulse * 0.9;
      const diag = Math.hypot(halfW, halfH);
      const glowRadius = diag * 3.5;
      const grd = ctx.createRadialGradient(0, 0, diag * 0.6, 0, 0, glowRadius);
      grd.addColorStop(0, `rgba(${auraRGB}, ${glowIntensity * 0.55})`);
      grd.addColorStop(0.25, `rgba(${auraRGB}, ${glowIntensity * 0.3})`);
      grd.addColorStop(0.6, `rgba(${auraRGB}, ${glowIntensity * 0.1})`);
      grd.addColorStop(1, `rgba(${auraRGB}, 0)`);
      ctx.fillStyle = grd;
      ctx.beginPath();
      ctx.arc(0, 0, glowRadius, 0, Math.PI * 2);
      ctx.fill();
    }

    // 角丸矩形パス
    const r = 4;
    ctx.beginPath();
    ctx.moveTo(-halfW + r, -halfH);
    ctx.lineTo(halfW - r, -halfH);
    ctx.arcTo(halfW, -halfH, halfW, -halfH + r, r);
    ctx.lineTo(halfW, halfH - r);
    ctx.arcTo(halfW, halfH, halfW - r, halfH, r);
    ctx.lineTo(-halfW + r, halfH);
    ctx.arcTo(-halfW, halfH, -halfW, halfH - r, r);
    ctx.lineTo(-halfW, -halfH + r);
    ctx.arcTo(-halfW, -halfH, -halfW + r, -halfH, r);
    ctx.closePath();

    ctx.save();
    ctx.clip();

    // 画像描画
    ctx.globalAlpha = totalOp;
    ctx.drawImage(img, -halfW, -halfH, this.w, this.h);

    // 【CHANGED縲台ｸ句・縺ｫ繝薙ロ繝・ヨ(暗い影) - 譏弱ｋ縺・勹濶ｲ縺ｧ繧らｸ√′隕九∴めE
const vignette = ctx.createRadialGradient(0, 0, Math.min(halfW, halfH) * 0.4, 0, 0, Math.max(halfW, halfH) * 1.2);
    vignette.addColorStop(0, 'rgba(0, 0, 0, 0)');
    vignette.addColorStop(0.7, 'rgba(0, 0, 0, 0.15)');
    vignette.addColorStop(1, 'rgba(0, 0, 0, 0.55)');
    ctx.globalAlpha = totalOp;
    ctx.fillStyle = vignette;
    ctx.fillRect(-halfW, -halfH, this.w, this.h);

    // 證励ａ縺ｮ繧ｪ繝ｼ繝舌・繝ｬ繧､ (繝帙ヰ繝ｼ譎ゅ・譎ｴ繧後ｋ) - 全体を少し暗く
    const darkness = 1 - this.hoverBoost * 0.9;
    if (darkness > 0.1) {
      ctx.globalAlpha = totalOp * 0.25 * darkness;
      ctx.fillStyle = '#0a0f0c';
      ctx.fillRect(-halfW, -halfH, this.w, this.h);
    }

    // 蜈峨・蜿榊ｰ・(荳企ΚのハイライチE
    ctx.globalAlpha = totalOp * (0.3 + this.hoverBoost * 0.5);
    const refGrad = ctx.createLinearGradient(-halfW, -halfH, halfW, halfH);
    refGrad.addColorStop(0, 'rgba(255, 255, 255, 0.22)');
    refGrad.addColorStop(0.4, 'rgba(255, 255, 255, 0)');
    refGrad.addColorStop(1, `rgba(${auraRGB}, 0.15)`);
    ctx.fillStyle = refGrad;
    ctx.fillRect(-halfW, -halfH, this.w, this.h);

    ctx.restore();

    // 【NEW縲大・蛛ｴ縺ｮ鮟偵＞邏ｰ縺・ｽｱ(contrast line) - 譏弱ｋ縺・レ譎ｯ縺ｧ逕ｻ蜒剰ｼｪ驛ｭ繧帝圀遶九◆せる
    ctx.globalAlpha = totalOp * 0.7;
    ctx.strokeStyle = 'rgba(0, 0, 0, 0.7)';
    ctx.lineWidth = 1;
    ctx.stroke();

    // 【CHANGED】外枠 - 蟆代＠螟ｪ繧√・驥題牡縺ｧ蟶ｸ譎ら岼遶九▽
    ctx.globalAlpha = totalOp;
    ctx.strokeStyle = `rgba(232, 196, 120, ${0.55 + this.hoverBoost * 0.45})`;
    ctx.lineWidth = 1.5 + this.hoverBoost * 1.5;
    ctx.stroke();

    ctx.restore();

    // ============ 繝帙ヰ繝ｼ譎ゅ・繧ｿ繧､繝医Ν表示 (縺九▲こよぁE ============
    if (this.hoverBoost > 0.05) {
      const scene = (typeof scenes !== 'undefined') ? scenes.find(s => s.id === this.sceneId) : null;
      if (scene) {
        const alpha = Math.min(1, this.hoverBoost * 1.3);
        // カード下端からの距離 (scale縺ｨ蛯ｾ縺阪ｒ閠・・縺励◆螳牙・繝槭・繧ｸ繝ｳ)
        const cardBottomY = this.y + (this.h * this.scale) / 2;
        const yBase = cardBottomY + 22;

        ctx.save();
        ctx.textAlign = 'center';
        ctx.textBaseline = 'alphabetic';

        // 英孁E(Cinzel, 蟆上＆縺丈ｸ翫↓)
        ctx.globalAlpha = alpha * 0.82;
        ctx.fillStyle = 'rgba(245, 216, 150, 0.92)';
        ctx.font = "500 10px 'Cinzel', serif";
        try { ctx.letterSpacing = '0.3em'; } catch(e) {}
        ctx.shadowColor = `rgba(${auraRGB}, 0.7)`;
        ctx.shadowBlur = 12;
        ctx.fillText((scene.en || '').toUpperCase(), this.x, yBase);

        // 陬・｣ｾ繝繝悶Νライン (驥鯛・鄙｡鄙繧ｰ繝ｩ繝・｢ｨ)
        try { ctx.letterSpacing = 'normal'; } catch(e) {}
        ctx.globalAlpha = alpha * 0.5;
        ctx.shadowBlur = 6;
        const lineY = yBase + 10;
        const lineW = 26 + this.hoverBoost * 14;
        const lg = ctx.createLinearGradient(this.x - lineW, lineY, this.x + lineW, lineY);
        lg.addColorStop(0, 'rgba(245, 216, 150, 0)');
        lg.addColorStop(0.5, 'rgba(245, 216, 150, 0.9)');
        lg.addColorStop(1, 'rgba(245, 216, 150, 0)');
        ctx.strokeStyle = lg;
        ctx.lineWidth = 0.8;
        ctx.beginPath();
        ctx.moveTo(this.x - lineW, lineY);
        ctx.lineTo(this.x + lineW, lineY);
        ctx.stroke();
        // 蟆上＆縺ｪ驥代・闖ｱ蠖｢ (荳ｭ螟ｮ陬・｣ｾ)
        ctx.fillStyle = 'rgba(245, 216, 150, 0.85)';
        ctx.beginPath();
        ctx.moveTo(this.x, lineY - 2.5);
        ctx.lineTo(this.x + 2.5, lineY);
        ctx.lineTo(this.x, lineY + 2.5);
        ctx.lineTo(this.x - 2.5, lineY);
        ctx.closePath();
        ctx.fill();

        // 譌･譛ｬ隱槭ち繧､繝医Ν (Noto Serif JP, 螟ｧ縺阪￥荳九↓)
        ctx.globalAlpha = alpha;
        ctx.fillStyle = 'rgba(250, 232, 190, 0.98)';
        ctx.font = "500 22px 'Noto Serif JP', serif";
        try { ctx.letterSpacing = '0.22em'; } catch(e) {}
        ctx.shadowColor = `rgba(${auraRGB}, 0.85)`;
        ctx.shadowBlur = 20;
        ctx.fillText(scene.jp || '', this.x, yBase + 36);

        // サブ情報 (jpSub, さらに控えめに)
        if (scene.jpSub) {
          try { ctx.letterSpacing = '0.3em'; } catch(e) {}
          ctx.globalAlpha = alpha * 0.6;
          ctx.fillStyle = 'rgba(245, 216, 150, 0.7)';
          ctx.font = "400 9.5px 'Noto Serif JP', serif";
          ctx.shadowBlur = 8;
          ctx.fillText(scene.jpSub, this.x, yBase + 56);
        }

        try { ctx.letterSpacing = 'normal'; } catch(e) {}
        ctx.restore();
      }
    }
  }

  hitTest(px, py) {
    const dx = px - this.x;
    const dy = py - this.y;
    const cos = Math.cos(-this.rot);
    const sin = Math.sin(-this.rot);
    const rx = dx * cos - dy * sin;
    const ry = dx * sin + dy * cos;
    return Math.abs(rx) < this.w * this.scale / 2 && Math.abs(ry) < this.h * this.scale / 2;
  }
}

let windows = [];

function setupWindows(currentIdx) {
  windows = [];
  // 5x3格子で配置、UI縺悟頃繧√ｋ鬆伜沺繧帝勁螟・
const COLS = 5, ROWS = 3;
  const grid = Array(COLS).fill(null).map(() => Array(ROWS).fill(false));
  // UI占有領域 (5x3座標系で)
  grid[0][0] = true; // brand (左丁E
  grid[0][1] = true; // scene-index 荳企Κ
  grid[0][2] = true; // scene-index 中丁E  grid[4][0] = true; // exit (右丁E
  grid[4][1] = true; // nav arrows (右中)
  grid[4][2] = true; // action tower (右丁E
  grid[2][2] = true; // player center

  const available = [];
  for (let x = 0; x < COLS; x++) {
    for (let y = 0; y < ROWS; y++) {
      if (!grid[x][y]) available.push([x, y]);
    }
  }
  // 残り: (1,0), (2,0), (3,0), (1,1), (2,1), (3,1), (1,2), (3,2) = 8マス

  // 繧ｷ繝｣繝・ヵ繝ｫ
  for (let i = available.length - 1; i > 0; i--) {
    const j = Math.floor(Math.random() * (i + 1));
    [available[i], available[j]] = [available[j], available[i]];
  }

  // 全8諠・勹繧帝・分縺ｫ繧ｷ繝｣繝・ヵ繝ｫ (迴ｾ蝨ｨ縺ｮ諠・勹繧ょ性繧 窶・縺ｩ縺ｮ諠・勹縺ｫ縺・※繧ゆｻ・諠・勹繧剃ｸｦ縺ｹ繧・
  const allScenes = [...scenes];
  for (let i = allScenes.length - 1; i > 0; i--) {
    const j = Math.floor(Math.random() * (i + 1));
    [allScenes[i], allScenes[j]] = [allScenes[j], allScenes[i]];
  }

  const N = Math.min(8, available.length);

  for (let i = 0; i < N; i++) {
    const pickScene = allScenes[i];
    const [gx, gy] = available[i];
    const w = new FloatingWindow(i, pickScene.id, gx, gy, COLS, ROWS);
    w.targetOpacity = 0;
    windows.push(w);
    setTimeout(() => { w.targetOpacity = 0.28 + w.depth * 0.12; }, 300 + i * 120);
  }
}

// 粒孁E(繝｢繝舌う繝ｫ縺ｧ縺ｯ謨ｰ繧呈ｸ帙ｉ縺励※負荷軽渁E
const _isMobileDevice = (window.matchMedia && window.matchMedia('(hover: none) and (pointer: coarse)').matches) || innerWidth <= 720;
// Safari / 菴取ｧ閭ｽ讖溘・縺輔ｉ縺ｫ 40% 削渁E(カクつき対筁E
const _perfScale = (_isSafari || _isLowPower) ? 0.55 : 1.0;
const PARTICLE_MID   = Math.round((_isMobileDevice ? 40 : 110) * _perfScale);
const PARTICLE_FRONT = Math.round((_isMobileDevice ? 14 : 40)  * _perfScale);
const particlesMid = [];
const particlesFront = [];
for (let i = 0; i < PARTICLE_MID; i++) {
  particlesMid.push({
    x: Math.random() * cw,
    y: Math.random() * ch,
    vx: (Math.random() - 0.5) * 0.2,
    vy: -0.04 - Math.random() * 0.12,
    r: 0.8 + Math.random() * 2,
    a: 0.5 + Math.random() * 0.5,
    phase: Math.random() * Math.PI * 2,
  });
}
for (let i = 0; i < PARTICLE_FRONT; i++) {
  particlesFront.push({
    x: Math.random() * cw,
    y: Math.random() * ch,
    vx: 0, vy: 0,
    tvx: (Math.random() - 0.5) * 0.12,
    tvy: -0.05 - Math.random() * 0.1,
    r: 2.5 + Math.random() * 6,
    a: 0.2 + Math.random() * 0.35,
    phase: Math.random() * Math.PI * 2,
    reactivity: 0.3 + Math.random() * 0.7,
  });
}

const burstQueue = [];
function burstParticles() {
  // 逕ｻ髱｢蜈ｨ菴薙↓繝ｩ繝ｳ繝繝縺ｫ驟咲ｽｮ縺輔ｌ縺溷・縺ｮ邊偵′縲√ｆ縺｣縺上ｊ螟門・縺ｫ蠎・′縺｣縺ｦ豸医∴めE  // (辷・匱縺ｧ縺ｯ縺ｪ縺上∝・縺ｮ諱ｯ縺･縺九＞縺ｮ繧医≧縺ｪ貍泌・)
  for (let i = 0; i < 60; i++) {
    // 逕ｻ髱｢蜈ｨ菴薙↓繝ｩ繝ｳ繝ム配置
    const x = Math.random() * cw;
    const y = Math.random() * ch;
    // 蜷・ｲ貞ｭ舌・荳ｭ螟ｮ縺九ｉ縺ｮ譁ｹ蜷代↓めE▲くり庁E′めE
const cx = cw / 2, cy = ch / 2;
    const dx = x - cx, dy = y - cy;
    const dist = Math.hypot(dx, dy) || 1;
    const speed = 0.8 + Math.random() * 1.5;
    burstQueue.push({
      x: x, y: y,
      vx: (dx / dist) * speed,
      vy: (dy / dist) * speed,
      r: 1.2 + Math.random() * 3,
      a: 0.4 + Math.random() * 0.5,
      life: 1,
      decay: 0.006 + Math.random() * 0.010,
    });
  }
}

let currentAuraRGB = '212, 164, 76';

function selectScene(index, updateTrack = true) {
  const isSameScene = (index === currentSceneIndex);
  const wasUnselected = (currentSceneIndex < 0); // 譛ｪ驕ｸ謚樞・驕ｸ謚槭∈の初回遷移ぁE
const scene = scenes[index];
  currentSceneIndex = index;

  // 繧ｷ繝ｼ繝ｳ蛻・崛 竊・繧ｿ繧ｰ逕ｻ蜒上が繝ｼ繝舌・繝ｩ繧､繝峨ｒ隗｣髯､ (updateTrack=false縺ｮ蝣ｴ蜷医・繧ｿ繧ｰ邨檎罰縺ｪ縺ｮ縺ｧ隗｣髯､縺励↑ぁE
  if (updateTrack) clearSceneImageOverride();

  // 驕ｸ謚槭＆繧後◆のでunselected繧ｯ繝ｩ繧ｹ繧貞､悶☆
  document.body.classList.remove('no-scene-selected');

  // scene-layerとscene-itemの表示は常に更新
  document.querySelectorAll('.scene-layer').forEach((l, i) => {
    l.classList.toggle('active', i === index);
  });
  document.querySelectorAll('.scene-item').forEach((el, i) => {
    el.classList.toggle('active', i === index);
  });

  $('titleJp').textContent = scene.jp;
  $('titleEn').textContent = scene.en;
  $('sceneTitle').classList.add('visible');
  clearTimeout(window._titleTimer);
  window._titleTimer = setTimeout(() => {
    $('sceneTitle').classList.remove('visible');
  }, 3800);

  windows.forEach(w => w.targetOpacity = 0);
  setTimeout(() => setupWindows(index), 600);

  if (updateTrack && !isSameScene) {
    // 繧ｿ繧ｰ繝吶・繧ｹ縺ｧ螳溘ヨ繝ｩ繝・け繧帝∈曲
    const picked = pickTrackForScene(scene.id);
    if (picked) {
      _pushHistory(scene.id, picked);
      currentTrackData = picked;
      const displayTitle = picked.title || '';
      trackName.textContent = displayTitle;
      imName.textContent = displayTitle;
      const wasPlaying = !audio.paused;
      audio.src = resolveTrackUrl(picked);
      audio.load();
      if (wasPlaying || wasUnselected) {
        initAudioAnalyser();
        if (audioCtx && audioCtx.state === 'suspended') audioCtx.resume().catch(() => {});
        audio.play().catch(() => {});
      }
    } else {
      // フォールバック: TRACKS未ロード時 (本来到達しなぁE
      trackName.textContent = '';
      imName.textContent = '';
    }
  }

  currentAuraRGB = scene.auraRGB;

  // 縺頑ｰ励↓蜈･繧翫・繧ｿ繝ｳ迥ｶ諷九・蜷梧悄
  if (typeof updateFavButtonState === 'function') updateFavButtonState();

  // 豐｡蜈･繝｢繝ｼ繝我ｸｭ縺ｮ諠・勹蛻・崛: 高解像度+字幁Eエフェクトを更新
  if (document.body.classList.contains('immersed')) {
    // 蜑阪・繧ｷ繝ｼ繝ｳ縺ｮ鬮倩ｧ｣蜒丞ｺｦ繧呈ｶ医☆
    Object.keys(hiresLayers).forEach(sid => {
      if (sid !== scene.id) {
        const l = hiresLayers[sid];
        if (l) l.classList.remove('active');
      }
    });
    setTimeout(() => {
      if (document.body.classList.contains('immersed')) {
        loadHiresForCurrentScene();
        showImmersiveSubtitle();
        startSceneEffect();
      }
    }, 200);
  }
}

// 繧ｪ繝ｼ繝・ぅ繧ｪ
let audioCtx, analyser, source, dataArray;
let lowpassFilter = null; // 豐｡蜈･蛻・崛譎ゅ・髻ｳ縺ｮ縺ｼ縺九＠逕ｨ
function initAudioAnalyser() {
  if (audioCtx) return;
  try {
    audioCtx = new (window.AudioContext || window.webkitAudioContext)();
    source = audioCtx.createMediaElementSource(audio);
    analyser = audioCtx.createAnalyser();
    analyser.fftSize = 256;
    analyser.smoothingTimeConstant = 0.85;
    dataArray = new Uint8Array(analyser.frequencyBinCount);

    // ローパスフィルタ (豐｡蜈･貍泌・逕ｨ縲・壼ｸｸ譎ゅ・繝輔Λ繝・ヨ)
    lowpassFilter = audioCtx.createBiquadFilter();
    lowpassFilter.type = 'lowpass';
    lowpassFilter.frequency.value = 22050; // 騾壼ｸｸ譎ゅ・蜿ｯ閨ｴ蝓溷・髢・    lowpassFilter.Q.value = 0.7;

    // 接綁E source 竊・lowpass 竊・analyser 竊・destination
    source.connect(lowpassFilter);
    lowpassFilter.connect(analyser);
    analyser.connect(audioCtx.destination);
  } catch (e) { console.warn(e); }
}

// 音を水中に沈めめE(繝ｭ繝ｼ繝代せ繝輔ぅ繝ｫ繧ｿ繧貞ｼｷ繧√ｋ)
function submergeAudio(durationSec) {
  if (!lowpassFilter || !audioCtx) return;
  const now = audioCtx.currentTime;
  // 22050Hz 竊・600Hz にめE▲くり下げめE(豌ｴ縺ｮ蠎輔・繧医≧な音)
  lowpassFilter.frequency.cancelScheduledValues(now);
  lowpassFilter.frequency.setValueAtTime(lowpassFilter.frequency.value, now);
  lowpassFilter.frequency.exponentialRampToValueAtTime(600, now + durationSec);
}

// 音を水面に戻ぁE
function surfaceAudio(durationSec) {
  if (!lowpassFilter || !audioCtx) return;
  const now = audioCtx.currentTime;
  lowpassFilter.frequency.cancelScheduledValues(now);
  lowpassFilter.frequency.setValueAtTime(lowpassFilter.frequency.value, now);
  lowpassFilter.frequency.exponentialRampToValueAtTime(22050, now + durationSec);
}

playBtn.addEventListener('click', async () => {
  initAudioAnalyser();
  if (audioCtx && audioCtx.state === 'suspended') await audioCtx.resume();
  if (audio.paused) audio.play().catch(console.warn);
  else audio.pause();
});
audio.addEventListener('play', () => playIcon.innerHTML = '<path d="M6 4h4v16H6zM14 4h4v16h-4z"/>');
audio.addEventListener('pause', () => playIcon.innerHTML = '<path d="M8 5v14l11-7L8 5z"/>');
audio.addEventListener('loadedmetadata', () => tTotal.textContent = formatTime(audio.duration));
audio.addEventListener('timeupdate', () => {
  tCurrent.textContent = formatTime(audio.currentTime);
  if (audio.duration) {
    const pct = (audio.currentTime / audio.duration) * 100;
    seekbarFill.style.width = `${pct}%`;
    seekbarHandle.style.left = `${pct}%`;
  }
});
audio.addEventListener('ended', () => {
  // 繧ｭ繝･繝ｼ縺後≠繧後・縺ｾ縺壹◎ちらを優允E(縺頑ｰ励↓蜈･繧企｣邯壼・逕・
  if (audio.loop) return;
  if (!playQueue || playQueue.currentIdx >= playQueue.ids.length - 1) {
    if (!playQueue) {
      // ウェルカム中 / 繧ｷ繝ｼ繝ｳ譛ｪ驕ｸ謚樊凾縺ｯ縺九●縺ｮ縺薙∴繧偵ΝーチE
const inWelcome = (typeof _welcomeMode !== 'undefined' && _welcomeMode) || currentSceneIndex < 0;
      if (inWelcome && typeof _playWelcomeMusic === 'function') {
        _playWelcomeMusic();
        return;
      }
      // 通常晁E 蜷後§繧ｷ繝ｼ繝ｳ蜀・〒谺｡縺ｮ譖ｲ縺ｸ (邊ｾ驪ｭ繝ｪ繧ｹ繝遺・繧ｿ繧ｰ繝励・繝ｫ縺ｮ鬆・↓辿めE
      // 繧ｷ繝ｼ繝ｳ蛻・崛縺ｯ譏守､ｺ逧・↑繧ｷ繝ｼ繝ｳ驕ｸ謚槭〒縺ｮ縺ｿ陦後≧
      nextTrack();
    }
  }
});

// ============ 音声ロード中の表示 (譖ｲ蛻・崛譎ゅ・豐磯ｻ吝ｯｾ遲・ ============
// waiting / loadstart 竊・body.audio-loading 莉倅ｸ・竊・繝励Ξ繧､繝､繝ｼ縺ｫ繝励Ο繧ｰ繝ｬ繧ｹ繝舌・
audio.addEventListener('loadstart', () => { document.body.classList.add('audio-loading'); });
audio.addEventListener('waiting',   () => { document.body.classList.add('audio-loading'); });
audio.addEventListener('canplay',   () => { document.body.classList.remove('audio-loading'); });
audio.addEventListener('playing',   () => { document.body.classList.remove('audio-loading'); });
audio.addEventListener('pause',     () => { document.body.classList.remove('audio-loading'); });

// ============ 髻ｳ螢ｰ繝ｭ繝ｼ繝牙､ｱ謨玲凾縺ｮ繝ｪ繧ｫ繝舌Μ ============
// MP3 ぁE404 / 繝阪ャ繝亥・譁ｭ 竊・谺｡縺ｮ譖ｲ縺ｸ閾ｪ蜍輔せ繧ｭ繝・・ + 繝医・繧ｹ繝磯夂衍
let _audioErrorSkipCount = 0;
audio.addEventListener('error', (e) => {
  // audio.src 縺檎ｩｺ縺ｪ繧臥┌要E(初期状慁E
  if (!audio.src || audio.currentSrc === '') return;
  console.warn('[theater] audio load error:', audio.error?.code, audio.currentSrc);
  _audioErrorSkipCount++;
  // 辟｡髯舌Μトライ防止 (3騾｣邯壹〒隲ｦ繧√ｋ)
  if (_audioErrorSkipCount > 3) {
    _audioErrorSkipCount = 0;
    if (typeof showToast === 'function') {
      showToast('讌ｽ譖ｲ繧定ｪｭ縺ｿ霎ｼ繧√∪縺帙ｓ縺ｧ縺励◆。時間をおいてお試しください、E');
    }
    return;
  }
  if (typeof showToast === 'function') {
    showToast('谺｡縺ｮ譖ｲ繧呈爾縺励※ぁE∪縺吮ｦ');
  }
  // 次の曲を試ぁE(シーン冁Eor ウェルカム)
  setTimeout(() => {
    if (currentSceneIndex < 0 && typeof _playWelcomeMusic === 'function') {
      // 繧ｦ繧ｧ繝ｫ繧ｫ繝譖ｲ閾ｪ菴薙′螟ｱ謨励＠縺溷ｴ蜷医・繝ｪ繝医Λ繧､縺励↑ぁE(辟｡髯舌Νープ回避)
      if (_audioErrorSkipCount >= 2) {
        if (typeof showToast === 'function') showToast('髻ｳ螢ｰ縺ｮ隱ｭ縺ｿ霎ｼ縺ｿ縺ｫ螟ｱ謨励＠縺ｾ縺励◆、E');
        return;
      }
      _playWelcomeMusic();
    } else {
      nextTrack();
    }
  }, 400);
});
// 蜀咲函謌仙粥縺励◆繧峨お繝ｩ繝ｼ繧ｫ繧ｦ繝ｳ繧ｿ繧偵Μ繧ｻ繝・ヨ
audio.addEventListener('playing', () => { _audioErrorSkipCount = 0; });

function formatTime(s) {
  if (!isFinite(s)) return '0:00';
  return `${Math.floor(s/60)}:${String(Math.floor(s%60)).padStart(2,'0')}`;
}

seekbar.addEventListener('click', e => {
  if (!audio.duration) return;
  const rect = seekbar.getBoundingClientRect();
  const p = (e.clientX - rect.left) / rect.width;
  audio.currentTime = p * audio.duration;
});

function nextScene() { selectScene((currentSceneIndex + 1) % scenes.length); }
function prevScene() { selectScene((currentSceneIndex - 1 + scenes.length) % scenes.length); }

// ============ 曲履歴操佁E(繧ｰ繝ｭ繝ｼ繝舌Ν履歴) ============
// 繧ｷ繝ｼ繝ｳ繧定ｷｨ縺・〒繧ゅ√え繧ｧ繝ｫ繧ｫ繝譖ｲ繧ゅ√☆縺ｹ縺ｦ縺ｮ繝医Λ繝・け縺・縺､縺ｮ邱壼ｽ｢螻･豁ｴ縺ｫ荳ｦ縺ｶ
// _history[i] = { track, sceneIndex, tagOverride }
const _history = [];
let _historyCursor = -1;

// 莠呈鋤諤ｧ縺ｮ縺溘ａ繝繝溘・ (旧API繧呈ｮ九☆蜻ｼ縺ｳ蜃ｺ縺励′螢翫ｌ縺ｪ縺・ｈ縺・
function _pushHistory(sceneId, track) {
  if (!track) return;
  const sceneIndex = scenes.findIndex(s => s.id === sceneId);
  _recordPlay(track, sceneIndex, _currentTagOverride);
}

function _recordPlay(track, sceneIndex, tagOverride) {
  if (!track) return;
  // 螻･豁ｴ縺ｮ騾比ｸｭ縺ｧ譁ｰ隕丞・逕・竊・繧ｫ繝ｼ繧ｽ繝ｫ莉･髯阪ｒ蛻・ｊ謐ｨ縺ｦ繧・(繝悶Λ繧ｦ繧ｶ縺ｮ謌ｻ繧・騾ｲ繧と同槁E
  if (_historyCursor < _history.length - 1) {
    _history.length = _historyCursor + 1;
  }
  _history.push({
    track: track,
    sceneIndex: (typeof sceneIndex === 'number' ? sceneIndex : currentSceneIndex),
    tagOverride: tagOverride || null
  });
  _historyCursor = _history.length - 1;
}

function _playTrackInHistory(track) {
  if (!track) return;
  currentTrackData = track;
  const displayTitle = track.title || '';
  trackName.textContent = displayTitle;
  imName.textContent = displayTitle;
  initAudioAnalyser();
  if (audioCtx && audioCtx.state === 'suspended') audioCtx.resume().catch(() => {});
  audio.src = resolveTrackUrl(track);
  audio.load();
  audio.play().catch(() => {});
  if (typeof updateFavButtonState === 'function') updateFavButtonState();
}

// 螻･豁ｴ繧ｨ繝ｳ繝医Μ繧貞・逕・(蠢・ｦ√↑らシーンも復允E
function _playHistoryEntry(entry) {
  if (!entry || !entry.track) return;
  // 繧ｷ繝ｼ繝ｳ縺悟､峨ｏ繧句ｴ蜷医・諠・勹繧ょｾｩ蜈・(updateTrack=false 縺ｧ譖ｲ縺ｯ隗ｦ繧峨↑ぁE
  if (entry.sceneIndex >= 0 && entry.sceneIndex !== currentSceneIndex) {
    selectScene(entry.sceneIndex, false);
    if (entry.tagOverride) {
      overrideSceneImageForTag(entry.tagOverride);
    } else {
      clearSceneImageOverride();
    }
  } else if (entry.sceneIndex < 0) {
    // ウェルカム朁E(シーン未選抁E 縺ｮ繝医Λ繝・け 竊・no-scene-selected に戻ぁE
document.body.classList.add('no-scene-selected');
    currentSceneIndex = -1;
    clearSceneImageOverride();
  }
  _playTrackInHistory(entry.track);
}

// 繝励Ξ繧､繝､繝ｼ蜀・・縲梧ｬ｡縺ｮ譖ｲ縲・ 螻･豁ｴ縺ｮ蜈医′縺ゅｌ縺ｰ騾ｲ繧縲√↑ければ現斁Eц縺ｧ譁ｰ隕城∈曲
function nextTrack() {
  // 螻･豁ｴ縺ｫ蜈医′縺ゅｌ縺ｰ騾ｲ繧
  if (_historyCursor < _history.length - 1) {
    _historyCursor++;
    _playHistoryEntry(_history[_historyCursor]);
    return;
  }
  // 譁ｰ隕城∈曲
  if (currentSceneIndex < 0) {
    // ウェルカム中は welcome track 繧偵ｂ縺・ｸ度
    if (typeof _playWelcomeMusic === 'function') _playWelcomeMusic();
    return;
  }
  const sid = scenes[currentSceneIndex].id;
  // _repeatMode === 'shuffle' 縺ｪ繧臥ｲｾ驪ｭ繝ｪ繧ｹ繝育┌隕悶〒繝ｩ繝ｳ繝繝縲ゅち繧ｰ譌・ｸｭ縺ｯ蟶ｸ縺ｫ繝ｩ繝ｳ繝ムなので影響なぁE
const useShuffle = (typeof _repeatMode !== 'undefined' && _repeatMode === 'shuffle');
  let picked;
  if (_currentTagOverride) {
    picked = pickTrackForTag(_currentTagOverride);
  } else if (useShuffle) {
    picked = pickTrackForSceneShuffle(sid);
  } else {
    picked = pickTrackForScene(sid);
  }
  if (!picked) return;
  _recordPlay(picked, currentSceneIndex, _currentTagOverride);
  _playTrackInHistory(picked);
}

// 繝励Ξ繧､繝､繝ｼ蜀・・縲悟燕縺ｮ譖ｲ縲・ 履歴めEつ戻めE(繧ｷ繝ｼ繝ｳ霍ｨ縺弱・繧ｦ繧ｧ繝ｫ繧ｫ繝譖ｲ繧ょｾｩ蜈・
function prevTrack() {
  if (_historyCursor <= 0) return;
  _historyCursor--;
  _playHistoryEntry(_history[_historyCursor]);
  return;
  // (莉･荳句芦驕比ｸ崎・ / 譌ｧ繧ｳ繝ｼ繝峨・繝繝溘・)
}

$('nextScene').addEventListener('click', nextScene);
$('prevScene').addEventListener('click', prevScene);
$('prevTrackBtn').addEventListener('click', prevTrack);
$('nextTrackBtn').addEventListener('click', nextTrack);
// ボタンのtitleを訂正
$('prevTrackBtn').title = '蜑阪・譖ｲ';
$('nextTrackBtn').title = '次の曲';

// ============ 髻ｳ驥上さ繝ｳ繝医Οール ============
const VOL_KEY = 'hmix_theater_volume';
const MUTE_KEY = 'hmix_theater_muted';
(function() {
  const slider = $('volumeSlider');
  const muteBtn = $('muteBtn');
  const iconOn = $('volIconOn');
  const iconOff = $('volIconOff');
  if (!slider || !muteBtn) return;

  // localStorage から復允E
const savedVol = parseInt(localStorage.getItem(VOL_KEY), 10);
  const savedMute = localStorage.getItem(MUTE_KEY) === '1';
  const startVol = isNaN(savedVol) ? 80 : Math.max(0, Math.min(100, savedVol));
  slider.value = startVol;
  audio.volume = startVol / 100;
  audio.muted = savedMute;
  updateVolIcon();

  function updateVolIcon() {
    const isMuted = audio.muted || audio.volume === 0;
    iconOn.style.display  = isMuted ? 'none' : '';
    iconOff.style.display = isMuted ? '' : 'none';
  }

  slider.addEventListener('input', () => {
    // 繝ｦ繝ｼ繧ｶ繝ｼ縺碁浹驥上ｒ蜍輔°縺励◆らウェルカムフェードをキャンセル
    if (typeof _welcomeFadeTimer !== 'undefined' && _welcomeFadeTimer) {
      clearInterval(_welcomeFadeTimer); _welcomeFadeTimer = null;
    }
    const v = parseInt(slider.value, 10) / 100;
    audio.volume = v;
    if (v > 0 && audio.muted) audio.muted = false;
    localStorage.setItem(VOL_KEY, slider.value);
    localStorage.setItem(MUTE_KEY, audio.muted ? '1' : '0');
    updateVolIcon();
  });

  muteBtn.addEventListener('click', () => {
    if (typeof _welcomeFadeTimer !== 'undefined' && _welcomeFadeTimer) {
      clearInterval(_welcomeFadeTimer); _welcomeFadeTimer = null;
    }
    audio.muted = !audio.muted;
    localStorage.setItem(MUTE_KEY, audio.muted ? '1' : '0');
    updateVolIcon();
  });
})();

// ============ 繝励Ο繝ｭ繝ｼ繧ｰ繝ｻ豐｡蜈･繝｢繝ｼ繝峨・髻ｳ驥上せ繝ｩ繧､繝ー同期 ============
// メインの #volumeSlider と #imVolumeSlider 繧貞酔譛溘☆繧九・
(function() {
  const mainSlider = document.getElementById('volumeSlider');
  const imSlider   = document.getElementById('imVolumeSlider');
  const imMute     = document.getElementById('imVolumeMute');
  const imIconOn   = document.getElementById('imVolIconOn');
  const imIconOff  = document.getElementById('imVolIconOff');
  if (!mainSlider) return;
  function syncAllFromValue(v) {
    if (imSlider  && imSlider.value  != v) imSlider.value  = v;
    if (mainSlider.value != v) mainSlider.value = v;
    try { localStorage.setItem('hmix_theater_volume', v); } catch(_) {}
  }
  function updateImIcon() {
    const muted = audio.muted || audio.volume === 0;
    if (imIconOn)  imIconOn.style.display  = muted ? 'none' : '';
    if (imIconOff) imIconOff.style.display = muted ? '' : 'none';
  }

  // 初期値めElocalStorage 縺九ｉ蠕ｩ蜈・＠縲・縺､縺ｮ繧ｹ繝ｩ繧､繝ー全てに反映
  let saved = parseInt(localStorage.getItem('hmix_theater_volume'), 10);
  if (isNaN(saved)) saved = 80;
  syncAllFromValue(saved);

  function onInput(e) {
    const v = parseInt(e.target.value, 10);
    // ウェルカムフェード中ならキャンセル
    if (typeof _welcomeFadeTimer !== 'undefined' && _welcomeFadeTimer) {
      clearInterval(_welcomeFadeTimer); _welcomeFadeTimer = null;
    }
    audio.volume = v / 100;
    if (v > 0 && audio.muted) audio.muted = false;
    syncAllFromValue(v);
    updateImIcon();
  }
  if (imSlider)  imSlider.addEventListener('input', onInput);
  // 繝｡繧､繝ｳ繧ｹ繝ｩ繧､繝ーの change 繧ょ酔譛溷・縺ｸ莨晄眺 (譌｢蟄倥ワ繝ｳ繝峨Λ縺ｯ迢ｬ遶九↓ localStorage 譖ｴ譁ｰ縺吶ｋ縺後∽ｸ頑嶌縺阪〒謨ｴ蜷・
  mainSlider.addEventListener('input', () => syncAllFromValue(mainSlider.value));

  if (imMute) {
    imMute.addEventListener('click', () => {
      if (typeof _welcomeFadeTimer !== 'undefined' && _welcomeFadeTimer) {
        clearInterval(_welcomeFadeTimer); _welcomeFadeTimer = null;
      }
      audio.muted = !audio.muted;
      try { localStorage.setItem('hmix_theater_muted', audio.muted ? '1' : '0'); } catch(_) {}
      updateImIcon();
    });
  }

  // 音声 volume/muted 螟画峩譎ゅ↓アイコン更新
  audio.addEventListener('volumechange', updateImIcon);
  updateImIcon();
})();

addEventListener('keydown', e => {
  // 繝・く繧ｹ繝亥・蜉帑ｸｭ縺ｯ辟｡隕・(form の中でキー操作してる可能性)
  const tag = (e.target && e.target.tagName) || '';
  if (tag === 'INPUT' || tag === 'TEXTAREA' || (e.target && e.target.isContentEditable)) return;

  // 遏｢蜊ｰ繧ｭ繝ｼ縺ｯ縲檎樟繧ｷ繝ｼ繝ｳ蜀・・蜑榊ｾ梧峇縲・繧ｿ繧ｰ譌・ｸｭ縺ｪ繧峨ち繧ｰ繝励・繝ｫ蜀・
  if (e.key === 'ArrowRight') nextTrack();
  if (e.key === 'ArrowLeft')  prevTrack();
  if (e.key === ' ') { e.preventDefault(); playBtn.click(); }
  if (e.key === 'Escape') {
    // ESC 優先度: 繝倥ΝチE> ライセンス > 確誁E> 縺頑ｰ励↓入めE> 没入モード解除
    const help = document.getElementById('helpPanel');
    if (help && help.classList.contains('visible')) { help.classList.remove('visible'); return; }
    exitImmersive();
  }
  if (e.key === '?' || (e.shiftKey && e.key === '/')) {
    e.preventDefault();
    const help = document.getElementById('helpPanel');
    if (help) help.classList.toggle('visible');
  }
});

// 繝倥Ν繝励ヱ繝阪Ν (譌・・縺励♀めE 開閉
(function() {
  const trigger = document.getElementById('helpTrigger');
  const panel   = document.getElementById('helpPanel');
  const closeBtn= document.getElementById('helpClose');
  if (!trigger || !panel) return;
  trigger.addEventListener('click', (e) => {
    e.stopPropagation();
    panel.classList.add('visible');
  });
  if (closeBtn) closeBtn.addEventListener('click', () => panel.classList.remove('visible'));
  // 螟門・繧ｯ繝ｪ繝・け縺ｧ髢峨§めE
panel.addEventListener('click', (e) => {
    if (e.target === panel) panel.classList.remove('visible');
  });
})();

// ============ 再生モーチE scene / one / shuffle の3抁E============
//  scene   = 繧ｷ繝ｼ繝ｳ繝ｪ繝斐・繝・(邊ｾ驪ｭ繝ｪ繧ｹ繝磯・竊・繧ｿ繧ｰ繝励・繝ｫ繝ｩ繝ｳ繝ム)
//  one     = 1譖ｲ繝ｪ繝斐・繝・(audio.loop = true)
//  shuffle = 繧ｷ繝｣繝・ヵ繝ｫ (邊ｾ驪ｭ繝ｪ繧ｹ繝育┌隕悶√す繝ｼ繝ｳ蜀・°繧牙ｮ悟・繝ｩ繝ｳ繝ム)
let _repeatMode = 'scene';

// アイコン SVG (path のみ、viewBox 縺ｯ譌｢蟄倩ｦ∫ｴ繧剃ｽｿ逕ｨ)
const _ICON_REPEAT_SCENE = '<path d="M17 1l4 4-4 4M3 11V9a4 4 0 014-4h14M7 23l-4-4 4-4M21 13v2a4 4 0 01-4 4H3"/>';
const _ICON_REPEAT_ONE   = '<path d="M17 1l4 4-4 4M3 11V9a4 4 0 014-4h14M7 23l-4-4 4-4M21 13v2a4 4 0 01-4 4H3"/><text x="12" y="15" text-anchor="middle" font-size="8" font-weight="700" fill="currentColor" stroke="none" style="font-family: sans-serif, \'Noto Sans JP\'">1</text>';
const _ICON_SHUFFLE      = '<path d="M16 3h5v5M4 20l17-17M21 16v5h-5M15 15l6 6M4 4l5 5"/>';

function _applyRepeatMode() {
  const btn  = $('loopBtn');
  const icon = $('loopBtnIcon');
  if (!btn || !icon) return;
  if (_repeatMode === 'one') {
    icon.innerHTML = _ICON_REPEAT_ONE;
    btn.title = '1譖ｲ繝ｪ繝斐・繝・(繧ｯ繝ｪ繝・け縺ｧ繧ｷ繝｣繝・ヵ繝ｫ縺ｸ)';
    btn.setAttribute('aria-label', '1譖ｲ繝ｪ繝斐・繝井ｸｭ 窶・繧ｯ繝ｪ繝・け縺ｧ繧ｷ繝｣繝・ヵ繝ｫ縺ｫ蛻・崛');
    audio.loop = true;
    btn.classList.add('active');
  } else if (_repeatMode === 'shuffle') {
    icon.innerHTML = _ICON_SHUFFLE;
    btn.title = '繧ｷ繝｣繝・ヵ繝ｫ (繧ｯ繝ｪ繝・け縺ｧ繧ｷ繝ｼ繝ｳ繝ｪ繝斐・繝医∈)';
    btn.setAttribute('aria-label', '繧ｷ繝｣繝・ヵ繝ｫ荳ｭ 窶・繧ｯ繝ｪ繝・け縺ｧ繧ｷ繝ｼ繝ｳ繝ｪ繝斐・繝医↓蛻・崛');
    audio.loop = false;
    btn.classList.add('active');
  } else {
    icon.innerHTML = _ICON_REPEAT_SCENE;
    btn.title = '繧ｷ繝ｼ繝ｳ繝ｪ繝斐・繝・(繧ｯ繝ｪ繝・け縺ｧ1譖ｲ繝ｪ繝斐・繝医∈)';
    btn.setAttribute('aria-label', '繧ｷ繝ｼ繝ｳ繝ｪ繝斐・繝井ｸｭ 窶・繧ｯ繝ｪ繝・け縺ｧ1譖ｲ繝ｪ繝斐・繝医↓蛻・崛');
    audio.loop = false;
    btn.classList.remove('active');
  }
}

$('loopBtn').addEventListener('click', () => {
  _repeatMode = (_repeatMode === 'scene') ? 'one'
             : (_repeatMode === 'one')   ? 'shuffle'
             : 'scene';
  _applyRepeatMode();
});
_applyRepeatMode();

// 繧ｷ繝｣繝・ヵ繝ｫ逕ｨ: 邊ｾ驪ｭ繝ｪ繧ｹ繝医ｒ辟｡隕悶＠縺溘す繝ｼ繝ｳ蜀・Λ繝ｳ繝ム選曲
function pickTrackForSceneShuffle(sceneId) {
  if (typeof TRACKS === 'undefined') return null;
  const candidates = findTracksForScene(sceneId);
  if (!candidates.length) return null;
  if (candidates.length === 1) return candidates[0];
  let picked, tries = 0;
  do {
    picked = candidates[Math.floor(Math.random() * candidates.length)];
    tries++;
  } while (currentTrackData && picked.id === currentTrackData.id && tries < 20);
  return picked;
}

// ============ 縺頑ｰ励↓蜈･繧頑ｩ溯・ ============
const FAV_KEY = 'hmix_theater_favorites_v1';
let favorites = [];
let selectedFavIds = new Set();
let draggedFavId = null;
let favPanelOpen = false;
let playQueue = null; // {ids: [...], currentIdx: 0, shuffle: bool}

function loadFavorites() {
  try {
    const raw = localStorage.getItem(FAV_KEY);
    if (raw) favorites = JSON.parse(raw);
  } catch (e) { console.warn(e); }
  updateFavBadge();
}

function saveFavorites() {
  try {
    localStorage.setItem(FAV_KEY, JSON.stringify(favorites));
  } catch (e) { console.warn(e); }
  updateFavBadge();
}

function updateFavBadge() {
  const badge = $('favBadge');
  if (favorites.length > 0) {
    badge.textContent = favorites.length;
    badge.classList.add('visible');
  } else {
    badge.classList.remove('visible');
  }
  $('favCount').textContent = `${favorites.length} tracks`;
}

function _currentFavKey() {
  const tid = currentTrackData ? currentTrackData.id : null;
  if (!tid) return null;
  // シーン未選抁E(ウェルカム曲 縺九●縺ｮ縺薙∴ など) 縺ｮ蝣ｴ蜷医・ 'welcome' スコープで登録
  if (currentSceneIndex < 0) return `welcome:${tid}`;
  const scene = scenes[currentSceneIndex];
  return `${scene.id}:${tid}`;
}

function isCurrentFavorited() {
  const key = _currentFavKey();
  if (!key) return false;
  return favorites.some(f => f.id === key);
}

function toggleCurrentFavorite() {
  const key = _currentFavKey();
  if (!key) return;
  // シーン未選択時 (ウェルカム曲) 縺ｯ繝繝溘・縺ｮ scene を用愁E
const scene = (currentSceneIndex >= 0) ? scenes[currentSceneIndex] : {
    id: 'welcome',
    jp: '縺九●縺ｮ縺薙∴',
    thumb: '/assets/images/scenes/forest.webp'
  };
  const existing = favorites.findIndex(f => f.id === key);
  const wasAdding = existing < 0;

  if (existing >= 0) {
    favorites.splice(existing, 1);
  } else {
    const displayTitle = currentTrackData ? (currentTrackData.title || '') : '';
    const trackUrl = currentTrackData ? resolveTrackUrl(currentTrackData) : null;
    favorites.push({
      id: key,
      trackName: displayTitle,
      track: trackUrl,
      trackId: currentTrackData ? currentTrackData.id : null,
      sceneId: scene.id,
      sceneName: scene.jp,
      thumb: scene.thumb,
      savedAt: Date.now()
    });
  }
  saveFavorites();
  updateFavButtonState();
  renderFavList();

  // 追加晁E 繝代ロ繝ｫ繧剃ｸ迸ｬ髢九＞縺ｦ隧ｲ蠖薙き繝ｼ繝峨ｒ蜈峨ｉ縺帙・遘貞ｾ後↓閾ｪ蜍輔〒髢峨§めE
if (wasAdding) _flashFavoriteAdded(key);
}

// 縺頑ｰ励↓蜈･繧願ｿｽ蜉繝輔ぅ繝ｼ繝峨ヰ繝・け: 繝代ロ繝ｫ繧偵・繝ｬ繝薙Ηー表示 ↁE新カードを光らせる 竊・3遘貞ｾ後↓髢峨§めE
let _favAutoCloseTimer = null;
let _favAutoCloseCancel = null;
function _flashFavoriteAdded(favId) {
  const wasOpen = favPanelOpen;
  if (!wasOpen) {
    favPanelOpen = true;
    favPanel.classList.add('visible');
    favTrigger.classList.add('active');
    renderFavList();
  }
  // 谺｡繝輔Ξ繝ｼ繝縺ｧ隧ｲ蠖薙き繝ｼ繝峨ｒ謗｢縺励※光らせる (renderFavList蠕後・DOM反映征E■)
  requestAnimationFrame(() => {
    const card = favPanel.querySelector('.fav-card[data-id="' + CSS.escape(favId) + '"]');
    if (card) {
      card.classList.add('just-added');
      try { card.scrollIntoView({ behavior: 'smooth', block: 'center' }); } catch(_) {}
      setTimeout(() => { card.classList.remove('just-added'); }, 3200);
    }
  });

  // 允E・哩縺倥※ぁE◆蝣ｴ蜷医・縺ｿ縲・遘貞ｾ後↓閾ｪ蜍輔〒髢峨§めE
if (!wasOpen) {
    clearTimeout(_favAutoCloseTimer);
    // 譌｢蟄倥・繧ｭ繝｣繝ｳ繧ｻ繝ｫ逶｣隕悶ｒ螟悶☆
    if (_favAutoCloseCancel) _favAutoCloseCancel();

    const cancelOnInteract = () => {
      clearTimeout(_favAutoCloseTimer);
      if (_favAutoCloseCancel) { _favAutoCloseCancel(); _favAutoCloseCancel = null; }
    };
    // 繝代ロ繝ｫ蜀・・謫堺ｽ・(繧ｯ繝ｪ繝・け繝ｻ繧ｹ繧ｯ繝ｭ繝ｼ繝ｫ) で自動クローズをキャンセル
    favPanel.addEventListener('mousedown', cancelOnInteract, { once: true });
    favPanel.addEventListener('touchstart', cancelOnInteract, { once: true, passive: true });
    favPanel.addEventListener('wheel', cancelOnInteract, { once: true, passive: true });
    _favAutoCloseCancel = () => {
      favPanel.removeEventListener('mousedown', cancelOnInteract);
      favPanel.removeEventListener('touchstart', cancelOnInteract);
      favPanel.removeEventListener('wheel', cancelOnInteract);
    };

    _favAutoCloseTimer = setTimeout(() => {
      if (favPanelOpen) {
        favPanelOpen = false;
        favPanel.classList.remove('visible');
        favTrigger.classList.remove('active');
        if (typeof hideLicenseGuide === 'function') hideLicenseGuide();
      }
      if (_favAutoCloseCancel) { _favAutoCloseCancel(); _favAutoCloseCancel = null; }
    }, 3000);
  }
}

function updateFavButtonState() {
  const favBtn = $('favBtn'); // 繝励Ξ繧､繝､繝ｼ蜀・・笙｡
  if (isCurrentFavorited()) {
    favBtn.classList.add('active');
    favBtn.querySelector('svg').classList.add('filled');
  } else {
    favBtn.classList.remove('active');
    favBtn.querySelector('svg').classList.remove('filled');
  }
}

// 譌｢蟄倥・favBtn縺ｮ繧ｯ繝ｪ繝・け繧剃ｸ頑嶌縺・
$('favBtn').onclick = () => {
  toggleCurrentFavorite();
};

// 縺頑ｰ励↓蜈･繧翫ヱ繝阪Νの開閉
const favTrigger = $('favTrigger');
const favPanel = $('favPanel');
const favClose = $('favClose');

favTrigger.addEventListener('click', () => {
  favPanelOpen = !favPanelOpen;
  favPanel.classList.toggle('visible', favPanelOpen);
  favTrigger.classList.toggle('active', favPanelOpen);
  if (favPanelOpen) {
    renderFavList();
    if (ringsOpen) closeRings();
  }
});
favClose.addEventListener('click', () => {
  favPanelOpen = false;
  favPanel.classList.remove('visible');
  favTrigger.classList.remove('active');
  hideLicenseGuide();
});

// 繝代ロ繝ｫ螟悶け繝ｪ繝・け縺ｧ髢峨§めEdo
cument.addEventListener('click', (e) => {
  if (!favPanelOpen) return;
  const t = e.target;
  // 繝代ロ繝ｫ譛ｬ菴薙・繝医Μ繧ｬ繝ｼ繝ｻ蜷・ｨｮ繝｢繝ｼ繝ル/繧ｪ繝ｼ繝舌・繝ｬ繧､蜀・・繧ｯ繝ｪ繝・け縺ｯ辟｡隕・
if (t.closest('.fav-panel')) return;
  if (t.closest('#favTrigger')) return;
  if (t.closest('#playerLicenseLink')) return;
  if (t.closest('.license-modal')) return;
  if (t.closest('.confirm-modal')) return;
  if (t.closest('.footprint-form-modal')) return;
  if (t.closest('.footprint-tooltip')) return;
  if (t.closest('.travel-menu')) return;
  if (t.closest('.rest-timer-menu')) return;
  // 蛻･縺ｮ繝｢繝ｼ繝ルが開ぁE※縺・ｋ髢薙ｂ繧ｹ繝ｫ繝ｼ (縺昴■繧峨・髢峨§繧句・逅・↓任せる)
  if (document.querySelector('.license-modal.visible, .confirm-modal.visible, .footprint-form-modal.visible')) return;
  favClose.click();
}, true);

// ============ ライセンス取得ガイチE(繧ｷ繝ｼ繧ｫ繝ｼ謚陦馴｢ｨ貍泌・) ============
let _licenseGuideActive = false;

// 遏｢蜊ｰ繧貞ｯｾ雎｡隕∫ｴ縺ｮ逵滉ｸ翫↓配置
function _positionGuideArrow() {
  const arrow = $('licenseGuideArrow');
  if (!arrow || !_licenseGuideActive) return;

  let target = null;
  if (selectedFavIds.size > 0) {
    // 驕ｸ謚槭≠繧・竊・蝠・畑繝ｩ繧､繧ｻ繝ｳ繧ｹ逕ｳ隲九・繧ｿ繝ｳ縺ｮ荳翫∈
    target = $('btnLicenseSelected');
  } else {
    // 驕ｸ謚槭↑縺・竊・譛蛻昴・繝√ぉ繝・け繝懊ャ繧ｯ繧ｹ (譛ｪ驕ｸ謚槭・繧ｫ繝ｼ繝・
    target = document.querySelector('.fav-card:not(.selected) .card-action[data-action="select"]')
          || document.querySelector('.fav-card .card-action[data-action="select"]');
  }

  if (!target) { arrow.style.visibility = 'hidden'; return; }

  const rect = target.getBoundingClientRect();
  const arrowW = 56, arrowH = 56;
  const gap = 10;
  arrow.style.left = (rect.left + rect.width / 2 - arrowW / 2) + 'px';
  arrow.style.top  = (rect.top - arrowH - gap) + 'px';
  arrow.style.visibility = 'visible';
}

// チEΟ繝・・繧・fav panel 縺ｮ荳企Κ (繝・・繝ｫ繝舌・荳・ に動的配置
function _positionGuideTelop() {
  const telop = $('licenseGuideTelop');
  const panel = $('favPanel');
  if (!telop || !panel || !_licenseGuideActive) return;
  const panelRect = panel.getBoundingClientRect();
  const toolbar = panel.querySelector('.fav-toolbar');
  let targetTop;
  if (toolbar) {
    const tbRect = toolbar.getBoundingClientRect();
    targetTop = tbRect.bottom + 8;  // 繝・・繝ｫ繝舌・逶ｴ荳・  } else {
    targetTop = panelRect.top + 150;  // fallback
  }
  // 水平位置: fav panel の中央に合わせる (transform: translate(-50%, 0) 縺ｧ荳ｭ蠢・純縺・
  const centerX = panelRect.left + panelRect.width / 2;
  telop.style.left = centerX + 'px';
  telop.style.top  = targetTop + 'px';
}

// 縺ｩ縺薙°繧ｯ繝ｪ繝・け縺ｧ豸医☆繝上Φドラ
function _onGuideDismissClick(e) {
  const t = e.target;
  // 蟇ｾ雎｡隕∫ｴ繧ｯ繝ｪ繝・け譎ゅ・ dismiss 縺励↑ぁE(遏｢蜊ｰ隱伜ｰ弱・邯咏ｶ・
  if (t.closest('.card-action[data-action="select"]')) return;
  if (t.closest('#btnLicenseSelected')) return;
  if (t.closest('#playerLicenseLink')) return;
  hideLicenseGuide();
}

function showLicenseGuide() {
  const telop = $('licenseGuideTelop');
  const arrow = $('licenseGuideArrow');
  if (!telop) return;
  _licenseGuideActive = true;
  document.body.classList.add('license-guide-mode');
  telop.classList.remove('leaving');
  telop.classList.add('visible');
  telop.setAttribute('aria-hidden', 'false');
  if (arrow) {
    arrow.classList.add('visible');
    arrow.setAttribute('aria-hidden', 'false');
  }
  // 驟咲ｽｮ繧呈ｬ｡繝輔Ξームで反映 (fav panel の show transition 螳御ｺ・ｾ・■)
  setTimeout(() => { _positionGuideArrow(); _positionGuideTelop(); }, 50);
  setTimeout(() => { _positionGuideArrow(); _positionGuideTelop(); }, 400);  // 繝代ロ繝ｫ縺ｮ繧｢繝九Γ螳御ｺ・ｾ後↓繧ょ・驟咲ｽｮ

  // 蟆代＠驕・ｉ縺帙※繧ｰ繝ｭ繝ｼ繝舌Ν繧ｯ繝ｪ繝・け繝ｪ繧ｹ繝翫・逋ｻ骭ｲ (繝医Μ繧ｬ繝ｼ繧ｯ繝ｪ繝・け縺ｮ繝舌ヶ繝ｫ繧帝∩ける)
  setTimeout(() => {
    document.addEventListener('click', _onGuideDismissClick, true);
  }, 60);
}

function hideLicenseGuide() {
  if (!_licenseGuideActive) return;
  _licenseGuideActive = false;
  const telop = $('licenseGuideTelop');
  const arrow = $('licenseGuideArrow');
  document.body.classList.remove('license-guide-mode');
  document.removeEventListener('click', _onGuideDismissClick, true);
  if (telop) {
    telop.classList.add('leaving');
    telop.setAttribute('aria-hidden', 'true');
    setTimeout(() => {
      if (!_licenseGuideActive) {
        telop.classList.remove('visible');
        telop.classList.remove('leaving');
      }
    }, 320);
  }
  if (arrow) {
    arrow.classList.remove('visible');
    arrow.setAttribute('aria-hidden', 'true');
  }
}

// 驕ｸ謚槫､牙喧譎ゅ↓遏｢蜊ｰ繧貞・驟咲ｽｮ (ウィンドウリサイズ時も)
window.addEventListener('resize', () => { if (_licenseGuideActive) _positionGuideArrow(); });

// 繝励Ξ繧､繝､繝ｼ縺ｮ縲後Λ繧､繧ｻ繝ｳ繧ｹ繧貞叙蠕・竊偵阪Μンク
(function() {
  const link = $('playerLicenseLink');
  if (!link) return;
  link.addEventListener('click', (e) => {
    e.preventDefault();
    // リング展開中なら閉じる
    if (ringsOpen) closeRings();
    // 縺頑ｰ励↓蜈･繧翫ヱ繝阪Νを開ぁE
if (!favPanelOpen) {
      favPanelOpen = true;
      favPanel.classList.add('visible');
      favTrigger.classList.add('active');
      renderFavList();
    }
    // ガイド発勁E    showLicenseGuide();
  });
})();

// 驕ｸ謚槫､画峩譎ゅ↓遏｢蜊ｰ繧貞・驟咲ｽｮ (繝√ぉ繝・け譛臥┌縺ｧ遘ｻ蜍募・縺悟､峨ｏ繧・
(function() {
  const originalUpdateFooter = updateFooter;
  updateFooter = function() {
    originalUpdateFooter.apply(this, arguments);
    if (_licenseGuideActive) {
      // 谺｡繝輔Ξ繝ｼ繝縺ｧ證ｫ螳夐・鄂ｮ
      requestAnimationFrame(_positionGuideArrow);
      // fav-footer のスライドイン (transform 0.4s) 螳御ｺ・ｾ後↓譛邨ゆｽ咲ｽｮ繧貞・險育ｮ・      // 蛻晏屓繝√ぉ繝・け譎・ footer ぁEtranslateY(100%) 竊・0 縺ｸ遘ｻ蜍輔☆繧九◆めE      // getBoundingClientRect 縺碁比ｸｭ縺ｮ荳区婿蠎ｧ讓吶ｒ霑斐＠縺ｦ縺励∪縺・・繧定｣懈ｭ｣
      setTimeout(_positionGuideArrow, 460);
    }
  };
})();

// リスト描画
function renderFavList() {
  const list = $('favList');

  if (favorites.length === 0) {
    list.innerHTML = `
      <div class="fav-empty">
        <div class="heart-icon">
          <svg viewBox="0 0 24 24"><path d="M20.84 4.61a5.5 5.5 0 00-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 00-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 000-7.78z"/></svg>
        </div>
        <div class="msg-jp">まだ記録はありません</div>
        <div class="msg-en">Let the journey begin</div>
      </div>
    `;
    selectedFavIds.clear();
    updateFooter();
    return;
  }

  list.innerHTML = favorites.map((f, i) => {
    const isSelected = selectedFavIds.has(f.id);
    const isPlaying = playQueue && playQueue.ids[playQueue.currentIdx] === f.id && !audio.paused;
    return `
      <div class="fav-card ${isSelected ? 'selected' : ''} ${isPlaying ? 'playing' : ''}"
           data-id="${f.id}"
           draggable="true">
        <div class="drag-handle">
          <svg viewBox="0 0 10 14"><circle cx="3" cy="3" r="1.2"/><circle cx="7" cy="3" r="1.2"/><circle cx="3" cy="7" r="1.2"/><circle cx="7" cy="7" r="1.2"/><circle cx="3" cy="11" r="1.2"/><circle cx="7" cy="11" r="1.2"/></svg>
        </div>
        <div class="thumb" style="background-image: url(${f.thumb})"></div>
        <div class="info">
          <div class="name">${f.trackName}</div>
          <div class="meta">秋山裕和 ﾂｷ <span class="scene-tag">${f.sceneName}</span></div>
        </div>
        <div class="card-actions">
          <button class="card-action play-action" data-action="play" title="再生">
            <svg viewBox="0 0 24 24" class="filled"><path d="M8 5v14l11-7L8 5z"/></svg>
          </button>
          <button class="card-action" data-action="select" title="選抁E>
            ${isSelected
              ? '<svg viewBox="0 0 24 24" class="filled"><path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"/></svg>'
              : '<svg viewBox="0 0 24 24"><rect x="4" y="4" width="16" height="16" rx="2"/></svg>'
            }
          </button>
          <button class="card-action delete-action" data-action="delete" title="削除">
            <svg viewBox="0 0 24 24"><path d="M3 6h18M8 6V4a2 2 0 012-2h4a2 2 0 012 2v2M19 6l-1 14a2 2 0 01-2 2H8a2 2 0 01-2-2L5 6"/></svg>
          </button>
        </div>
      </div>
    `;
  }).join('');

  // 繧､繝吶ΦチE
list.querySelectorAll('.fav-card').forEach(card => {
    const id = card.dataset.id;
    const fav = favorites.find(f => f.id === id);

    // 繧ｫ繝ｼ繝峨け繝ｪ繝・け = 選択トグル
    card.addEventListener('click', e => {
      if (e.target.closest('.card-action')) return;
      if (selectedFavIds.has(id)) selectedFavIds.delete(id);
      else selectedFavIds.add(id);
      renderFavList();
    });

    card.querySelector('[data-action="play"]').addEventListener('click', e => {
      e.stopPropagation();
      playFavorite(fav);
    });
    card.querySelector('[data-action="select"]').addEventListener('click', e => {
      e.stopPropagation();
      if (selectedFavIds.has(id)) selectedFavIds.delete(id);
      else selectedFavIds.add(id);
      renderFavList();
    });
    card.querySelector('[data-action="delete"]').addEventListener('click', e => {
      e.stopPropagation();
      const idx = favorites.findIndex(f => f.id === id);
      if (idx >= 0) {
        favorites.splice(idx, 1);
        selectedFavIds.delete(id);
        saveFavorites();
        renderFavList();
        updateFavButtonState();
      }
    });

    // 繝峨Λ繝・げ荳ｦ縺ｳ譖ｿ縺・
card.addEventListener('dragstart', e => {
      draggedFavId = id;
      card.classList.add('dragging');
      e.dataTransfer.effectAllowed = 'move';
    });
    card.addEventListener('dragend', () => {
      card.classList.remove('dragging');
      list.querySelectorAll('.drag-over').forEach(c => c.classList.remove('drag-over'));
      draggedFavId = null;
    });
    card.addEventListener('dragover', e => {
      e.preventDefault();
      if (id !== draggedFavId) card.classList.add('drag-over');
    });
    card.addEventListener('dragleave', () => card.classList.remove('drag-over'));
    card.addEventListener('drop', e => {
      e.preventDefault();
      if (!draggedFavId || draggedFavId === id) return;
      const srcIdx = favorites.findIndex(f => f.id === draggedFavId);
      const dstIdx = favorites.findIndex(f => f.id === id);
      if (srcIdx < 0 || dstIdx < 0) return;
      const [moved] = favorites.splice(srcIdx, 1);
      favorites.splice(dstIdx, 0, moved);
      saveFavorites();
      renderFavList();
    });
  });

  updateFooter();
}

function updateFooter() {
  const footer = $('favFooter');
  const count = selectedFavIds.size;
  if (count > 0) {
    footer.classList.add('visible');
    $('favFooterInfo').textContent = `${count} 譖ｲ繧帝∈択中`;
  } else {
    footer.classList.remove('visible');
  }
}

function playFavorite(fav) {
  // 諠・勹蛻・崛 (あれば)
  const targetIdx = scenes.findIndex(s => s.id === fav.sceneId);
  if (targetIdx >= 0) {
    selectScene(targetIdx, false);
  }

  // 螳溘ヨ繝ｩ繝・け繝・・繧ｿ繧貞ｾｩ蜈・(笙｡繝医げ繝ｫ縺梧ｭ｣縺励￥蜍輔￥繧医≧に)
  if (fav.trackId && typeof TRACKS !== 'undefined') {
    const real = TRACKS.find(t => t.id === fav.trackId);
    if (real) currentTrackData = real;
  }

  trackName.textContent = fav.trackName;
  imName.textContent = fav.trackName;

  initAudioAnalyser();
  if (audioCtx && audioCtx.state === 'suspended') audioCtx.resume();
  audio.src = fav.track;
  audio.load();
  audio.play().catch(() => {});

  // キュー開姁E単佁E
  playQueue = { ids: [fav.id], currentIdx: 0, shuffle: false };
  renderFavList();
}

// 繝・・繝ｫ繝舌・繝懊ち繝ｳ
$('toolPlayAll').addEventListener('click', () => {
  if (favorites.length === 0) return;
  playQueue = { ids: favorites.map(f => f.id), currentIdx: 0, shuffle: false };
  playFavorite(favorites[0]);
});
$('toolShuffle').addEventListener('click', () => {
  if (favorites.length === 0) return;
  const shuffled = [...favorites].sort(() => Math.random() - 0.5);
  playQueue = { ids: shuffled.map(f => f.id), currentIdx: 0, shuffle: true };
  playFavorite(shuffled[0]);
});
$('toolDlAll').addEventListener('click', () => {
  if (favorites.length === 0) { showConfirm('繝繧ｦ繝ｳ繝ｭ繝ｼ繝峨☆繧区峇縺後≠繧翫∪せん', () => {}); return; }
  // チEΔ用: 蜷・峇縺ｮMP3URL繧貞句挨縺ｫ繝ウンローチE
favorites.forEach((f, i) => {
    setTimeout(() => {
      const a = document.createElement('a');
      a.href = f.track;
      a.download = `${f.trackName}.mp3`;
      document.body.appendChild(a);
      a.click();
      a.remove();
    }, i * 400);
  });
});
$('toolExport').addEventListener('click', () => {
  const data = JSON.stringify(favorites, null, 2);
  const blob = new Blob([data], { type: 'application/json' });
  const url = URL.createObjectURL(blob);
  const a = document.createElement('a');
  a.href = url;
  a.download = `hmix_favorites_${new Date().toISOString().slice(0,10)}.json`;
  document.body.appendChild(a);
  a.click();
  a.remove();
  URL.revokeObjectURL(url);
});
$('toolImport').addEventListener('click', () => {
  const input = document.createElement('input');
  input.type = 'file';
  input.accept = 'application/json';
  input.addEventListener('change', e => {
    const file = e.target.files[0];
    if (!file) return;
    const reader = new FileReader();
    reader.onload = ev => {
      try {
        const imported = JSON.parse(ev.target.result);
        if (!Array.isArray(imported)) return;
        // 譌｢蟄倥↓追加 (驥崎､・勁螟・
        const existingIds = new Set(favorites.map(f => f.id));
        imported.forEach(f => {
          if (f.id && !existingIds.has(f.id)) favorites.push(f);
        });
        saveFavorites();
        renderFavList();
        updateFavButtonState();
      } catch (err) { console.warn(err); }
    };
    reader.readAsText(file);
  });
  input.click();
});
$('toolClear').addEventListener('click', () => {
  if (favorites.length === 0) return;
  showConfirm('縺吶∋縺ｦ縺ｮ險倬鹸繧貞炎髯､縺励∪縺吶・br>よろしいですか?', () => {
    favorites = [];
    selectedFavIds.clear();
    saveFavorites();
    renderFavList();
    updateFavButtonState();
  });
});

// フッター
$('btnClearSelection').addEventListener('click', () => {
  selectedFavIds.clear();
  renderFavList();
});
$('btnLicenseSelected').addEventListener('click', () => {
  if (selectedFavIds.size === 0) return;
  openLicenseModal([...selectedFavIds]);
});

// 遒ｺ隱阪Δ繝ｼ繝ル
function showConfirm(msg, onOk) {
  $('confirmMsg').innerHTML = msg;
  $('confirmModal').classList.add('visible');
  const ok = $('confirmOk');
  const cancel = $('confirmCancel');

  const close = () => {
    $('confirmModal').classList.remove('visible');
    ok.onclick = null;
    cancel.onclick = null;
  };
  ok.onclick = () => { onOk(); close(); };
  cancel.onclick = close;
}

// ============ 繝ｩ繧､繧ｻ繝ｳ繧ｹ逕ｳ隲九Δ繝ｼ繝ル (螟夜Κ繝ｩ繧､繧ｻ繝ｳ繧ｹ繝壹・繧ｸ縺ｸ縺ｮ蟆守ｷ・ ============
const licenseModal = $('licenseModal');

function openLicenseModal(favIds) {
  const selected = favorites.filter(f => favIds.includes(f.id));
  if (selected.length === 0) return;

  // 楽曲リスト描画
  const listEl = $('licenseList');
  listEl.innerHTML = selected.map(f => `
    <li>
      <span>${f.trackName} <span style="color:rgba(212,164,76,0.55); font-size:10px; margin-left:8px;">(${f.sceneName})</span></span>
    </li>
  `).join('');

  // 縲檎筏隲九・繝ｼ繧ｸ縺ｸ騾ｲ繧 竊偵阪・ href に tracks 繝代Λ繝｡繝ｼ繧ｿ繧剃ｻ戊ｾｼ繧
  const trackIds = selected.map(f => String(f.trackId || f.id)).filter(Boolean);
  const href = '/license-request.html#tracks=' + encodeURIComponent(trackIds.join(','));
  const submitBtn = $('licenseSubmit');
  if (submitBtn) {
    submitBtn.href = href;
    submitBtn.target = '_blank';
    submitBtn.rel = 'noopener';
  }

  licenseModal.classList.add('visible');
  licenseModal.dataset.favIds = JSON.stringify(favIds);
}

function closeLicenseModal() {
  licenseModal.classList.remove('visible');
}
$('licenseClose').addEventListener('click', closeLicenseModal);
$('licenseCancel').addEventListener('click', closeLicenseModal);

// 逕ｳ隲九・繝ｼ繧ｸ驕ｷ遘ｻ蠕後↓繝｢繝ｼ繝ルを閉じる (次回開ぁE◆譎ゅ↓新鮮な状慁E
$('licenseSubmit').addEventListener('click', () => {
  // 譁ｰ繧ｿ繝悶〒逕ｳ隲九・繝ｼ繧ｸ縺碁幕縺・◆繧峨√す繧｢繧ｿ繝ｼ縺ｮ繝｢繝ｼ繝繝ｫ縺ｯ髢峨§めE
setTimeout(closeLicenseModal, 300);
});

// ESC 縺ｧ髢峨§めE
addEventListener('keydown', e => {
  if (e.key === 'Escape') {
    if (licenseModal.classList.contains('visible')) closeLicenseModal();
    else if ($('confirmModal').classList.contains('visible')) $('confirmModal').classList.remove('visible');
    else if (favPanelOpen) favClose.click();
  }
});

// 谺｡縺ｮ諠・勹縺ｫ陦後￥縺ｨ縺阪√く繝･繝ｼ縺後≠繧後・谺｡縺ｸ
const originalAudioEnded = audio.onended;
audio.addEventListener('ended', () => {
  if (audio.loop) return;
  if (playQueue && playQueue.ids.length > 1) {
    playQueue.currentIdx++;
    if (playQueue.currentIdx < playQueue.ids.length) {
      const nextId = playQueue.ids[playQueue.currentIdx];
      const nextFav = favorites.find(f => f.id === nextId);
      if (nextFav) { playFavorite(nextFav); return; }
    }
    playQueue = null;
  }
});

// 起動時ローチEloadFavorites();
setTimeout(updateFavButtonState, 100);
$('favBtn').addEventListener('click', () => { /* replaced by toggleCurrentFavorite */ });

// ============ 繧ｿ繝夜撼陦ｨ遉ｺ譎ゅ・繝輔Ξーム停止 (逵・崕蜉・ ============
// 繧ｿ繝悶′繝舌ャ繧ｯ繧ｰ繝ｩ繧ｦ繝ｳ繝峨↓蝗槭▲たら Canvas 繝ｫ繝ｼ繝励ｒ豁｢繧√ｋ (音楽は継綁E
document.addEventListener('visibilitychange', () => {
  _loopPaused = document.visibilityState === 'hidden';
  if (!_loopPaused) lastFrame = performance.now();  // dt 縺碁℃螟ｧ縺ｫ縺ｪ繧峨↑縺・ｈ縺・Μ繧ｻ繝・ヨ
});

// ============ 繝｢繝ｼ繝ルの aria-hidden めE.visible に同期 ============
(function() {
  const ids = ['ringsOverlay', 'footprintFormModal', 'favPanel', 'confirmModal', 'licenseModal'];
  ids.forEach(id => {
    const el = document.getElementById(id);
    if (!el) return;
    const obs = new MutationObserver(() => {
      el.setAttribute('aria-hidden', el.classList.contains('visible') ? 'false' : 'true');
    });
    obs.observe(el, { attributes: true, attributeFilter: ['class'] });
  });
})();

// ============ 諠・勹迢ｬ閾ｪ縺ｮ繧ｨ繝輔ぉ繧ｯ繝育ｲ貞ｭ・============
const sceneEffectCanvas = $('sceneEffectCanvas');
const seCtx = sceneEffectCanvas.getContext('2d', { alpha: true });
let sceneEffectActive = false;
let sceneEffectParticles = [];
let sceneEffectType = null;

function resizeSceneEffectCanvas() {
  // 陬・｣ｾ逕ｨ縺ｪ縺ｮ縺ｧ DECOR_DPR で負荷軽渁E  sceneEffectCanvas.width = innerWidth * DECOR_DPR;
  sceneEffectCanvas.height = innerHeight * DECOR_DPR;
  sceneEffectCanvas.style.width = innerWidth + 'px';
  sceneEffectCanvas.style.height = innerHeight + 'px';
  seCtx.setTransform(DECOR_DPR, 0, 0, DECOR_DPR, 0, 0);
}

function startSceneEffect() {
  const scene = scenes[currentSceneIndex];
  if (!scene) return;
  sceneEffectActive = true;
  sceneEffectType = scene.id;
  // 譌｢蟄倥・邊貞ｭ舌・谿九＠縺､縺､譁ｰ縺励＞繧ｿ繧､繝励・邊貞ｭ舌ｒ霑ｽ蜉
  sceneEffectParticles = [];
  createSceneEffectParticles(scene.id);
  resizeSceneEffectCanvas();
}

function stopSceneEffect() {
  sceneEffectActive = false;
  // フェードアウチE particlesのtargetOpacity繧・縺ｫ縺励※自然消滁E
sceneEffectParticles.forEach(p => { p.fadeOut = true; });
}

function createSceneEffectParticles(sceneId) {
  let count = {
    festival: 80,
    forest:   50,
    night:    40,
    fantasy:  60,
    japanese: 60,
    farewell: 120,
    horror:   50,
    battle:   70,
  }[sceneId] || 40;
  // Safari / 菴取ｧ閭ｽ讖溘・ 55% に削渁E(カクつき対筁E
  if (_isSafari || _isLowPower) count = Math.round(count * 0.55);

  for (let i = 0; i < count; i++) {
    sceneEffectParticles.push(makeSceneParticle(sceneId, true));
  }
}

function makeSceneParticle(type, initial) {
  const p = { type, opacity: initial ? Math.random() * 0.6 : 0, targetOpacity: 0.5 + Math.random() * 0.5, age: 0, phase: Math.random() * Math.PI * 2 };

  switch (type) {
    case 'festival': // 謠千・縺ｮ轣ｫ闃ｱ縲∽ｸ頑・
      p.x = Math.random() * innerWidth;
      p.y = initial ? Math.random() * innerHeight : innerHeight + 20;
      p.vx = (Math.random() - 0.5) * 0.3;
      p.vy = -0.5 - Math.random() * 1.2;
      p.r = 1 + Math.random() * 2.5;
      p.color = `rgba(255, ${140 + Math.random() * 60}, ${60 + Math.random() * 40}, 1)`;
      p.glow = 3 + Math.random() * 4;
      break;

    case 'forest': // 陋阪√ｆ縺｣縺上ｊ闊槭≧
      p.x = Math.random() * innerWidth;
      p.y = Math.random() * innerHeight;
      p.vx = (Math.random() - 0.5) * 0.3;
      p.vy = (Math.random() - 0.5) * 0.2;
      p.r = 1.5 + Math.random() * 2;
      p.color = `rgba(${180 + Math.random() * 60}, 255, 120, 1)`;
      p.glow = 6 + Math.random() * 6;
      p.blinkPhase = Math.random() * Math.PI * 2;
      break;

    case 'night': // 譏溘・縺ｾ縺溘◆ぁE+ 縺溘∪縺ｫ豬√ｌ譏・      p.x = Math.random() * innerWidth;
      p.y = Math.random() * innerHeight * 0.7;
      p.vx = 0;
      p.vy = 0;
      p.r = 0.6 + Math.random() * 1.4;
      p.color = `rgba(${200 + Math.random() * 55}, ${220 + Math.random() * 35}, 255, 1)`;
      p.glow = 2 + Math.random() * 3;
      p.twinkle = Math.random() * Math.PI * 2;
      p.shootingChance = 0.0008;
      break;

    case 'fantasy': // 髮ｲ縺ｮ繧医≧な粒孁E      p.x = Math.random() * innerWidth;
      p.y = Math.random() * innerHeight;
      p.vx = -0.15 - Math.random() * 0.2;
      p.vy = (Math.random() - 0.5) * 0.08;
      p.r = 3 + Math.random() * 8;
      p.color = `rgba(${200 + Math.random() * 40}, ${220 + Math.random() * 30}, 255, 1)`;
      p.glow = 10 + Math.random() * 15;
      break;

    case 'japanese': // 桜吹雪
      p.x = Math.random() * innerWidth;
      p.y = initial ? Math.random() * innerHeight : -10;
      p.vx = -0.3 + (Math.random() - 0.5) * 0.5;
      p.vy = 0.3 + Math.random() * 0.6;
      p.r = 2 + Math.random() * 2.5;
      p.color = `rgba(255, ${180 + Math.random() * 50}, ${200 + Math.random() * 40}, 1)`;
      p.glow = 4 + Math.random() * 4;
      p.rot = Math.random() * Math.PI * 2;
      p.rotSpeed = (Math.random() - 0.5) * 0.1;
      break;

    case 'farewell': // 雨の筁E      p.x = Math.random() * (innerWidth + 200);
      p.y = initial ? Math.random() * innerHeight : -20;
      p.vx = -1;
      p.vy = 8 + Math.random() * 4;
      p.len = 10 + Math.random() * 18;
      p.color = `rgba(${160 + Math.random() * 40}, ${190 + Math.random() * 30}, 230, 1)`;
      p.thickness = 0.5 + Math.random() * 0.6;
      break;

    case 'horror': // 紫の霧
      p.x = Math.random() * innerWidth;
      p.y = Math.random() * innerHeight;
      p.vx = (Math.random() - 0.5) * 0.15;
      p.vy = (Math.random() - 0.5) * 0.1;
      p.r = 15 + Math.random() * 30;
      p.color = `rgba(${140 + Math.random() * 40}, ${80 + Math.random() * 60}, ${180 + Math.random() * 60}, 1)`;
      p.glow = 20 + Math.random() * 20;
      p.baseOpacity = 0.12 + Math.random() * 0.15;
      break;

    case 'battle': // 火花が散めE      p.x = Math.random() * innerWidth;
      p.y = Math.random() * innerHeight;
      p.vx = (Math.random() - 0.5) * 2;
      p.vy = (Math.random() - 0.5) * 2 - 0.3;
      p.r = 1 + Math.random() * 2;
      p.color = `rgba(255, ${100 + Math.random() * 100}, ${40 + Math.random() * 50}, 1)`;
      p.glow = 4 + Math.random() * 6;
      p.life = 1.0;
      p.decay = 0.008 + Math.random() * 0.012;
      break;
  }

  return p;
}

function drawSceneEffect(dt, time) {
  if (sceneEffectParticles.length === 0 && !sceneEffectActive) {
    seCtx.clearRect(0, 0, innerWidth, innerHeight);
    return;
  }

  seCtx.clearRect(0, 0, innerWidth, innerHeight);

  // 譁ｰ縺励＞邊貞ｭ舌・陬懷・ (蜍輔″縺後≠るタイチE
  if (sceneEffectActive && sceneEffectType) {
    const spawnRate = {
      festival: 2, forest: 0, night: 0, fantasy: 0.3,
      japanese: 1.5, farewell: 4, horror: 0, battle: 1.5,
    }[sceneEffectType] || 0;

    if (Math.random() < spawnRate * dt * 60 / 60) {
      sceneEffectParticles.push(makeSceneParticle(sceneEffectType, false));
    }
  }

  // 蜷・ｲ貞ｭ舌・譖ｴ譁ｰ&描画
  for (let i = sceneEffectParticles.length - 1; i >= 0; i--) {
    const p = sceneEffectParticles[i];
    p.age += dt;

    // opacity補間
    if (p.fadeOut) {
      p.opacity += (0 - p.opacity) * 0.04;
    } else {
      p.opacity += (p.targetOpacity - p.opacity) * 0.04;
    }

    let shouldRemove = false;

    switch (p.type) {
      case 'festival': {
        p.x += p.vx + Math.sin(time * 0.7 + p.phase) * 0.2;
        p.y += p.vy;
        if (p.y < -10) { shouldRemove = true; break; }
        const alpha = p.opacity * (0.6 + Math.sin(time * 2 + p.phase) * 0.4);
        const grd = seCtx.createRadialGradient(p.x, p.y, 0, p.x, p.y, p.r * p.glow);
        grd.addColorStop(0, p.color.replace(', 1)', `, ${alpha})`));
        grd.addColorStop(1, p.color.replace(', 1)', ', 0)'));
        seCtx.fillStyle = grd;
        seCtx.beginPath();
        seCtx.arc(p.x, p.y, p.r * p.glow, 0, Math.PI * 2);
        seCtx.fill();
        seCtx.fillStyle = p.color.replace(', 1)', `, ${alpha})`);
        seCtx.beginPath();
        seCtx.arc(p.x, p.y, p.r, 0, Math.PI * 2);
        seCtx.fill();
        break;
      }
      case 'forest': {
        p.x += p.vx + Math.sin(time * 0.5 + p.phase) * 0.4;
        p.y += p.vy + Math.cos(time * 0.3 + p.phase) * 0.3;
        if (p.x < -10) p.x = innerWidth + 10;
        if (p.x > innerWidth + 10) p.x = -10;
        if (p.y < -10) p.y = innerHeight + 10;
        if (p.y > innerHeight + 10) p.y = -10;
        const blink = 0.3 + Math.abs(Math.sin(time * 0.8 + p.blinkPhase)) * 0.7;
        const alpha = p.opacity * blink;
        const grd = seCtx.createRadialGradient(p.x, p.y, 0, p.x, p.y, p.r * p.glow);
        grd.addColorStop(0, p.color.replace(', 1)', `, ${alpha})`));
        grd.addColorStop(1, p.color.replace(', 1)', ', 0)'));
        seCtx.fillStyle = grd;
        seCtx.beginPath();
        seCtx.arc(p.x, p.y, p.r * p.glow, 0, Math.PI * 2);
        seCtx.fill();
        seCtx.fillStyle = p.color.replace(', 1)', `, ${alpha})`);
        seCtx.beginPath();
        seCtx.arc(p.x, p.y, p.r, 0, Math.PI * 2);
        seCtx.fill();
        break;
      }
      case 'night': {
        const twinkle = 0.3 + Math.abs(Math.sin(time * 1.5 + p.twinkle)) * 0.7;
        const alpha = p.opacity * twinkle;
        seCtx.fillStyle = p.color.replace(', 1)', `, ${alpha})`);
        seCtx.beginPath();
        seCtx.arc(p.x, p.y, p.r, 0, Math.PI * 2);
        seCtx.fill();
        // 縺溘∪縺ｫ蜊∝ｭ励・蜈・(螟ｧ縺阪↑昁E
        if (p.r > 1.4) {
          seCtx.strokeStyle = p.color.replace(', 1)', `, ${alpha * 0.5})`);
          seCtx.lineWidth = 0.5;
          seCtx.beginPath();
          seCtx.moveTo(p.x - p.r * 3, p.y);
          seCtx.lineTo(p.x + p.r * 3, p.y);
          seCtx.moveTo(p.x, p.y - p.r * 3);
          seCtx.lineTo(p.x, p.y + p.r * 3);
          seCtx.stroke();
        }
        break;
      }
      case 'fantasy': {
        p.x += p.vx;
        p.y += p.vy + Math.sin(time * 0.2 + p.phase) * 0.05;
        if (p.x < -p.glow * 2) { shouldRemove = true; break; }
        const alpha = p.opacity * 0.35;
        const grd = seCtx.createRadialGradient(p.x, p.y, 0, p.x, p.y, p.glow);
        grd.addColorStop(0, p.color.replace(', 1)', `, ${alpha})`));
        grd.addColorStop(1, p.color.replace(', 1)', ', 0)'));
        seCtx.fillStyle = grd;
        seCtx.beginPath();
        seCtx.arc(p.x, p.y, p.glow, 0, Math.PI * 2);
        seCtx.fill();
        break;
      }
      case 'japanese': {
        p.x += p.vx + Math.sin(time * 0.8 + p.phase) * 0.6;
        p.y += p.vy;
        p.rot += p.rotSpeed;
        if (p.y > innerHeight + 10) { shouldRemove = true; break; }
        const alpha = p.opacity;
        seCtx.save();
        seCtx.translate(p.x, p.y);
        seCtx.rotate(p.rot);
        // 闃ｱ蠑√・讌募・
        const grd = seCtx.createRadialGradient(0, 0, 0, 0, 0, p.r * p.glow);
        grd.addColorStop(0, p.color.replace(', 1)', `, ${alpha * 0.6})`));
        grd.addColorStop(1, p.color.replace(', 1)', ', 0)'));
        seCtx.fillStyle = grd;
        seCtx.beginPath();
        seCtx.arc(0, 0, p.r * p.glow, 0, Math.PI * 2);
        seCtx.fill();
        seCtx.fillStyle = p.color.replace(', 1)', `, ${alpha})`);
        seCtx.beginPath();
        seCtx.ellipse(0, 0, p.r * 1.2, p.r * 0.6, 0, 0, Math.PI * 2);
        seCtx.fill();
        seCtx.restore();
        break;
      }
      case 'farewell': {
        p.x += p.vx;
        p.y += p.vy;
        if (p.y > innerHeight + 30) { shouldRemove = true; break; }
        const alpha = p.opacity * 0.5;
        seCtx.strokeStyle = p.color.replace(', 1)', `, ${alpha})`);
        seCtx.lineWidth = p.thickness;
        seCtx.beginPath();
        seCtx.moveTo(p.x, p.y);
        seCtx.lineTo(p.x + p.vx * 3, p.y + p.len);
        seCtx.stroke();
        break;
      }
      case 'horror': {
        p.x += p.vx + Math.sin(time * 0.15 + p.phase) * 0.2;
        p.y += p.vy + Math.cos(time * 0.1 + p.phase) * 0.15;
        if (p.x < -p.r) p.x = innerWidth + p.r;
        if (p.x > innerWidth + p.r) p.x = -p.r;
        if (p.y < -p.r) p.y = innerHeight + p.r;
        if (p.y > innerHeight + p.r) p.y = -p.r;
        const alpha = p.opacity * p.baseOpacity;
        const grd = seCtx.createRadialGradient(p.x, p.y, 0, p.x, p.y, p.glow);
        grd.addColorStop(0, p.color.replace(', 1)', `, ${alpha})`));
        grd.addColorStop(1, p.color.replace(', 1)', ', 0)'));
        seCtx.fillStyle = grd;
        seCtx.beginPath();
        seCtx.arc(p.x, p.y, p.glow, 0, Math.PI * 2);
        seCtx.fill();
        break;
      }
      case 'battle': {
        p.x += p.vx;
        p.y += p.vy;
        p.vy += 0.05; // 重力
        p.life -= p.decay;
        if (p.life <= 0) { shouldRemove = true; break; }
        const alpha = p.opacity * p.life;
        const grd = seCtx.createRadialGradient(p.x, p.y, 0, p.x, p.y, p.r * p.glow);
        grd.addColorStop(0, p.color.replace(', 1)', `, ${alpha})`));
        grd.addColorStop(1, p.color.replace(', 1)', ', 0)'));
        seCtx.fillStyle = grd;
        seCtx.beginPath();
        seCtx.arc(p.x, p.y, p.r * p.glow, 0, Math.PI * 2);
        seCtx.fill();
        seCtx.fillStyle = p.color.replace(', 1)', `, ${alpha})`);
        seCtx.beginPath();
        seCtx.arc(p.x, p.y, p.r, 0, Math.PI * 2);
        seCtx.fill();
        break;
      }
    }

    if (shouldRemove || p.opacity < 0.01 && p.fadeOut) {
      sceneEffectParticles.splice(i, 1);
    }
  }
}
addEventListener('resize', resizeSceneEffectCanvas);
resizeSceneEffectCanvas();
$('exitImmersive').addEventListener('click', exitImmersive);
$('immersiveBtn').addEventListener('click', enterImmersive);

// ============ 没入モーチE 貍泌・繧ｪ繝ｼ繝舌・繝ｬ繧､縺ｮ陦ｨ遉ｺ蛻・崛 ============
// 繝・ヵ繧ｩ繝ｫ繝磯撼陦ｨ遉ｺ縲ゅΘ繝ｼ繧ｶ繝ｼ縺後梧ｼ泌・繧定｡ｨ遉ｺ縲阪・繧ｿ繝ｳ縺ｧ繝医げ繝ｫ縲りｨｭ螳壹ｒ localStorage 縺ｫ險俶・縲・
const OVERLAY_SHOW_KEY = 'hmix_theater_immersive_overlays_v1';
(function() {
  const btn = document.getElementById('immersiveOverlayToggle');
  if (!btn) return;

  const iconShow = btn.querySelector('.ov-icon-show');
  const iconHide = btn.querySelector('.ov-icon-hide');
  const labelShow = btn.querySelector('.ov-label-show');
  const labelHide = btn.querySelector('.ov-label-hide');

  // 蛻晄悄迥ｶ諷九・蟶ｸ縺ｫ false (髫縺・縲よ勹濶ｲ縺ｮ荳ｭ縺ｫ蜈･繧九◆縺ｳ縺ｫ豈主屓繝ｪ繧ｻ繝・ヨ縺吶ｋ譁ｹ驥・  // (莉･蜑阪・ localStorage 蠕ｩ蜈・＠縺ｦ縺・◆縺後∽ｸ也阜隕ｳ蜆ｪ蜈医〒豈主屓OFF繧ｹ繧ｿ繝ｼ繝医↓変更)
  let showOverlays = false;
  try { localStorage.removeItem(OVERLAY_SHOW_KEY); } catch(_) {}
  applyState();

  function applyState() {
    document.body.classList.toggle('show-immersive-overlays', showOverlays);
    iconShow.style.display = showOverlays ? 'none' : '';
    iconHide.style.display = showOverlays ? '' : 'none';
    labelShow.style.display = showOverlays ? 'none' : '';
    labelHide.style.display = showOverlays ? '' : 'none';
  }

  // 譎ｯ濶ｲ縺ｮ荳ｭ縺ｫ蜈･繧九◆縺ｳ縺ｫ貍泌・繧ｪ繝ｼ繝舌・繝ｬ繧､繧貞ｼｷ蛻ｶ OFF (世界観優允E
  window._resetImmersiveOverlays = function() {
    showOverlays = false;
    applyState();
  };

  btn.addEventListener('click', (e) => {
    e.stopPropagation();
    showOverlays = !showOverlays;
    applyState();
    // 謇句虚繝医げ繝ｫ縺ｯ縺昴・繧ｻ繝・す繝ｧ繝ｳ蜀・〒縺ｮ縺ｿ譛牙柑縲よｬ｡縺ｮ enterImmersive 縺ｧ繝ｪ繧ｻ繝・ヨ縺輔ｌ繧・
});
})();

// 豐｡蜈･繝｢繝ｼ繝画凾縺ｮ鬮倩ｧ｣蜒丞ｺｦ逕ｻ蜒上Ξイヤー (蜷・す繝ｼ繝ｳ縺ｫ1譫壹★縺､縲∝ｿ・ｦ∵凾縺ｫ蟾ｮ縺玲崛縺・
const hiresLayers = {};

function loadHiresForCurrentScene() {
  const scene = scenes[currentSceneIndex];
  if (!scene || !scene.hires) return;

  // 繧ｿ繧ｰ逕ｻ蜒上が繝ｼ繝舌・繝ｩ繧､繝我ｸｭ縺ｪ繧峨ち繧ｰ逕ｻ蜒上ｒ蜆ｪ蜈・(タグで旁E☆繧倶ｽ馴ｨ薙・邯咏ｶ・
  const useTagImage = (_currentTagOverride !== null);
  const imageUrl = useTagImage ? _getTagImageUrl(_currentTagOverride) : scene.hires;

  let layer = hiresLayers[scene.id];
  if (!layer) {
    // 縺ｾ縺菴懊▲縺ｦ縺ｪ縺代ｌ縺ｰ縲∬ｩｲ蠖薙・scene-layer縺ｮ荳翫↓驥阪・繧・
const sceneLayer = document.querySelectorAll('.scene-layer')[currentSceneIndex];
    if (!sceneLayer) return;
    layer = document.createElement('div');
    layer.className = 'scene-hires';
    sceneLayer.appendChild(layer);
    hiresLayers[scene.id] = layer;
  }

  // 繧ｿ繧ｰ逕ｻ蜒上・蝣ｴ蜷医・豈主屓繝ｭ繝ｼ繝峨√す繝ｼ繝ｳ逕ｻ蜒上・繧ｭ繝｣繝・す繝･
  const needsLoad = useTagImage || !layer.dataset.loaded;
  if (needsLoad) {
    const img = new Image();
    img.onload = () => {
      layer.style.backgroundImage = `url(${imageUrl})`;
      if (!useTagImage) layer.dataset.loaded = 'true';
      if (document.body.classList.contains('immersed')) {
        layer.classList.add('active');
      }
    };
    img.onerror = () => {
      // 繧ｿ繧ｰ逕ｻ蜒上Ο繝ｼ繝牙､ｱ謨・竊・繧ｷ繝ｼ繝ｳ逕ｻ蜒上↓フォールバック
      if (useTagImage) {
        layer.style.backgroundImage = `url(${scene.hires})`;
        if (document.body.classList.contains('immersed')) {
          layer.classList.add('active');
        }
      }
    };
    img.src = imageUrl;
  } else {
    layer.classList.add('active');
  }
}

function unloadHiresForCurrentScene() {
  const scene = scenes[currentSceneIndex];
  if (!scene) return;
  const layer = hiresLayers[scene.id];
  if (layer) layer.classList.remove('active');
}

// 霆｢謠帑ｸｭ縺ｮ莠碁㍾繧ｯ繝ｪ繝・け髦ｲ豁｢
let transitioning = false;

function enterImmersive() {
  if (transitioning) return;
  if (document.body.classList.contains('immersed')) return;
  // 諠・勹縺梧悴驕ｸ謚槭↑ら動作しなぁE
if (currentSceneIndex < 0) {
    if (typeof showToast === 'function') showToast('縺ｾ縺壽ュ譎ｯ繧帝∈繧薙〒縺上□さい');
    return;
  }
  // 譎ｯ濶ｲ縺ｮ荳ｭ縺ｫ蜈･繧九◆縺ｳ縺ｫ貍泌・繧ｪ繝ｼ繝舌・繝ｬ繧､繧貞ｼｷ蛻ｶ OFF (豬ｮ驕翫き繝ｼ繝峨・雜ｳ霍｡繧帝撼陦ｨ遉ｺ)
  if (typeof window._resetImmersiveOverlays === 'function') window._resetImmersiveOverlays();
  transitioning = true;

  const veil = $('dramaticVeil');

  // ========== Phase 1: 蜈峨・蜿取據 (0.0s 竊・1.5s) ==========
  submergeAudio(1.5);
  document.body.classList.add('transitioning-to-immersed');

  // 0.3s時点で暗転開姁E(transitionで1.5s謗帙￠縺ｦ逵溘▲鮟偵↓縺ｪ繧・竊・1.8s 縺ｫ螳悟・證苓ｻ｢)
  setTimeout(() => {
    veil.classList.add('dark');
  }, 300);

  // ========== Phase 2: 螳悟・證苓ｻ｢繧堤ｶｭ謖・(1.8s 竊・3.3s) ==========
  // 螳悟・證苓ｻ｢縺ｮ譛滄俣繧・.5秒確俁E
setTimeout(() => {
    // 縺薙・髢薙↓body.immersedを付けめE(螳悟・證苓ｻ｢縺ｮ陬上〒)
    document.body.classList.remove('gallery-mode');
    document.body.classList.add('immersed');
    loadHiresForCurrentScene();
    startSceneEffect();
  }, 2100);

  // ========== Phase 3: 蜈峨・隕夐・ (3.3s 竊・4.5s) ==========
  setTimeout(() => {
    veil.classList.remove('dark');
    veil.classList.add('dawning');
  }, 3300);

  // ========== Phase 4: 諠・勹縺ｮ鬘慕樟 (4.5s 竊・6.0s) ==========
  setTimeout(() => {
    veil.classList.remove('dawning');
    veil.classList.add('fading');
    surfaceAudio(1.5);
  }, 4500);

  // ========== Phase 5: 完亁E(6.0s) ==========
  setTimeout(() => {
    veil.classList.remove('fading');
    showImmersiveSubtitle();
    transitioning = false;
    document.body.classList.remove('transitioning-to-immersed');
    // UI 繧｢繧､繝峨Ν検知を開姁E    startImmersiveIdleTimer();
  }, 6000);

  if (document.documentElement.requestFullscreen) {
    document.documentElement.requestFullscreen().catch(() => {});
  }
}

function exitImmersive() {
  if (transitioning) return;
  if (!document.body.classList.contains('immersed')) return;
  transitioning = true;

  // UI繧｢繧､繝峨Ν検知解除
  stopImmersiveIdleTimer();
  document.body.classList.remove('ui-idle');

  const veil = $('dramaticVeil');

  hideImmersiveSubtitle();
  stopSceneEffect();
  submergeAudio(1.2);

  // 0.2s で暗転開姁EↁE1.7s縺ｫ螳悟・證苓ｻ｢
  setTimeout(() => {
    veil.classList.remove('fading');
    veil.classList.add('dark');
  }, 200);

  // 螳悟・證苓ｻ｢縺ｮ陬上〒蛻・崛 (2.0s)
  setTimeout(() => {
    document.body.classList.remove('immersed');
    document.body.classList.add('gallery-mode');
    unloadHiresForCurrentScene();
  }, 2000);

  // 2.7s からフェードイン
  setTimeout(() => {
    veil.classList.remove('dark');
    veil.classList.add('fading');
    surfaceAudio(1.5);
  }, 2700);

  setTimeout(() => {
    veil.classList.remove('fading');
    transitioning = false;
  }, 4500);

  if (document.fullscreenElement) document.exitFullscreen().catch(() => {});
}

// ============ 没入モード中のUI繧｢繧､繝峨Ν検知 ============
let immersiveIdleTimer = null;
const IMMERSIVE_IDLE_MS = 2500;

function showImmersiveUI() {
  document.body.classList.remove('ui-idle');
  if (immersiveIdleTimer) clearTimeout(immersiveIdleTimer);
  if (document.body.classList.contains('immersed')) {
    immersiveIdleTimer = setTimeout(() => {
      if (document.body.classList.contains('immersed')) {
        document.body.classList.add('ui-idle');
      }
    }, IMMERSIVE_IDLE_MS);
  }
}

function startImmersiveIdleTimer() {
  showImmersiveUI(); // 譛蛻昴・陦ｨ遉ｺ縲√い繧､繝峨Ν検知開姁E
}

function stopImmersiveIdleTimer() {
  if (immersiveIdleTimer) {
    clearTimeout(immersiveIdleTimer);
    immersiveIdleTimer = null;
  }
}

// 繝槭え繧ｹ遘ｻ蜍輔・繧ｯ繝ｪ繝・け繝ｻ繧ｭ繝ｼ謫堺ｽ懊〒蜀崎｡ｨ遉ｺ
addEventListener('pointermove', () => {
  if (document.body.classList.contains('immersed')) showImmersiveUI();
});
addEventListener('pointerdown', () => {
  if (document.body.classList.contains('immersed')) showImmersiveUI();
});
addEventListener('keydown', () => {
  if (document.body.classList.contains('immersed')) showImmersiveUI();
});

// ============ 豐｡蜈･繝｢繝ｼ繝峨・蟄怜ｹ・============
// タグID から TAGS_FEELING/TAGS_SCENE 蜀・・繧ｨ繝ｳ繝医Μを検索
function _findTagEntry(tagId) {
  if (!tagId) return null;
  return TAGS_FEELING.find(t => t.id === tagId) || TAGS_SCENE.find(t => t.id === tagId) || null;
}

function showImmersiveSubtitle() {
  const scene = scenes[currentSceneIndex];
  if (!scene) return;

  // タグで旁E☆繧倶ｸｭ縺ｪ繧峨ち繧ｰ蜷阪ｒ陦ｨ遉ｺ縲√◎縺・〒縺ｪ縺代ｌ縺ｰ繧ｷ繝ｼ繝ｳ蜷・
const tagEntry = _currentTagOverride ? _findTagEntry(_currentTagOverride) : null;
  if (tagEntry) {
    $('imSubJp').textContent = tagEntry.jp;
    $('imSubEn').textContent = tagEntry.en;
    $('imSubGenre').textContent = scene.jpSub;  // 繧ｷ繝ｼ繝ｳ蜑ｯ鬘後・譌・・縺ｮ髮ｰ蝗ｲ豌励→縺励※谿九☆
  } else {
    $('imSubJp').textContent = scene.jp;
    $('imSubEn').textContent = scene.en;
    $('imSubGenre').textContent = scene.jpSub;
  }
  const subtitle = $('immersiveSubtitle');

  clearTimeout(window._imSubTimer);
  setTimeout(() => subtitle.classList.add('visible'), 800);
  // 余韻を長ぁE 7秒表示 (以剁E4.2s 竊・諠・勹縺ｮ險俶・縺梧ｮ九ｋ繧医≧に)
  window._imSubTimer = setTimeout(() => subtitle.classList.remove('visible'), 7500);
}
function hideImmersiveSubtitle() {
  $('immersiveSubtitle').classList.remove('visible');
  clearTimeout(window._imSubTimer);
}

// ============ 豐｡蜈･繝｢繝ｼ繝峨・繝溘ル繝槭Ν繧ｳ繝ｳ繝医Οール ============
// 竢ｮ竢ｭ 縺ｯ縲檎樟繧ｷ繝ｼ繝ｳ蜀・・蜑榊ｾ梧峇縲・諠・勹縺ｯ螟峨∴なぁEよュ譎ｯ蛻・崛縺ｯ繧ｷ繝ｼ繝ｳ繝｡繝九Ηーから)
$('imPrev').addEventListener('click', () => { prevTrack(); });
$('imNext').addEventListener('click', () => { nextTrack(); });
$('imPlay').addEventListener('click', () => {
  playBtn.click();
  // アイコン同期
  const imPlayIcon = $('imPlayIcon');
  if (audio.paused) {
    imPlayIcon.innerHTML = '<path d="M8 5v14l11-7L8 5z"/>';
  } else {
    imPlayIcon.innerHTML = '<path d="M6 4h4v16H6zM14 4h4v16h-4z"/>';
  }
});
// 騾壼ｸｸ繝励Ξ繧､繝､繝ｼ縺ｮ蜀咲函迥ｶ諷句､牙喧繧偵Α繝九・繝ｫ繧｢繧､繧ｳ繝ｳ縺ｫ蜷梧悄
audio.addEventListener('play', () => {
  const imPlayIcon = $('imPlayIcon');
  if (imPlayIcon) imPlayIcon.innerHTML = '<path d="M6 4h4v16H6zM14 4h4v16h-4z"/>';
});
audio.addEventListener('pause', () => {
  const imPlayIcon = $('imPlayIcon');
  if (imPlayIcon) imPlayIcon.innerHTML = '<path d="M8 5v14l11-7L8 5z"/>';
});

// カーソル
const cur = $('cur'), curDot = $('curDot');
let cx = 0, cy = 0, tx = innerWidth/2, ty = innerHeight/2;
let lastX = tx, lastY = ty;
let mouseVelocity = 0;

addEventListener('pointermove', e => {
  tx = e.clientX; ty = e.clientY;
  curDot.style.left = tx + 'px';
  curDot.style.top = ty + 'px';
});

function tickCursor() {
  cx += (tx - cx) * 0.25;
  cy += (ty - cy) * 0.25;
  cur.style.left = cx + 'px';
  cur.style.top = cy + 'px';
  mouseVelocity = mouseVelocity * 0.9 + Math.hypot(tx - lastX, ty - lastY) * 0.1;
  lastX = tx; lastY = ty;
  requestAnimationFrame(tickCursor);
}
tickCursor();

const hoverSelectors = '.scene-item, .glass-btn, .ctrl-btn, .play-btn, .nav-arrow, .track-license a, .seekbar';
let windowHover = false;

addEventListener('pointermove', e => {
  // 遯薙・繝舌・蛻､螳・
let hit = null;
  for (let i = windows.length - 1; i >= 0; i--) {
    if (windows[i].hitTest(e.clientX, e.clientY)) {
      hit = windows[i];
      break;
    }
  }
  windows.forEach(w => w.hovering = false);
  if (hit) hit.hovering = true;

  const wasHover = windowHover;
  windowHover = !!hit;

  // 豬ｮ驕顔ｪ薙・繝舌・ 竊・蟇ｾ蠢懊☆繧九す繝ｼ繝ｳ繝｡繝九Η繝ｼ繧貞・繧峨○めE
document.querySelectorAll('.scene-item').forEach(item => {
    item.classList.remove('highlight');
  });
  if (hit) {
    const matchItem = document.querySelector(`.scene-item[data-scene-id="${hit.sceneId}"]`);
    if (matchItem) matchItem.classList.add('highlight');
  }

  // UI隕∫ｴ繝帙ヰ繝ｼ
  const uiHover = e.target.closest(hoverSelectors);

  if (uiHover || windowHover) cur.classList.add('hov');
  else cur.classList.remove('hov');
});

addEventListener('click', e => {
  if (e.target.closest('.ui, button, a, .fav-panel, .license-modal, .footprint-form-modal, .confirm-modal, .rings-overlay, .rest-timer-menu, .travel-menu, .rest-timer-farewell')) return;
  // 笘・繝励Ο繝ｭ繝ｼ繧ｰ縺後∪だDOM縺ｫ縺ゅｊ縲碁撼陦ｨ遉ｺ螳御ｺ・燕縲阪・蝣ｴ蜷医∵ｵｮ驕翫き繝ｼ繝峨・繝偵ャ繝亥愛螳壹ｒ繧ｹ繧ｭ繝・・ (繧ｿ繝・・雋ｫ騾夐亟豁｢)
  const prologueEl = document.getElementById('prologue');
  if (prologueEl && prologueEl.style.display !== 'none') return;
  // 笘・target ぁEprologue 譛ｬ菴薙∪縺溘・縺昴・蟄仙ｭｫ縺ｪ繧臥┌要E
if (e.target.closest('#prologue')) return;

  // 繧ｯ繝ｪ繝・け豕｢邏九ｒ逋ｺ蜍・(UI莉･螟悶・蝣ｴ謇縺ｧ繧ｯ繝ｪ繝・け縺輔ｌ縺・
  spawnRipple(e.clientX, e.clientY);

  // 豬ｮ驕顔ｪ薙・繝偵ャ繝亥愛螳・(既孁E
  for (let i = windows.length - 1; i >= 0; i--) {
    if (windows[i].hitTest(e.clientX, e.clientY)) {
      const targetIdx = scenes.findIndex(s => s.id === windows[i].sceneId);
      if (targetIdx >= 0) {
        windows[i].glowPulse = 1;
        selectScene(targetIdx);
      }
      break;
    }
  }
});

// ============ 繧ｯ繝ｪ繝・け豕｢邏・============
const rippleCanvas = $('rippleCanvas');
const rippleCtx = rippleCanvas.getContext('2d', { alpha: true });
const ripples = [];

function resizeRippleCanvas() {
  rippleCanvas.width = innerWidth * DECOR_DPR;
  rippleCanvas.height = innerHeight * DECOR_DPR;
  rippleCanvas.style.width = innerWidth + 'px';
  rippleCanvas.style.height = innerHeight + 'px';
  rippleCtx.setTransform(DECOR_DPR, 0, 0, DECOR_DPR, 0, 0);
}
resizeRippleCanvas();
addEventListener('resize', resizeRippleCanvas);

// ============ 星雲エフェクチE(リング展開晁E ============
const nebulaCanvas = $('nebulaCanvas');
const nebulaCtx = nebulaCanvas.getContext('2d', { alpha: true });
const nebulaStars = [];
const nebulaShootingStars = [];
const nebulaWisps = []; // 金色の霧

function initNebula() {
  nebulaStars.length = 0;
  // Safari / 菴取ｧ閭ｽ讖溘・譏滓焚繧・60% 渁E(400 竊・160) で負荷軽渁E
const starCount = (typeof _isSafari !== 'undefined' && (_isSafari || _isLowPower)) ? 160 : 400;
  for (let i = 0; i < starCount; i++) {
    nebulaStars.push({
      x: Math.random() * innerWidth,
      y: Math.random() * innerHeight,
      r: 0.5 + Math.random() * 2.2,
      baseBright: 0.5 + Math.random() * 0.5,
      phase: Math.random() * Math.PI * 2,
      speed: 0.4 + Math.random() * 1.2,
      vx: (Math.random() - 0.5) * 0.08,
      vy: (Math.random() - 0.5) * 0.08,
      color: Math.random() < 0.6 ? '245, 240, 230' : (Math.random() < 0.5 ? '255, 210, 150' : '160, 200, 255'),
    });
  }
  // 金色の霧(nebula wisps) - 螟ｧ縺阪￥縺ｦ逶ｮ遶九▽
  nebulaWisps.length = 0;
  for (let i = 0; i < 8; i++) {
    nebulaWisps.push({
      x: Math.random() * innerWidth,
      y: Math.random() * innerHeight,
      r: 280 + Math.random() * 320,
      vx: (Math.random() - 0.5) * 0.12,
      vy: (Math.random() - 0.5) * 0.12,
      phase: Math.random() * Math.PI * 2,
      tint: Math.random() < 0.4 ? '212, 164, 76' : (Math.random() < 0.5 ? '180, 130, 220' : '80, 140, 200'),
    });
  }
}

function resizeNebulaCanvas() {
  nebulaCanvas.width = innerWidth * DECOR_DPR;
  nebulaCanvas.height = innerHeight * DECOR_DPR;
  nebulaCanvas.style.width = innerWidth + 'px';
  nebulaCanvas.style.height = innerHeight + 'px';
  nebulaCtx.setTransform(DECOR_DPR, 0, 0, DECOR_DPR, 0, 0);
  initNebula();
}
resizeNebulaCanvas();
addEventListener('resize', resizeNebulaCanvas);

function spawnShootingStar() {
  // 逕ｻ髱｢遶ｯ縺九ｉ繝ｩ繝ｳ繝ムに
  const side = Math.floor(Math.random() * 2);
  const x = side === 0 ? -50 : innerWidth * 0.2 + Math.random() * innerWidth * 0.4;
  const y = side === 0 ? Math.random() * innerHeight * 0.6 : -50;
  const angle = Math.PI * 0.25 + (Math.random() - 0.5) * 0.3;
  const speed = 8 + Math.random() * 6;
  nebulaShootingStars.push({
    x, y,
    vx: Math.cos(angle) * speed,
    vy: Math.sin(angle) * speed,
    life: 1,
    trail: [],
  });
}

let nebulaTimeLastShooting = 0;

function drawNebula(dt, time) {
  if (!document.body.classList.contains('rings-open')) {
    // 髢峨§縺ｦ縺・ｋ譎ゅ・謠冗判繧ｹ繧ｭ繝・・
    nebulaCtx.clearRect(0, 0, innerWidth, innerHeight);
    return;
  }

  // 阮・＞鮟偵〒驥阪・縺ｦ蠕ｮ螯吶↑繝医Ξイル効极E(豬√ｌ譏溘・霆瑚ｷ｡縺ｪ縺ｩ)
  nebulaCtx.fillStyle = 'rgba(5, 8, 12, 0.08)';
  nebulaCtx.fillRect(0, 0, innerWidth, innerHeight);

  // 金色の霧 (nebula wisps)
  nebulaWisps.forEach(w => {
    w.x += w.vx * dt * 60;
    w.y += w.vy * dt * 60;
    w.phase += dt * 0.3;
    if (w.x < -w.r) w.x = innerWidth + w.r;
    if (w.x > innerWidth + w.r) w.x = -w.r;
    if (w.y < -w.r) w.y = innerHeight + w.r;
    if (w.y > innerHeight + w.r) w.y = -w.r;

    const pulse = 0.5 + 0.5 * Math.sin(w.phase);
    const grd = nebulaCtx.createRadialGradient(w.x, w.y, 0, w.x, w.y, w.r);
    grd.addColorStop(0, `rgba(${w.tint}, ${0.18 * pulse})`);
    grd.addColorStop(0.5, `rgba(${w.tint}, ${0.08 * pulse})`);
    grd.addColorStop(1, `rgba(${w.tint}, 0)`);
    nebulaCtx.fillStyle = grd;
    nebulaCtx.beginPath();
    nebulaCtx.arc(w.x, w.y, w.r, 0, Math.PI * 2);
    nebulaCtx.fill();
  });

  // 昁E
nebulaStars.forEach(s => {
    s.x += s.vx * dt * 60;
    s.y += s.vy * dt * 60;
    s.phase += dt * s.speed;
    if (s.x < 0) s.x = innerWidth;
    if (s.x > innerWidth) s.x = 0;
    if (s.y < 0) s.y = innerHeight;
    if (s.y > innerHeight) s.y = 0;

    const twinkle = 0.5 + 0.5 * Math.sin(s.phase);
    const bright = s.baseBright * (0.5 + twinkle * 0.5);

    nebulaCtx.fillStyle = `rgba(${s.color}, ${bright})`;
    nebulaCtx.beginPath();
    nebulaCtx.arc(s.x, s.y, s.r, 0, Math.PI * 2);
    nebulaCtx.fill();

    // 螟ｧ縺阪＞譏溘・蜊∝ｭ怜・
    if (s.r > 1.3 && bright > 0.4) {
      nebulaCtx.strokeStyle = `rgba(${s.color}, ${bright * 0.5})`;
      nebulaCtx.lineWidth = 0.5;
      nebulaCtx.beginPath();
      nebulaCtx.moveTo(s.x - s.r * 3, s.y);
      nebulaCtx.lineTo(s.x + s.r * 3, s.y);
      nebulaCtx.moveTo(s.x, s.y - s.r * 3);
      nebulaCtx.lineTo(s.x, s.y + s.r * 3);
      nebulaCtx.stroke();
    }
  });

  // 豬√ｌ譏溘ｒ譎ゅ・函謌・(4、E秒間隁E
  if (time - nebulaTimeLastShooting > 4000 + Math.random() * 4000) {
    spawnShootingStar();
    nebulaTimeLastShooting = time;
  }

  // 豬√ｌ譏滓緒逕ｻ
  for (let i = nebulaShootingStars.length - 1; i >= 0; i--) {
    const ss = nebulaShootingStars[i];
    ss.x += ss.vx;
    ss.y += ss.vy;
    ss.trail.push({ x: ss.x, y: ss.y });
    if (ss.trail.length > 20) ss.trail.shift();
    ss.life -= 0.012;

    // 繝医Ξイル描画
    for (let j = 1; j < ss.trail.length; j++) {
      const prev = ss.trail[j - 1];
      const curr = ss.trail[j];
      const t = j / ss.trail.length;
      nebulaCtx.strokeStyle = `rgba(245, 216, 150, ${t * ss.life * 0.7})`;
      nebulaCtx.lineWidth = t * 2;
      nebulaCtx.beginPath();
      nebulaCtx.moveTo(prev.x, prev.y);
      nebulaCtx.lineTo(curr.x, curr.y);
      nebulaCtx.stroke();
    }
    // 先端の允E    nebulaCtx.fillStyle = `rgba(245, 216, 150, ${ss.life})`;
    nebulaCtx.beginPath();
    nebulaCtx.arc(ss.x, ss.y, 2, 0, Math.PI * 2);
    nebulaCtx.fill();

    if (ss.life <= 0 || ss.x > innerWidth + 50 || ss.y > innerHeight + 50) {
      nebulaShootingStars.splice(i, 1);
    }
  }
}

function spawnRipple(x, y) {
  ripples.push({
    x, y,
    radius: 0,
    maxRadius: 150 + Math.random() * 50,
    opacity: 0.6,
    age: 0,
    life: 1.8, // 私E
});

  // 霑代￥縺ｮ豬ｮ驕顔ｲ貞ｭ舌↓蜿榊ｿ懊ｒ荳弱∴めE
if (typeof particlesMid !== 'undefined') {
    particlesMid.forEach(p => {
      const dx = p.x - x, dy = p.y - y;
      const dist = Math.hypot(dx, dy);
      if (dist < 200 && dist > 0.1) {
        const push = (200 - dist) / 200 * 2.5;
        p.vx += (dx / dist) * push;
        p.vy += (dy / dist) * push;
      }
    });
  }
  if (typeof particlesFront !== 'undefined') {
    particlesFront.forEach(p => {
      const dx = p.x - x, dy = p.y - y;
      const dist = Math.hypot(dx, dy);
      if (dist < 200 && dist > 0.1) {
        const push = (200 - dist) / 200 * 3;
        p.vx += (dx / dist) * push;
        p.vy += (dy / dist) * push;
      }
    });
  }
}

function drawRipples(dt) {
  rippleCtx.clearRect(0, 0, innerWidth, innerHeight);
  for (let i = ripples.length - 1; i >= 0; i--) {
    const r = ripples[i];
    r.age += dt;
    const t = r.age / r.life;
    if (t >= 1) { ripples.splice(i, 1); continue; }

    // イージング: 早く大きくなってめE▲縺上ｊ豸医∴めE
const eased = 1 - Math.pow(1 - t, 3);
    r.radius = r.maxRadius * eased;
    const alpha = r.opacity * (1 - t);

    // 螟門・縺ｮ蜀・
const grd = rippleCtx.createRadialGradient(r.x, r.y, r.radius * 0.6, r.x, r.y, r.radius);
    grd.addColorStop(0, `rgba(${currentAuraRGB || '245, 216, 150'}, 0)`);
    grd.addColorStop(0.7, `rgba(${currentAuraRGB || '245, 216, 150'}, ${alpha * 0.15})`);
    grd.addColorStop(1, `rgba(${currentAuraRGB || '245, 216, 150'}, ${alpha * 0.6})`);
    rippleCtx.fillStyle = grd;
    rippleCtx.beginPath();
    rippleCtx.arc(r.x, r.y, r.radius, 0, Math.PI * 2);
    rippleCtx.fill();

    // 蜀・・縺ｮ邏ｰ縺・・霈ｪ
    rippleCtx.strokeStyle = `rgba(${currentAuraRGB || '245, 216, 150'}, ${alpha * 0.9})`;
    rippleCtx.lineWidth = 1.5;
    rippleCtx.beginPath();
    rippleCtx.arc(r.x, r.y, r.radius, 0, Math.PI * 2);
    rippleCtx.stroke();
  }
}

let mx = 0, my = 0, mxT = 0, myT = 0;
addEventListener('pointermove', e => {
  mxT = (e.clientX / innerWidth - 0.5) * 2;
  myT = (e.clientY / innerHeight - 0.5) * 2;
});

// メインルーチE
let time = 0;
let lastFrame = performance.now();

let _loopPaused = false;
function loop(now) {
  if (_loopPaused) {
    // 繧ｿ繝夜撼陦ｨ遉ｺ荳ｭ縺ｯ繝輔Ξ繝ｼ繝繧呈ｭ｢繧√ｋ (CPU/バッチEΜ繝ｼ遽紁E
    requestAnimationFrame(loop);
    return;
  }
  const dt = Math.min(0.05, (now - lastFrame) / 1000);
  lastFrame = now;
  time += dt;

  mx += (mxT - mx) * 0.06;
  my += (myT - my) * 0.06;

  let audioLevel = 0;
  if (analyser && !audio.paused) {
    analyser.getByteFrequencyData(dataArray);
    let sum = 0;
    for (let i = 0; i < 32; i++) sum += dataArray[i];
    audioLevel = sum / 32 / 255;
  }

  // 諠・勹逕ｻ蜒上・隕門ｷｮ (直接transform縲∬ｻｽ驥・
  const activeImg = document.querySelector('.scene-layer.active .scene-image');
  if (activeImg && !document.body.classList.contains('immersed')) {
    const breath = 1.04 + audioLevel * 0.015 + Math.sin(time * 0.2) * 0.004;
    activeImg.style.transform = `scale(${breath}) translate(${-mx * 1.2}%, ${-my * 0.8}%)`;
  }

  ctx.clearRect(0, 0, cw, ch);

  // 粒孁E(中層)
  for (const p of particlesMid) {
    p.x += p.vx + Math.sin(time * 0.8 + p.phase) * 0.15;
    p.y += p.vy * (1 + audioLevel * 1.5);

    const dx = p.x - tx, dy = p.y - ty;
    const dist = Math.hypot(dx, dy);
    if (dist < 140) {
      const force = (1 - dist / 140) * 0.6;
      p.x += (dx / (dist + 1)) * force * 4;
      p.y += (dy / (dist + 1)) * force * 4;
    }

    if (p.y < -5) { p.y = ch + 5; p.x = Math.random() * cw; }
    if (p.x < -5) p.x = cw + 5;
    if (p.x > cw + 5) p.x = -5;

    const alpha = p.a * (0.6 + Math.sin(time + p.phase) * 0.4) * (1 + audioLevel * 0.4);
    const glow = p.r * (1 + audioLevel * 0.5);

    ctx.beginPath();
    ctx.fillStyle = `rgba(${currentAuraRGB}, ${alpha})`;
    ctx.arc(p.x, p.y, p.r, 0, Math.PI * 2);
    ctx.fill();

    const grd = ctx.createRadialGradient(p.x, p.y, 0, p.x, p.y, glow * 7);
    grd.addColorStop(0, `rgba(${currentAuraRGB}, ${alpha * 0.55})`);
    grd.addColorStop(1, `rgba(${currentAuraRGB}, 0)`);
    ctx.fillStyle = grd;
    ctx.beginPath();
    ctx.arc(p.x, p.y, glow * 7, 0, Math.PI * 2);
    ctx.fill();
  }

  // 浮遊突E
windows.forEach(w => w.update(dt, time, mx, my, audioLevel));
  // 没入モーチE(overlay トグル OFF) 縺ｧ縺ｯ豬ｮ驕翫き繝ｼ繝峨・謠冗判縺励↑ぁEらｲ貞ｭ舌□け残して世界観を維持E
const _hideWindowsInImmersive = document.body.classList.contains('immersed') &&
                                  !document.body.classList.contains('show-immersive-overlays');
  if (!_hideWindowsInImmersive) {
    windows.sort((a, b) => a.depth - b.depth).forEach(w => w.draw(ctx, currentAuraRGB));
  }

  // 粒孁E(手前)
  for (const p of particlesFront) {
    p.vx += (p.tvx - p.vx) * 0.05;
    p.vy += (p.tvy - p.vy) * 0.05;

    const dx = p.x - tx, dy = p.y - ty;
    const dist = Math.hypot(dx, dy);
    if (dist < 380) {
      const force = (1 - dist / 380) * mouseVelocity * 0.03 * p.reactivity;
      p.vx += (dx / (dist + 1)) * force;
      p.vy += (dy / (dist + 1)) * force;
    }

    p.vx *= 0.95;
    p.vy *= 0.95;

    p.x += p.vx + Math.sin(time * 0.5 + p.phase) * 0.18;
    p.y += p.vy - 0.06;

    if (p.y < -10) { p.y = ch + 10; p.x = Math.random() * cw; p.vx = p.tvx; p.vy = p.tvy; }
    if (p.x < -20) p.x = cw + 20;
    if (p.x > cw + 20) p.x = -20;

    const alpha = p.a * (0.7 + Math.sin(time * 0.6 + p.phase) * 0.3) * (1 + audioLevel * 0.5);
    const glow = p.r * (1 + audioLevel * 0.4);

    const grd = ctx.createRadialGradient(p.x, p.y, 0, p.x, p.y, glow * 10);
    grd.addColorStop(0, `rgba(${currentAuraRGB}, ${alpha * 0.55})`);
    grd.addColorStop(0.3, `rgba(${currentAuraRGB}, ${alpha * 0.28})`);
    grd.addColorStop(1, `rgba(${currentAuraRGB}, 0)`);
    ctx.fillStyle = grd;
    ctx.beginPath();
    ctx.arc(p.x, p.y, glow * 10, 0, Math.PI * 2);
    ctx.fill();
  }

  // 辷・匱邊貞ｭ・
if (burstQueue.length > 0) {
    for (let i = burstQueue.length - 1; i >= 0; i--) {
      const p = burstQueue[i];
      p.x += p.vx; p.y += p.vy;
      p.vx *= 0.96; p.vy *= 0.96;
      p.life -= p.decay;
      if (p.life <= 0) { burstQueue.splice(i, 1); continue; }
      const alpha = p.a * p.life;
      const grd = ctx.createRadialGradient(p.x, p.y, 0, p.x, p.y, p.r * 12);
      grd.addColorStop(0, `rgba(${currentAuraRGB}, ${alpha})`);
      grd.addColorStop(1, `rgba(${currentAuraRGB}, 0)`);
      ctx.fillStyle = grd;
      ctx.beginPath();
      ctx.arc(p.x, p.y, p.r * 12, 0, Math.PI * 2);
      ctx.fill();
      ctx.beginPath();
      ctx.fillStyle = `rgba(${currentAuraRGB}, ${alpha * 0.9})`;
      ctx.arc(p.x, p.y, p.r, 0, Math.PI * 2);
      ctx.fill();
    }
  }

  // 諠・勹迢ｬ閾ｪ繧ｨ繝輔ぉ繧ｯ繝・(没入モード時に活性匁E
  if (typeof drawSceneEffect === 'function') {
    drawSceneEffect(dt, time);
  }

  // 繧ｯ繝ｪ繝・け豕｢邏・
if (typeof drawRipples === 'function') {
    drawRipples(dt);
  }

  // 星雲エフェクチE(リング展開晁E
  if (typeof drawNebula === 'function') {
    drawNebula(dt, time);
  }

  requestAnimationFrame(loop);
}

// 繝励Οローグの skip 繝上Φ繝峨Λ繧偵Δ繧ｸ繝･繝ｼ繝ｫ繝ｬ繝吶Νで管琁E(蜀咲函豈弱↓付け外し)
let _prologueSkipHandlers = null;
let _prologueAutoCloseTimer = null;
let _prologueHideTimer = null;

function _clearPrologueSkipHandlers() {
  if (_prologueSkipHandlers) {
    document.removeEventListener('click', _prologueSkipHandlers.click);
    document.removeEventListener('touchstart', _prologueSkipHandlers.click);
    document.removeEventListener('keydown', _prologueSkipHandlers.key);
    _prologueSkipHandlers = null;
  }
}

function runPrologue() {
  const l1 = $('pLine1'), l2 = $('pLine2');
  const prologue = $('prologue');
  if (!prologue || !l1 || !l2) return;

  // 前回の skip 繝上Φ繝峨Λ縺梧ｮ九▲縺ｦ縺・ｌ縺ｰ謦､蜴ｻ (螟夐㍾発火防止)
  _clearPrologueSkipHandlers();
  if (_prologueAutoCloseTimer) { clearTimeout(_prologueAutoCloseTimer); _prologueAutoCloseTimer = null; }
  if (_prologueHideTimer)      { clearTimeout(_prologueHideTimer);      _prologueHideTimer = null; }

  // 迥ｶ諷九Μ繧ｻ繝・ヨ
  prologue.classList.remove('done');
  prologue.style.display = '';
  prologue.style.opacity = '';
  prologue.style.pointerEvents = '';
  l1.classList.remove('show', 'hide');
  l2.classList.remove('show', 'hide');

  const timers = [];
  const t = (fn, ms) => timers.push(setTimeout(fn, ms));

  // 1行目: 1.2s に登場 竊・4.8s 縺ｫ豸医∴めE(3.6秒表示)
  t(() => l1.classList.add('show'), 1200);
  t(() => l1.classList.add('hide'), 4800);

  // 2行目: 5.4s に登場 竊・9s 縺ｫ豸医∴めE(3.6秒表示)
  t(() => l2.classList.add('show'), 5400);
  t(() => l2.classList.add('hide'), 9000);

  // 全体を 10s 縺ｫ髢峨§めE
_prologueAutoCloseTimer = setTimeout(() => {
    prologue.classList.add('done');
    _prologueHideTimer = setTimeout(() => { prologue.style.display = 'none'; }, 3000);
    _clearPrologueSkipHandlers();
  }, 10000);
  timers.push(_prologueAutoCloseTimer);

  // 繧ｯ繝ｪ繝・け/繧ｭ繝ｼ謚ｼ荳九〒繧ｹ繧ｭ繝・・
  const skipProlog = (e) => {
    // touchstart の preventDefault 縺ｧ蜷域・ click を抑止 (荳九・繝懊ち繝ｳ隱､繧ｿ繝・・蟇ｾ遲・
    if (e && e.type === 'touchstart' && e.cancelable) {
      try { e.preventDefault(); } catch(_) {}
    }
    timers.forEach(clearTimeout);
    if (_prologueHideTimer) { clearTimeout(_prologueHideTimer); }

    // 笘・縺薙％縺瑚・: .done CSSの pointer-events:none めEinline で上書きして
    //   prologue 譛ｬ菴薙ｒ繧ｯ繝ｪ繝・け謐墓拷蠖ｹ縺ｮ縺ｾ縺ｾ 700ms 邯ｭ謖√☆繧九・    //   touch竊団lick 縺ｮ蜷域・繧ｯ繝ｪ繝・け繧ゅ√◎縺ｮ蠕後・騾｣謇薙ｂ荳九↓貫通しなぁE・
prologue.style.pointerEvents = 'auto';
    prologue.style.transition = 'opacity 0.4s ease';
    prologue.classList.add('done');

    // 騾乗・繝悶Ο繝・き繝ｼ: 丁E′荳 prologue 蛛ｴ縺梧黒縺ｾ縺域錐縺ｭ縺ｦ繧よ怙蜑埼擇縺ｧ遒ｺ螳溘↓防ぁE
const blocker = document.createElement('div');
    blocker.setAttribute('aria-hidden', 'true');
    blocker.style.cssText =
      'position:fixed;inset:0;z-index:100001;background:transparent;' +
      'pointer-events:auto;cursor:none;';
    const consume = (ev) => { ev.stopPropagation(); if (ev.cancelable) ev.preventDefault(); };
    ['click','touchstart','touchend','pointerdown','pointerup','mousedown','mouseup'].forEach(type =>
      blocker.addEventListener(type, consume, { capture: true, passive: false })
    );
    document.body.appendChild(blocker);

    _prologueHideTimer = setTimeout(() => {
      prologue.style.display = 'none';
      prologue.style.pointerEvents = '';
      prologue.style.transition = '';
      blocker.remove();
    }, 700);

    _clearPrologueSkipHandlers();
  };
  const skipKey = (e) => {
    if (e.key === 'Escape' || e.key === ' ' || e.key === 'Enter') skipProlog();
  };

  _prologueSkipHandlers = { click: skipProlog, key: skipKey };

  prologue.style.cursor = 'pointer';
  // 蛻晏虚縺ｮ繧ｯ繝ｪ繝・け/繧ｭ繝ｼ繧､繝吶Φ繝医′繝舌ヶ繝ｫ縺ｧ隱倡匱縺励↑縺・ｈ縺・ｰ代＠驕・ｉ縺帙※ attach
  setTimeout(() => {
    if (!_prologueSkipHandlers) return;  // 縺昴・髢薙↓髢峨§繧峨ｌ縺溷ｴ蜷医・菴輔ｂ縺励↑ぁE
document.addEventListener('click', _prologueSkipHandlers.click);
    document.addEventListener('touchstart', _prologueSkipHandlers.click);
    document.addEventListener('keydown', _prologueSkipHandlers.key);
  }, 250);
}

// ============ 土星リング (タグ) ============
const ringsCanvas = $('ringsCanvas');
const ringsCtx = ringsCanvas.getContext('2d', { alpha: true });
const ringsOverlay = $('ringsOverlay');
const ringsTrigger = $('ringsTrigger');
const tagFlash = $('tagFlash');

let ringsOpen = false;
let ringsAnimProgress = 0; // 0: 髢峨§, 1: 螳悟・螻暮幕
let ringsAnimTarget = 0;

// リング設宁E
let RING_TILT = -0.32; // 土星の傾ぁE(ラジアン) - 繝峨Λ繝・げ縺ｧ螟画峩蜿ｯ閭ｽ
let PERSPECTIVE_K = 0.35; // 讌募・縺ｮY軸圧縮 (螂･陦後″愁E - 繝峨Λ繝・げ縺ｧ螟画峩蜿ｯ閭ｽ
const PERSPECTIVE_K_MIN = 0.12; // ほぼ横から見る(阮・＞讌募・)
const PERSPECTIVE_K_MAX = 0.85; // ほぼ真上から見る(冁E↓近い)

class TagRing {
  constructor(tags, radiusMul, rotationSpeed, direction) {
    this.tags = tags;
    this.radiusMul = radiusMul;
    this.rotation = Math.random() * Math.PI * 2;
    this.rotationSpeed = rotationSpeed * direction;
    this.hoveredIndex = -1;
    this.tagStates = tags.map(() => ({ hover: 0, pulse: 0 }));
    // 繝峨Λ繝・げ縺ｫ繧医ｋ謇句虚蝗櫁ｻ｢逕ｨ
    this.isDragging = false;
    this.dragLastAngle = 0;
    this.velocity = 0; // 繝峨Λ繝・げ繝ｪ繝ｪ繝ｼ繧ｹ蠕後・諷｣諤ｧ
  }

  getTagPosition(index, cx, cy, baseRadius) {
    const angleStep = (Math.PI * 2) / this.tags.length;
    const baseAngle = index * angleStep + this.rotation;

    // 蜀・捉荳翫・菴咲ｽｮ繧呈･募・縺ｫ謚募ｽｱ (土星傾き込み)
    const cosT = Math.cos(RING_TILT);
    const sinT = Math.sin(RING_TILT);

    const rx = Math.cos(baseAngle) * baseRadius * this.radiusMul;
    const ry = Math.sin(baseAngle) * baseRadius * this.radiusMul * PERSPECTIVE_K;

    // 傾き回転
    const x = cx + rx * cosT - ry * sinT;
    const y = cy + rx * sinT + ry * cosT;

    // 螂･陦後″ (y縺御ｸ句・縺ｻ縺ｩ謇句燕縲∽ｸ雁・縺ｻ縺ｩ螂･)
    // 視覚的なz: sin(baseAngle) 縺梧ｭ｣縺ｪ繧牙･･縲∬ｲ縺ｪ繧画焔蜑・
const z = Math.sin(baseAngle);

    return { x, y, z, angle: baseAngle };
  }

  update(dt, time) {
    if (ringsOpen) {
      if (this.isDragging) {
        // 繝峨Λ繝・げ荳ｭ: rotation縺ｯ螟夜Κ縺九ｉ譖ｴ譁ｰ縺輔ｌ繧九∬・蜍募屓霆｢縺励↑ぁE      } else if (Math.abs(this.velocity) > 0.0005) {
        // 繝ｪ繝ｪ繝ｼ繧ｹ蠕後・諷｣諤ｧ
        this.rotation += this.velocity;
        this.velocity *= 0.94; // めE▲くり減衰
      } else {
        this.velocity = 0;
        // 通常の自動回転
        this.rotation += this.rotationSpeed * dt * (1 - this.tagStates.reduce((a, s) => a + s.hover, 0) * 0.2);
      }
    }

    this.tagStates.forEach((s, i) => {
      s.hover += ((this.hoveredIndex === i ? 1 : 0) - s.hover) * 0.15;
      s.pulse *= 0.92;
    });
  }

  draw(ctx, cx, cy, baseRadius, openAmount, auraRGB) {
    // 繝ｪ繝ｳ繧ｰ縺ｮ繝医Ξース緁E(ぁE▲すら)
    if (openAmount > 0.3) {
      ctx.save();
      ctx.translate(cx, cy);
      ctx.rotate(RING_TILT);
      ctx.scale(1, PERSPECTIVE_K);
      ctx.beginPath();
      ctx.arc(0, 0, baseRadius * this.radiusMul, 0, Math.PI * 2);
      ctx.strokeStyle = `rgba(212, 164, 76, ${0.12 * openAmount})`;
      ctx.lineWidth = 1;
      ctx.stroke();

      // リングの星屁E(陬・｣ｾ)
      const dustCount = 120;
      for (let i = 0; i < dustCount; i++) {
        const a = (i / dustCount) * Math.PI * 2;
        const r = baseRadius * this.radiusMul * (0.98 + Math.sin(i * 17.3) * 0.03);
        const x = Math.cos(a) * r;
        const y = Math.sin(a) * r;
        const sparkle = (Math.sin(a * 3 + performance.now() * 0.001) + 1) * 0.5;
        ctx.beginPath();
        ctx.fillStyle = `rgba(245, 216, 150, ${0.15 * openAmount * sparkle})`;
        ctx.arc(x, y, 0.8, 0, Math.PI * 2);
        ctx.fill();
      }
      ctx.restore();
    }

    // 蜷・ち繧ｰ縺ｮ謠冗判
    this.tags.forEach((tag, i) => {
      const pos = this.getTagPosition(i, cx, cy, baseRadius);
      const state = this.tagStates[i];

      // 螻暮幕繧｢繝九Γ: 荳ｭ螟ｮ縺九ｉ蠕舌・↓庁E′めE
const animRadius = baseRadius * this.radiusMul * openAmount;
      const adjustedX = cx + (pos.x - cx) * openAmount;
      const adjustedY = cy + (pos.y - cy) * openAmount;

      // 螂･陦後″によるサイズ変化
      const depthScale = 0.8 + (pos.z + 1) * 0.2; // 0.8 、E1.2

      // 繧ｪ繝代す繝・ぅ (ホバーで明るぁE
      const baseOp = 0.35 * openAmount;
      const hoverOp = state.hover * 0.6;
      const pulseOp = state.pulse * 0.4;
      const totalOp = Math.min(1, baseOp + hoverOp + pulseOp);

      // グロー (ホバー/繝代Νス晁E
      if (state.hover > 0.05 || state.pulse > 0.01) {
        const glowRad = 40 * (state.hover + state.pulse);
        const grd = ctx.createRadialGradient(adjustedX, adjustedY, 0, adjustedX, adjustedY, glowRad);
        grd.addColorStop(0, `rgba(245, 216, 150, ${(state.hover * 0.4 + state.pulse * 0.6) * openAmount})`);
        grd.addColorStop(1, 'rgba(245, 216, 150, 0)');
        ctx.fillStyle = grd;
        ctx.beginPath();
        ctx.arc(adjustedX, adjustedY, glowRad, 0, Math.PI * 2);
        ctx.fill();
      }

      // 繧ｿ繧ｰ譁・ｭ・      ctx.save();
      ctx.translate(adjustedX, adjustedY);

      // 譁・ｭ励ｒ蜀・捉縺ｮ謗･邱壹↓豐ｿ繧上○めE(リング傾き込み)
      const tangentAngle = pos.angle + Math.PI / 2;
      const cosT = Math.cos(RING_TILT);
      const sinT = Math.sin(RING_TILT);
      // 蛯ｾ縺榊ｾ後・謗･邱夊ｧ貞ｺｦ
      let textRotation = Math.atan2(
        Math.sin(tangentAngle) * cosT * PERSPECTIVE_K + Math.cos(tangentAngle) * sinT,
        Math.cos(tangentAngle) * cosT - Math.sin(tangentAngle) * sinT * PERSPECTIVE_K
      );
      // 譁・ｭ励′蟶ｸ縺ｫ隱ｭ繧√ｋ蜷代″縺ｫ縺ｪ繧九ｈ縺・ｭ｣隕丞喧 (-90度、E90度に収めめE
      // textRotationが下向ぁE(90度、E70度) なめE80度反転
      while (textRotation > Math.PI / 2) textRotation -= Math.PI;
      while (textRotation < -Math.PI / 2) textRotation += Math.PI;

      ctx.rotate(textRotation);
      ctx.scale(depthScale, depthScale);

      // 繝・く繧ｹ繝域緒逕ｻ
      ctx.font = `600 21px 'Noto Serif JP', serif`;
      ctx.textAlign = 'center';
      ctx.textBaseline = 'middle';

      // 影 (読みめE☆縺募━蜈医〒蠑ｷ繧√↓)
      ctx.shadowColor = `rgba(0, 0, 0, ${0.85 * openAmount})`;
      ctx.shadowBlur = 14;

      // 繝帙ヰ繝ｼ譎ゅ・濶ｲ
      const textColorR = 245;
      const textColorG = 240 - state.hover * 16;
      const textColorB = 230 - state.hover * 44;
      ctx.fillStyle = `rgba(${textColorR}, ${textColorG}, ${textColorB}, ${totalOp})`;
      ctx.fillText(tag.jp, 0, 0);

      // 繝帙ヰ繝ｼ譎ゅ・霑ｽ蜉逋ｺ蜈・
if (state.hover > 0.1) {
        ctx.shadowColor = 'rgba(245, 216, 150, 0.9)';
        ctx.shadowBlur = 24 * state.hover;
        ctx.fillStyle = `rgba(245, 216, 150, ${state.hover * 0.6})`;
        ctx.fillText(tag.jp, 0, 0);
      }

      ctx.shadowColor = 'transparent';
      ctx.shadowBlur = 0;

      // 闍ｱ隱槭Λ繝吶Ν (繝帙ヰ繝ｼ譎ゅ・縺ｿ)
      if (state.hover > 0.2) {
        ctx.font = `500 12px 'Cinzel', serif`;
        ctx.fillStyle = `rgba(212, 164, 76, ${state.hover * 0.8})`;
        ctx.fillText(tag.en.toUpperCase(), 0, 20);
      }

      // タグ数 (繝帙ヰ繝ｼ譎ゅ・縺ｿ)
      if (state.hover > 0.3) {
        ctx.font = `400 12px 'Cinzel', serif`;
        ctx.fillStyle = `rgba(245, 240, 230, ${state.hover * 0.6})`;
        ctx.fillText(`${tag.count} tracks`, 0, -20);
      }

      ctx.restore();
    });
  }

  hitTest(px, py, cx, cy, baseRadius, openAmount) {
    if (openAmount < 0.5) return -1;
    let closest = -1;
    let closestDist = 55; // ヒット半征E
this.tags.forEach((tag, i) => {
      const pos = this.getTagPosition(i, cx, cy, baseRadius);
      const adjustedX = cx + (pos.x - cx) * openAmount;
      const adjustedY = cy + (pos.y - cy) * openAmount;
      const dx = px - adjustedX;
      const dy = py - adjustedY;
      const dist = Math.hypot(dx, dy);
      if (dist < closestDist) {
        closest = i;
        closestDist = dist;
      }
    });
    return closest;
  }
}

// 繧ｿ繧ｰ謨ｰ縺悟｢励∴縺溘・縺ｧ蜊雁ｾ・ｒ諡｡螟ｧ (霈ｪ縺ｯ螟ｧ縺阪￥縺ｪ繧九′譁・ｭ鈴俣繧堤｢ｺ菫・
// 蜀・ｼｪ 26タグ (feeling 9 + story 17), 外輪 32タグ (scene 21 + style 11)
const ringInner = new TagRing(TAGS_FEELING, 0.92, 0.08, 1);
const ringOuter = new TagRing(TAGS_SCENE,   1.55, -0.05, -1);

function resizeRingsCanvas() {
  ringsCanvas.width = innerWidth * dpr;
  ringsCanvas.height = innerHeight * dpr;
  ringsCanvas.style.width = innerWidth + 'px';
  ringsCanvas.style.height = innerHeight + 'px';
  ringsCtx.setTransform(dpr, 0, 0, dpr, 0, 0);
}
resizeRingsCanvas();
addEventListener('resize', resizeRingsCanvas);

function toggleRings() {
  if (ringsOpen) closeRings();
  else openRings();
}
function openRings() {
  ringsOpen = true;
  ringsAnimTarget = 1;
  ringsOverlay.classList.add('visible');
  ringsTrigger.classList.add('active');
  document.body.classList.add('rings-open');
}
function closeRings() {
  ringsOpen = false;
  ringsAnimTarget = 0;
  ringsOverlay.classList.remove('visible');
  ringsTrigger.classList.remove('active');
  document.body.classList.remove('rings-open');
  ringInner.hoveredIndex = -1;
  ringOuter.hoveredIndex = -1;
}

ringsTrigger.addEventListener('click', toggleRings);

// 繝ｪ繝ｳ繧ｰ縺ｮ繝峨Λ繝・げ迥ｶ諷・
let ringDragActiveRing = null;
let ringDragStartPx = null;
let ringDragStartPy = null;
let ringDragStartTime = 0;
let ringDragStartRotation = 0;
let ringDragStartPerspective = 0;
let ringDragHasMoved = false;
const RING_DRAG_THRESHOLD = 5;

ringsCanvas.addEventListener('pointerdown', e => {
  if (!ringsOpen) return;

  const cx = innerWidth / 2;
  const cy = innerHeight / 2;
  const baseRadius = Math.min(innerWidth, innerHeight) * 0.48;

  const dx = e.clientX - cx;
  const dy = e.clientY - cy;
  const cosT = Math.cos(RING_TILT);
  const sinT = Math.sin(RING_TILT);
  const localX = dx * cosT + dy * sinT;
  const localY = (-dx * sinT + dy * cosT) / PERSPECTIVE_K;
  const distFromCenter = Math.hypot(localX, localY);

  const innerR = baseRadius * ringInner.radiusMul;
  const outerR = baseRadius * ringOuter.radiusMul;
  const distToInner = Math.abs(distFromCenter - innerR);
  const distToOuter = Math.abs(distFromCenter - outerR);
  const targetRing = distToInner < distToOuter ? ringInner : ringOuter;

  ringDragActiveRing = targetRing;
  ringDragStartPx = e.clientX;
  ringDragStartPy = e.clientY;
  ringDragStartTime = performance.now();
  ringDragStartRotation = targetRing.rotation;
  ringDragStartPerspective = PERSPECTIVE_K;
  ringDragHasMoved = false;
  targetRing.isDragging = false;
});

ringsCanvas.addEventListener('pointermove', e => {
  if (!ringsOpen) return;

  if (ringDragActiveRing) {
    const moveDx = e.clientX - ringDragStartPx;
    const moveDy = e.clientY - ringDragStartPy;
    const moveDist = Math.hypot(moveDx, moveDy);

    if (!ringDragHasMoved && moveDist > RING_DRAG_THRESHOLD) {
      ringDragHasMoved = true;
      ringDragActiveRing.isDragging = true;
      ringDragActiveRing.velocity = 0;
    }

    if (ringDragHasMoved) {
      const cx = innerWidth / 2;
      const cy = innerHeight / 2;

      // 横移勁E(角度変化) 竊・蝗櫁ｻ｢
      const startAngle = Math.atan2(ringDragStartPy - cy, ringDragStartPx - cx);
      const currentAngle = Math.atan2(e.clientY - cy, e.clientX - cx);
      let deltaAngle = currentAngle - startAngle;
      while (deltaAngle > Math.PI) deltaAngle -= Math.PI * 2;
      while (deltaAngle < -Math.PI) deltaAngle += Math.PI * 2;
      const newRotation = ringDragStartRotation + deltaAngle;
      ringDragActiveRing.velocity = (newRotation - ringDragActiveRing.rotation) * 0.4;
      ringDragActiveRing.rotation = newRotation;

      // 邵ｦ遘ｻ蜍・竊・螂･陦後″(PERSPECTIVE_K)繧貞､峨∴めE      // 上方吁E 冁E↓霑代▼ぁE真上から見る)縲∽ｸ区婿蜷・ 阮・＞讌募・(横から見る)
      PERSPECTIVE_K = ringDragStartPerspective - moveDy / 500;
      PERSPECTIVE_K = Math.max(PERSPECTIVE_K_MIN, Math.min(PERSPECTIVE_K_MAX, PERSPECTIVE_K));

      return;
    }
  }

  // ホバー判宁E(繝峨Λ繝・げ縺励※ぁE↑縺・ｴ蜷・
  const cx = innerWidth / 2;
  const cy = innerHeight / 2;
  const baseRadius = Math.min(innerWidth, innerHeight) * 0.48;

  const innerHit = ringInner.hitTest(e.clientX, e.clientY, cx, cy, baseRadius, ringsAnimProgress);
  ringInner.hoveredIndex = innerHit;
  const outerHit = (innerHit >= 0) ? -1 :
    ringOuter.hitTest(e.clientX, e.clientY, cx, cy, baseRadius, ringsAnimProgress);
  ringOuter.hoveredIndex = outerHit;

  if (innerHit >= 0 || outerHit >= 0) cur.classList.add('hov');
  else cur.classList.remove('hov');
});

addEventListener('pointerup', e => {
  if (ringDragActiveRing) {
    if (ringDragHasMoved) {
      ringDragActiveRing.isDragging = false;
    }
    ringDragActiveRing = null;
  }
});

// 繝ｪ繝ｳ繧ｰ蜀・・繧ｯ繝ｪ繝・け (繝峨Λ繝・げ縺輔ｌ縺ｪ縺九▲縺溷ｴ蜷医・縺ｿ)
ringsCanvas.addEventListener('click', e => {
  if (!ringsOpen) return;
  // 繝峨Λ繝・げ縺檎匱逕溘＠縺ｦ縺・◆蝣ｴ蜷医・繧ｯ繝ｪ繝・け謇ｱ縺・＠縺ｪ縺・
if (ringDragHasMoved) {
    ringDragHasMoved = false;
    return;
  }

  const cx = innerWidth / 2;
  const cy = innerHeight / 2;
  const baseRadius = Math.min(innerWidth, innerHeight) * 0.48;

  // 謇句燕縺ｮ蜀・ｼｪ縺九ｉ蛻､螳・
let hitTag = null;
  let hitType = null;

  // tag.type 縺ｫ蠢懊§縺溘Λ繝吶Ν (feeling/story/scene/style)
  const _CAT_LABEL = {
    feeling: { en: 'Feeling', jp: '感情' },
    story:   { en: 'Story',   jp: '物誁E' },
    scene:   { en: 'Scene',   jp: '諠・勹' },
    style:   { en: 'Style',   jp: 'スタイル' }
  };

  const innerHit = ringInner.hitTest(e.clientX, e.clientY, cx, cy, baseRadius, ringsAnimProgress);
  if (innerHit >= 0) {
    hitTag = ringInner.tags[innerHit];
    hitType = _CAT_LABEL[hitTag.type] || { en: 'Tag', jp: 'タグ' };
    ringInner.tagStates[innerHit].pulse = 1;
  } else {
    const outerHit = ringOuter.hitTest(e.clientX, e.clientY, cx, cy, baseRadius, ringsAnimProgress);
    if (outerHit >= 0) {
      hitTag = ringOuter.tags[outerHit];
      hitType = _CAT_LABEL[hitTag.type] || { en: 'Tag', jp: 'タグ' };
      ringOuter.tagStates[outerHit].pulse = 1;
    }
  }

  if (hitTag) {
    selectTag(hitTag, hitType);
  } else {
    // 菴輔ｂ縺ｪ縺・→縺薙ｍ繧ｯ繝ｪ繝・け縺ｧ髢峨§めE    closeRings();
  }
});

// ESC縺ｧ髢峨§めE
addEventListener('keydown', e => {
  if (e.key === 'Escape' && ringsOpen) {
    e.stopPropagation();
    closeRings();
  }
});

// タグ選択時の処琁E
function selectTag(tag, type) {
  // 繧ｿ繧ｰ驕ｸ謚槭ヵ繝ｩ繝・す繝･陦ｨ遉ｺ
  $('tagTypeLabel').textContent = `${type.en} ﾂｷ ${type.jp}`;
  $('tagJp').textContent = tag.jp;
  $('tagTracks').textContent = `${tag.count} tracks`;
  tagFlash.classList.add('visible');

  setTimeout(() => {
    // 諠・勹蛻・崛 (譖ｲ縺ｯ蠕後〒荳頑嶌縺阪☆繧九・縺ｧ updateTrack=false)
    const targetIdx = scenes.findIndex(s => s.id === tag.sceneId);
    if (targetIdx >= 0) {
      selectScene(targetIdx, false);
    }

    // 繧ｷ繝ｼ繝ｳ蜷阪ち繧､繝医Νを抑制 (繧ｿ繧ｰ譌・ｸｭ縺ｯ繧ｿ繧ｰ蜷阪′荳ｻ蠖ｹ縲√す繝ｼ繝ｳ蜷阪・蜃ｺ縺輔↑ぁE
    clearTimeout(window._titleTimer);
    $('sceneTitle').classList.remove('visible');

    // 繧ｿ繧ｰ蝗ｺ譛臥判蜒上↓差し替ぁE(存在すれば)
    overrideSceneImageForTag(tag.id);

    // 繧ｿ繧ｰ驕ｸ謚槭・繝ｦ繝ｼ繧ｶ繝ｼ蜈･蝣ｴ縺ｮ譏守､ｺ逧・桃菴懊↑のでウェルカムモードを解除
    // (隗｣髯､縺励↑縺・→譖ｲ邨ゆｺ・凾縺ｫ ended竊胆playWelcomeMusic 縺ｸ鬟帙・縲√ち繧ｰ譌・′1曲で止まめE
    if (typeof _welcomeMode !== 'undefined') _welcomeMode = false;

    // 繧ｿ繧ｰ繝吶・繧ｹ縺ｧ螳溘ヨ繝ｩ繝・け繧帝∈曲
    const picked = pickTrackForTag(tag.id);
    if (picked) {
      _pushHistory(tag.sceneId, picked);
      currentTrackData = picked;
      const displayTitle = picked.title || '';
      trackName.textContent = displayTitle;
      imName.textContent = displayTitle;
      initAudioAnalyser();
      if (audioCtx && audioCtx.state === 'suspended') audioCtx.resume();
      audio.src = resolveTrackUrl(picked);
      audio.load();
      audio.play().catch(() => {});
    }

    // 繝ｪ繝ｳ繧ｰ髢峨§めE    closeRings();
  }, 1000);

  setTimeout(() => {
    tagFlash.classList.remove('visible');
  }, 2500);
}

// リング描画ルーチE
function drawRings() {
  // 繧｢繝九Γ補間
  ringsAnimProgress += (ringsAnimTarget - ringsAnimProgress) * 0.08;

  if (ringsAnimProgress < 0.01 && !ringsOpen) {
    ringsCtx.clearRect(0, 0, innerWidth, innerHeight);
    requestAnimationFrame(drawRings);
    return;
  }

  ringsCtx.clearRect(0, 0, innerWidth, innerHeight);

  const cx = innerWidth / 2;
  const cy = innerHeight / 2;
  const baseRadius = Math.min(innerWidth, innerHeight) * 0.48;

  const now = performance.now() * 0.001;
  const dt = 0.016;

  ringInner.update(dt, now);
  ringOuter.update(dt, now);

  // 荳ｭ螟ｮ縺ｮ陬・｣ｾ: 蜈峨・譬ｸ
  if (ringsAnimProgress > 0.2) {
    const coreOp = ringsAnimProgress;
    const coreSize = 30 + Math.sin(now * 1.5) * 3;
    const grd = ringsCtx.createRadialGradient(cx, cy, 0, cx, cy, coreSize);
    grd.addColorStop(0, `rgba(245, 216, 150, ${0.6 * coreOp})`);
    grd.addColorStop(0.4, `rgba(212, 164, 76, ${0.25 * coreOp})`);
    grd.addColorStop(1, 'rgba(245, 216, 150, 0)');
    ringsCtx.fillStyle = grd;
    ringsCtx.beginPath();
    ringsCtx.arc(cx, cy, coreSize, 0, Math.PI * 2);
    ringsCtx.fill();

    // 中央の小さな冁E    ringsCtx.beginPath();
    ringsCtx.arc(cx, cy, 3, 0, Math.PI * 2);
    ringsCtx.fillStyle = `rgba(245, 216, 150, ${0.9 * coreOp})`;
    ringsCtx.fill();
  }

  // 外輪 (後ろから描画)
  ringOuter.draw(ringsCtx, cx, cy, baseRadius, ringsAnimProgress, currentAuraRGB);
  // 蜀・ｼｪ (手前)
  ringInner.draw(ringsCtx, cx, cy, baseRadius, ringsAnimProgress, currentAuraRGB);

  requestAnimationFrame(drawRings);
}
drawRings();

// ============ 雜ｳ霍｡讖溯・ (蝓ｺ譛ｬ繝ｭ繧ｸ繝・け - Firebase連携剁E ============
const footprintCanvas = $('footprintCanvas');
const footprintCtx = footprintCanvas.getContext('2d', { alpha: true });

function resizeFootprintCanvas() {
  // 雜ｳ霍｡譁・ｭ励・ DECOR_DPR 縺ｧ蜊∝・ (shadowBlur 縺ｫ繧医ｋ縺ｫ縺倥∩が支配的なので)
  footprintCanvas.width = innerWidth * DECOR_DPR;
  footprintCanvas.height = innerHeight * DECOR_DPR;
  footprintCanvas.style.width = innerWidth + 'px';
  footprintCanvas.style.height = innerHeight + 'px';
  footprintCtx.setTransform(DECOR_DPR, 0, 0, DECOR_DPR, 0, 0);
}
resizeFootprintCanvas();
addEventListener('resize', resizeFootprintCanvas);

// 足跡オブジェクチE(螟懃ｩｺ繧呈ｼゅ≧縲√⊂繧・￠縺溯ｩｩ逧・↑險葁E
class Footprint {
  constructor(data) {
    this.id = data.id;
    this.message = data.message;
    this.author = data.author;
    this.sceneId = data.sceneId;
    this.sceneName = data.sceneName;
    this.createdAt = data.createdAt;
    this.isLegend = data.isLegend || false;

    // 深度 (0=遠ぁE小さぁEぼんやめE 1=近い/大きい/はっきり)
    // 譁ｰ隕乗兜遞ｿ縺ｯ蜈ｨ菴鍋噪縺ｫ螂･蟇・ｊ繝ｻ荳驛ｨ繧定ｿ第勹縺ｧ逶ｮ遶九◆せる
    const r = Math.random();
    if (r < 0.60) this.depth = Math.random() * 0.30;            // 遠ぁE(60%)
    else if (r < 0.90) this.depth = 0.30 + Math.random() * 0.35; // 中 (30%)
    else this.depth = 0.70 + Math.random() * 0.30;              // 近い (10%) 竊・逶ｮ遶九▽

    // 伝説(Claude逕滓・)は常に奥・滲ませる (譛ｬ迚ｩ縺ｮ雜ｳ霍｡縺ｮ閭梧勹縺ｨ縺励※)
    if (this.isLegend) {
      this.depth = 0.08 + Math.random() * 0.30; // 0.08、E.38 (奥〜中の手前まで)
    }

    // 譁・ｭ励し繧､繧ｺ: 深度で変化
    if (this.isLegend) {
      // 莨晁ｪｬ縺ｯ蟆上＆繧√∵而縺医ａ
      this.fontSize = 13 + this.depth * 14; // 13、E0px
    } else {
      // 新規投稿: 近いほど大きく (逶ｮ遶九▽繧医≧に)
      this.fontSize = 10 + this.depth * 38; // 10、E8px
    }

    // ぼかし釁E 遠ぁE⊇縺ｩ縺ｼ繧・￠繧・
if (this.isLegend) {
      // 莨晁ｪｬ縺ｯ繧医ｊ蠑ｷ縺上⊂かして滲ませる
      this.blur = (1 - this.depth) * 9 + 2.0; // 実効 4.2、E1.0
    } else {
      this.blur = (1 - this.depth) * 6 + 0.8;
    }

    // 蝓ｺ譛ｬ繧ｪ繝代す繝・ぅ (蟄伜惠諢溘ｒ蠑ｱ繧√※ UI 縺ｮ驍ｪ鬲斐ｒ縺励↑ぁE
    this.baseOpacity = 0.12 + this.depth * 0.26;  // 0.12 、E0.38
    if (this.isLegend) {
      // 伝説はさらに控えめ (貊ｲ繧薙〒螂･縺ｫ豐医・)
      this.baseOpacity = 0.09 + this.depth * 0.12; // 0.09、E.14
    }

    // 繧上★縺九↑傾ぁE
this.rotation = (Math.random() - 0.5) * 0.25;
    // 莨晁ｪｬ縺ｯ繧ゅ▲縺ｨ逵溘▲逶ｴ縺舌↓ (蜴ｳ縺九＆繧貞・縺・
    if (this.isLegend) {
      this.rotation = (Math.random() - 0.5) * 0.1;
    }

    // 蜍輔″の速度 (驕縺・ｂ縺ｮ縺ｻ縺ｩ繧・▲くり)
    this.speed = (0.08 + Math.random() * 0.12) * (0.4 + this.depth * 0.8);
    // 伝説はさらにめE▲くり(驥阪∩縺ｮ縺ゅｋ蜍輔″)
    if (this.isLegend) {
      this.speed *= 0.7;
    }

    this.phase = Math.random() * Math.PI * 2;
    this.ampY = 4 + Math.random() * 10 + this.depth * 8;
    this.ampX = 2 + Math.random() * 5;
    this.rotPhase = Math.random() * Math.PI * 2;
    this.rotAmp = 0.015 + Math.random() * 0.025;

    this.colorWarmth = this.depth;

    this.reset(true);

    this.opacity = 0;
    this.targetOpacity = this.baseOpacity;
    this.hoverBoost = 0;
    this.age = 0;
    this.hovering = false;
  }

  reset(initial = false) {
    if (initial) {
      // 初回: 画面冁E↓繝ｩ繝ｳ繝ム配置 (縺吶＄隕九∴るよぁE↓)
      this.x = Math.random() * innerWidth;
    } else {
      // 蜀榊・迴ｾ: 右端外かめE
this.x = innerWidth + 80 + Math.random() * 200;
    }
    // Y座樁E 蜈ｨ逕ｻ髱｢繝ｩ繝ｳ繝ム (荳贋ｸ九・繝ｼ繧ｸ繝ｳ蟆代＠)
    this.y = 60 + Math.random() * (innerHeight - 120);

    this.phase = Math.random() * Math.PI * 2;
    this.age = 0;
  }

  update(dt, time) {
    this.age += dt;
    // めE▲縺上ｊ蟾ｦ縺ｸ豬√ｌ繧・(深度で速度変化)
    this.x -= this.speed * 60 * dt;
    // 荳贋ｸ九↓縺ｵ繧上・繧・
this.bobY = Math.sin(time * 0.3 + this.phase) * this.ampY;
    this.bobX = Math.cos(time * 0.2 + this.phase * 1.3) * this.ampX;

    // 蝗櫁ｻ｢縺ｮ謠ｺ繧峨℃
    this.currentRotation = this.rotation + Math.sin(time * 0.15 + this.rotPhase) * this.rotAmp;

    // 逕ｻ髱｢螟悶↓出たら右端へ戻ぁE(豌ｸ驕縺ｫ貍ゅ≧)
    if (this.x < -600) this.reset();

    // 繧ｪ繝代す繝・ぅ: フェードイン
    this.opacity += (this.targetOpacity - this.opacity) * 0.025;

    // 繝帙ヰ繝ｼ繝悶・繧ｹ繝・
this.hoverBoost += ((this.hovering ? 1 : 0) - this.hoverBoost) * 0.18;

    // 蜃ｺ迴ｾ逶ｴ蠕後・蜈・(閾ｪ蛻・・謚慕ｨｿ譎・
    if (this.justBorn > 0) {
      this.justBorn -= dt;
    }
  }

  draw(ctx) {
    if (this.opacity < 0.01) return;
    if (!this.message) return;

    const effectiveX = this.x + this.bobX;
    const effectiveY = this.y + this.bobY;

    // 繝帙ヰ繝ｼ譎ゅ・蠑ｷ蛹・
const hoverFade = this.hoverBoost;
    const currentOpacity = Math.min(1, this.opacity * (1 + hoverFade * 0.8));
    const currentSize = this.fontSize * (1 + hoverFade * 0.06);

    ctx.save();
    ctx.translate(effectiveX, effectiveY);
    ctx.rotate(this.currentRotation);

    // 色: 伝説は特別な金緑色、E壼ｸｸ縺ｯ關ｽ縺｡逹ぁE◆青緁E(豺ｱ蠎ｦ縺ｧ豼・ｷ｡繧貞､峨∴めE
    let r, g, b;
    if (this.isLegend) {
      // 伝説: 神秘的な古代金色 (繧｢繝ｳ繝・ぅ繝ｼ繧ｯ繧ｴ繝ｼ繝ｫ繝・縲∵ｷｱ蠎ｦ縺ｧ譏弱ｋ縺輔□縺大､峨∴めE
const base = 0.65 + this.depth * 0.35;
      r = Math.round(212 * base + 40);
      g = Math.round(180 * base + 40);
      b = Math.round(120 * base + 30);
    } else {
      // 通常足跡: 縺ｻ縺ｼ逋ｽ縺ｫ髱堤ｷ代・縺ｻ縺ｮ縺九↑色味。控えめで UI 縺ｮ驍ｪ鬲斐ｒ縺励↑ぁE
const nearR = 225, nearG = 240, nearB = 235;  // 手前: 逋ｽ縺ｫ讌ｵ繧√※近い青緁E
const farR  = 170, farG  = 200, farB  = 195;  // 奥: 阮・＞髱堤ｷ・(逋ｽ蟇・ｊ)
      r = Math.round(farR + (nearR - farR) * this.colorWarmth);
      g = Math.round(farG + (nearG - farG) * this.colorWarmth);
      b = Math.round(farB + (nearB - farB) * this.colorWarmth);
    }

    // フォンチE
const weight = 300 + Math.round(this.depth * 100);
    ctx.font = `${weight} ${currentSize}px 'Noto Serif JP', serif`;
    ctx.textAlign = 'left';
    ctx.textBaseline = 'middle';

    // ========== 逋ｺ蜈峨・謚代∴めE ぁE▲縺吶ｉ逋ｽ髱堤ｷ代・繧ｪ繝ｼ繝ｩ ==========
    // 螟門・縺ｮ譟斐ｉ縺九＞蜈・(謗ｧ縺医ａ縲√・繝舌・譎ゅ・縺ｿ蠑ｷ蛹・
    ctx.shadowColor = `rgba(${r}, ${g}, ${b}, ${0.35 + hoverFade * 0.35})`;
    ctx.shadowBlur = (this.isLegend ? 10 : 14) + this.depth * 8 + hoverFade * 24;
    ctx.shadowOffsetX = 0;
    ctx.shadowOffsetY = 0;

    // 縺ｼ繧・￠縺滓枚蟄励ｒ隍・焚蝗樣㍾縺ｭ縺ｦ縲後↓縺倥∩」を作る (阮・ａ)
    const blurPasses = Math.round(2 + (1 - this.depth) * 2); // 遠=4蝗槭∬ｿ・2囁E
const baseOpacity = currentOpacity * 0.35;
    for (let i = 0; i < blurPasses; i++) {
      ctx.fillStyle = `rgba(${r}, ${g}, ${b}, ${baseOpacity / blurPasses * 2})`;
      ctx.fillText(this.message, 0, 0);
    }

    // 繝｡繧､繝ｳ縺ｮ譁・ｭ・(控えめに)
    ctx.shadowBlur = (this.isLegend ? 3 : 6) + hoverFade * 12;
    ctx.fillStyle = `rgba(${r}, ${g}, ${b}, ${currentOpacity * 0.7})`;
    ctx.fillText(this.message, 0, 0);

    // 繝帙ヰ繝ｼ譎ゅ・逋ｽ繧帝㍾ねめE
if (hoverFade > 0.15) {
      ctx.shadowColor = `rgba(255, 240, 210, ${hoverFade * 0.9})`;
      ctx.shadowBlur = 22 * hoverFade;
      ctx.fillStyle = `rgba(255, 248, 230, ${hoverFade * currentOpacity})`;
      ctx.fillText(this.message, 0, 0);
    }

    // 蜃ｺ迴ｾ逶ｴ蠕後・迚ｹ蛻･縺ｪ蜈・(閾ｪ蛻・・謚慕ｨｿ譎ゅ・遘帝俣)
    if (this.justBorn && this.justBorn > 0) {
      const bornIntensity = Math.min(1, this.justBorn / 2);
      ctx.shadowColor = `rgba(255, 240, 210, ${bornIntensity})`;
      ctx.shadowBlur = 40 * bornIntensity;
      ctx.fillStyle = `rgba(255, 248, 230, ${bornIntensity * 0.8})`;
      ctx.fillText(this.message, 0, 0);
    }

    ctx.restore();
  }

  hitTest(px, py, ctx) {
    const effectiveX = this.x + this.bobX;
    const effectiveY = this.y + this.bobY;

    // 蝗櫁ｻ｢繧定・・縺励◆ヒットテスチE
const dx = px - effectiveX;
    const dy = py - effectiveY;
    const cos = Math.cos(-this.currentRotation);
    const sin = Math.sin(-this.currentRotation);
    const rx = dx * cos - dy * sin;
    const ry = dx * sin + dy * cos;

    ctx.font = `300 ${this.fontSize}px 'Noto Serif JP', serif`;
    const width = ctx.measureText(this.message).width;
    const height = this.fontSize * 1.5;

    return (
      rx >= -12 &&
      rx <= width + 12 &&
      ry >= -height / 2 &&
      ry <= height / 2
    );
  }

  // 繝・・繝ｫ繝√ャ繝礼畑縺ｮ逕ｻ髱｢荳翫・菴咲ｽｮ
  getScreenPos(ctx) {
    ctx.font = `300 ${this.fontSize}px 'Noto Serif JP', serif`;
    const width = ctx.measureText(this.message).width;
    // 蝗櫁ｻ｢繧定・・縺励◆中央位置
    const cos = Math.cos(this.currentRotation);
    const sin = Math.sin(this.currentRotation);
    const centerX = this.x + this.bobX + (width / 2) * cos;
    const centerY = this.y + this.bobY + (width / 2) * sin;
    return { x: centerX, y: centerY };
  }
}

let footprints = [];
let hoveredFootprint = null;
const footprintTooltip = $('footprintTooltip');

// ============ 足跡の描画ルーチE============
let lastFootprintFrame = performance.now();
let _footprintDebugLogged = false;

function footprintLoop(now) {
  const dt = Math.min(0.05, (now - lastFootprintFrame) / 1000);
  lastFootprintFrame = now;
  const time = now * 0.001;

  footprintCtx.clearRect(0, 0, innerWidth, innerHeight);

  // 繝・ヰ繝・げ: 譛蛻昴・謨ｰ遘偵□縺代Ο繧ｰ繧貞・縺・
if (!_footprintDebugLogged && footprints.length > 0) {
    console.log('[footprints] rendering', footprints.length, 'items. Example:', footprints[0]);
    _footprintDebugLogged = true;
  }

  footprints.forEach(f => {
    try {
      f.hovering = (f === hoveredFootprint);
      f.update(dt, time);
      f.draw(footprintCtx);
    } catch (e) {
      console.error('[footprint draw error]', e, f);
    }
  });

  requestAnimationFrame(footprintLoop);
}
requestAnimationFrame(footprintLoop);

// ホバー判宁E 繝・・繝ｫ繝√ャ繝苓｡ｨ遉ｺ
addEventListener('pointermove', e => {
  // UI荳翫・繝√ぉ繝・け縺励↑ぁE
if (e.target.closest('.ui > *, .action-tower, .fav-panel, .license-modal, .footprint-form-modal, .confirm-modal, .rings-overlay')) {
    if (hoveredFootprint) {
      hoveredFootprint = null;
      footprintTooltip.classList.remove('visible');
    }
    return;
  }

  let hit = null;
  for (const f of footprints) {
    if (f.hitTest(e.clientX, e.clientY, footprintCtx)) {
      hit = f;
      break;
    }
  }

  if (hit !== hoveredFootprint) {
    hoveredFootprint = hit;
    if (hit) {
      const authorName = hit.author || '名もなき旅人';
      footprintTooltip.innerHTML = `
        <div class="tt-msg">${escapeHtml(hit.message)}</div>
        <div class="tt-meta">
          <span class="author"> E${escapeHtml(authorName)}</span>
          <span>${escapeHtml(hit.sceneName || '')}
            <span class="tt-report" data-id="${hit.id}" title="通報">笞・騾壼ｱ</span>
          </span>
        </div>
      `;
      const pos = hit.getScreenPos(footprintCtx);
      footprintTooltip.style.left = pos.x + 'px';
      footprintTooltip.style.top = pos.y + 'px';
      footprintTooltip.classList.add('visible');
    } else {
      footprintTooltip.classList.remove('visible');
    }
  }

  // 繝・・繝ｫ繝√ャ繝嶺ｽ咲ｽｮ譖ｴ譁ｰ (蜍輔＞縺ｦ縺・ｋ雜ｳ霍｡縺ｫ霑ｽ蠕・
  if (hoveredFootprint) {
    const pos = hoveredFootprint.getScreenPos(footprintCtx);
    footprintTooltip.style.left = pos.x + 'px';
    footprintTooltip.style.top = pos.y + 'px';
  }
});

// 繝・・繝ｫ繝√ャ繝嶺ｸ翫・騾壼ｱ繝懊ち繝ｳ
footprintTooltip.addEventListener('click', e => {
  const reportEl = e.target.closest('.tt-report');
  if (!reportEl) return;
  const fpId = reportEl.dataset.id;
  reportFootprint(fpId);
});

function escapeHtml(s) {
  return String(s || '').replace(/[&<>"']/g, c => ({
    '&':'&amp;', '<':'&lt;', '>':'&gt;', '"':'&quot;', "'":'&#39;'
  })[c]);
}

// ============ 投稿フォーム ============
const footprintTrigger = $('footprintTrigger');
const footprintFormModal = $('footprintFormModal');
const footprintMessage = $('footprintMessage');
const footprintAuthor = $('footprintAuthor');
const footprintCharCount = $('footprintCharCount');
const footprintFormError = $('footprintFormError');

// ============ 雜ｳ霍｡縺ｮ陦ｨ遉ｺ蛻・崛繝医げ繝ｫ ============
// 起動時は常に表示ON縲る℃去の localStorage 縺ｯ荳蠎ｦ繧ｯ繝ｪ繧｢縺励※繝ｪ繧ｻ繝・ヨ
// (莉･蜑阪・繝医げ繝ｫ閾ｪ菴薙′髱櫁｡ｨ遉ｺ縺ｧ縲・俣驕輔▲て hidden=true 縺梧ｮ九▲縺ｦ縺・ｋ繧ｱ繝ｼ繧ｹ繧呈舞貂・
let footprintsHidden = false;
try { localStorage.removeItem('hmix_footprints_hidden'); } catch(_) {}
const footprintToggle = $('footprintToggle');
const footprintToggleIcon = $('footprintToggleIcon');

function applyFootprintVisibility() {
  footprintCanvas.style.transition = 'opacity 0.8s ease';
  footprintCanvas.style.opacity = footprintsHidden ? '0' : '1';
  footprintTooltip.style.display = footprintsHidden ? 'none' : '';
  // 繧｢繧､繧ｳ繝ｳ縺ｨ繝ｩ繝吶Ν繧貞・譖ｿ
  if (footprintsHidden) {
    // 非表示中: 髢峨§た目 + 縲瑚ｶｳ霍｡繧呈綾縺吶・    footprintToggleIcon.innerHTML = '<path d="M17.94 17.94A10.07 10.07 0 0112 20c-7 0-11-8-11-8a18.45 18.45 0 015.06-5.94M9.9 4.24A9.12 9.12 0 0112 4c7 0 11 8 11 8a18.5 18.5 0 01-2.16 3.19m-6.72-1.07a3 3 0 11-4.24-4.24"/><line x1="1" y1="1" x2="23" y2="23"/>';
    footprintToggle.querySelector('.label-show').textContent = '足跡を戻ぁE';
    footprintToggle.querySelector('.label-sub-show').textContent = 'Restore Voices';
  } else {
    footprintToggleIcon.innerHTML = '<path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/>';
    footprintToggle.querySelector('.label-show').textContent = '雜ｳ霍｡繧帝撕繧√ｋ';
    footprintToggle.querySelector('.label-sub-show').textContent = 'Silence Voices';
  }
}

footprintToggle.addEventListener('click', () => {
  footprintsHidden = !footprintsHidden;
  localStorage.setItem('hmix_footprints_hidden', footprintsHidden ? 'true' : 'false');
  applyFootprintVisibility();
});

// 初期状態適用
setTimeout(applyFootprintVisibility, 100);

// ============ 旁EΔーチE(謖・ｮ壽凾髢捺ｯ弱↓諠・勹繧定・蜍募・譖ｿ) ============
let travelMode = false;
let travelTimer = null;
let travelInterval = 60000; // 繝・ヵ繧ｩ繝ｫ繝・蛻・
const travelToggle = $('travelToggle');
const travelLabel = $('travelLabel');
const travelLabelSub = $('travelLabelSub');

function applyTravelMode() {
  if (travelMode) {
    travelLabel.textContent = '譌・ｒ豁｢繧√ｋ';
    travelLabelSub.textContent = 'Pause Travel';
    travelToggle.classList.add('travel-active');
    scheduleNextTravel();
  } else {
    travelLabel.textContent = '旁E☆めE';
    travelLabelSub.textContent = 'Travel';
    travelToggle.classList.remove('travel-active');
    if (travelTimer) { clearTimeout(travelTimer); travelTimer = null; }
    // 騾ｲ陦御ｸｭ繝輔ぉ繝ｼ繝峨ｒ蛛懈ｭ｢縺励※音量を復允E
if (_travelFadeTimer) { clearInterval(_travelFadeTimer); _travelFadeTimer = null; }
    const userVol = (function() {
      const v = parseInt(localStorage.getItem(VOL_KEY) || '80', 10) / 100;
      return isNaN(v) ? 0.8 : Math.max(0, Math.min(1, v));
    })();
    audio.volume = userVol;
  }
}

// 音量フェーチE(譌・・驕ｷ遘ｻ逕ｨ)
let _travelFadeTimer = null;
function _travelFade(targetVol, durationMs, onDone) {
  if (_travelFadeTimer) { clearInterval(_travelFadeTimer); _travelFadeTimer = null; }
  const startVol = audio.volume;
  const steps = 30;
  const stepMs = Math.max(20, durationMs / steps);
  let i = 0;
  _travelFadeTimer = setInterval(() => {
    i++;
    audio.volume = Math.max(0, Math.min(1, startVol + (targetVol - startVol) * (i / steps)));
    if (i >= steps) {
      clearInterval(_travelFadeTimer);
      _travelFadeTimer = null;
      if (onDone) onDone();
    }
  }, stepMs);
}

function scheduleNextTravel() {
  if (travelTimer) clearTimeout(travelTimer);
  travelTimer = setTimeout(() => {
    if (!travelMode) return;
    // ユーザーの音量設定を保孁E
const userVol = (function() {
      const v = parseInt(localStorage.getItem(VOL_KEY) || '80', 10) / 100;
      return isNaN(v) ? 0.8 : Math.max(0, Math.min(1, v));
    })();

    // フェードアウチEↁE次曲へ遷移 ↁEフェードイン
    const fadeMs = Math.min(1500, Math.max(600, travelInterval * 0.15));
    _travelFade(0, fadeMs, () => {
      if (!travelMode) return;
      if (_currentTagOverride) {
        // 繧ｿ繧ｰ譌・ｸｭ縺ｯ蜷後§繧ｿ繧ｰ蜀・〒谺｡縺ｮ譖ｲ (繧ｷ繝ｼ繝ｳ縺ｯ蛻・ｊ譖ｿ縺医↑ぁE
        nextTrack();
      } else {
        // 騾壼ｸｸ縺ｮ諠・勹蟾｡蝗・
let nextIdx;
        do {
          nextIdx = Math.floor(Math.random() * scenes.length);
        } while (nextIdx === currentSceneIndex && scenes.length > 1);
        selectScene(nextIdx);
      }
      // 譁ｰ縺励＞譖ｲ繝ｭ繝ｼ繝牙ｾ後√ヵ繧ｧ繝ｼ繝峨う繝ｳ
      setTimeout(() => {
        if (!travelMode) return;
        _travelFade(userVol, fadeMs);
      }, 250);
    });
    scheduleNextTravel();
  }, travelInterval);
}

travelToggle.addEventListener('click', () => {
  if (travelMode) {
    // 縺吶〒縺ｫ譌・ｸｭ縺ｪ繧牙●止
    travelMode = false;
    applyTravelMode();
    return;
  }
  // 譎る俣驕ｸ謚槭Γ繝九Η繝ｼ繧貞・縺・  showTravelMenu();
});

function showTravelMenu() {
  const menu = document.createElement('div');
  menu.className = 'travel-menu';
  menu.innerHTML = `
    <div class="travel-menu-title">諠・勹繧貞ｷ｡繧矩俣髫・/div>
    <button data-sec="15">15 私E/button>
    <button data-sec="30">30 私E/button>
    <button data-sec="60">1 刁E/button>
    <button data-sec="90">1 刁E30 私E/button>
    <button data-sec="120">2 刁E/button>
    <button data-sec="180">3 刁E/button>
    <button class="travel-menu-cancel">戻めE/button>
  `;
  document.body.appendChild(menu);
  setTimeout(() => menu.classList.add('visible'), 10);

  const close = () => {
    menu.classList.remove('visible');
    setTimeout(() => menu.remove(), 500);
  };

  menu.querySelectorAll('button[data-sec]').forEach(btn => {
    btn.addEventListener('click', () => {
      const sec = parseInt(btn.dataset.sec, 10);
      travelInterval = sec * 1000;
      travelMode = true;
      applyTravelMode();
      showToast(`${btn.textContent.trim()}豈弱↓諠・勹繧貞ｷ｡繧翫∪す`);
      close();
    });
  });
  menu.querySelector('.travel-menu-cancel').addEventListener('click', close);
  // 螟悶け繝ｪ繝・け縺ｧ髢峨§めE
setTimeout(() => {
    const outside = (e) => {
      if (!menu.contains(e.target)) {
        close();
        document.removeEventListener('click', outside);
      }
    };
    document.addEventListener('click', outside);
  }, 100);
}

// ============ 莨第・繧ｿ繧､繝槭・ (5/10/30蛻・ｾ後↓終亁E ============
let restTimerTimeout = null;
let restTimerEndAt = 0;

const restTimerBtn = $('restTimerBtn');

restTimerBtn.addEventListener('click', () => {
  if (restTimerTimeout) {
    // すでに動作中なら解除
    clearTimeout(restTimerTimeout);
    restTimerTimeout = null;
    restTimerEndAt = 0;
    restTimerBtn.classList.remove('rest-active');
    showToast('縺ｲ縺ｨ莨代∩繧定ｧ｣髯､縺励∪縺励◆');
    return;
  }
  // 譎る俣驕ｸ謚槭Γ繝九Η繝ｼ繧貞・縺・  showRestTimerMenu();
});

function showRestTimerMenu() {
  const menu = document.createElement('div');
  menu.className = 'rest-timer-menu';
  menu.innerHTML = `
    <div class="rest-timer-menu-title">縺ｲ縺ｨ莨代∩まで</div>
    <button data-min="5">5 刁E/button>
    <button data-min="10">10 刁E/button>
    <button data-min="30">30 刁E/button>
    <button class="rest-timer-cancel">戻めE/button>
  `;
  document.body.appendChild(menu);
  setTimeout(() => menu.classList.add('visible'), 10);

  const close = () => {
    menu.classList.remove('visible');
    setTimeout(() => menu.remove(), 500);
  };

  menu.querySelectorAll('button[data-min]').forEach(btn => {
    btn.addEventListener('click', () => {
      const min = parseInt(btn.dataset.min, 10);
      startRestTimer(min);
      close();
    });
  });
  menu.querySelector('.rest-timer-cancel').addEventListener('click', close);
  // 螟悶け繝ｪ繝・け縺ｧ髢峨§めE
setTimeout(() => {
    const outside = (e) => {
      if (!menu.contains(e.target)) {
        close();
        document.removeEventListener('click', outside);
      }
    };
    document.addEventListener('click', outside);
  }, 100);
}

function startRestTimer(minutes) {
  restTimerEndAt = Date.now() + minutes * 60 * 1000;
  restTimerBtn.classList.add('rest-active');
  showToast(`${minutes} 蛻・ｾ後↓縺ｲ縺ｨ莨代∩`);
  restTimerTimeout = setTimeout(() => {
    triggerRestTimerEnd();
  }, minutes * 60 * 1000);
}

function triggerRestTimerEnd() {
  // 音楽をゆっくりフェードアウチE
const startVol = audio.volume;
  const fadeSteps = 40;
  const fadeInterval = 100;
  let step = 0;
  const fader = setInterval(() => {
    step++;
    audio.volume = Math.max(0, startVol * (1 - step / fadeSteps));
    if (step >= fadeSteps) {
      clearInterval(fader);
      audio.pause();
      audio.volume = startVol; // 復帰用
    }
  }, fadeInterval);

  // 暗転+繝｡繝・そ繝ｼ繧ｸ
  const farewell = document.createElement('div');
  farewell.className = 'rest-timer-farewell';
  farewell.innerHTML = `
    <div class="farewell-title">窶披・譌・・縲√・縺ｨ莨代∩、E/div>
    <div class="farewell-sub">A moment of rest in your journey.</div>
    <button class="farewell-close">譌・ｒ邯壹￠繧・/button>
  `;
  document.body.appendChild(farewell);
  setTimeout(() => farewell.classList.add('visible'), 100);
  farewell.querySelector('.farewell-close').addEventListener('click', () => {
    farewell.classList.remove('visible');
    setTimeout(() => farewell.remove(), 1500);
  });

  restTimerBtn.classList.remove('rest-active');
  restTimerTimeout = null;
}

// 簡易トースチE(譌｢蟄倥・雜ｳ霍｡謚慕ｨｿ繝医・繧ｹ繝医ｒ蜀榊茜逕ｨ)
function showToast(msg) {
  const toast = $('footprintToast');
  if (!toast) return;
  const span = toast.querySelector('span');
  const prev = span.textContent;
  span.textContent = msg;
  toast.classList.add('visible');
  setTimeout(() => {
    toast.classList.remove('visible');
    setTimeout(() => span.textContent = prev, 500);
  }, 2400);
}

footprintTrigger.addEventListener('click', () => {
  if (ringsOpen) closeRings();
  if (favPanelOpen) { favClose.click(); }
  openFootprintForm();
});

function openFootprintForm() {
  // 譛ｪ驕ｸ謚樊凾縺ｯ諠・勹繧帝∈縺ｶ繧医≧俁E☆
  if (currentSceneIndex < 0) {
    if (typeof showToast === 'function') showToast('縺ｾ縺壽ュ譎ｯ繧帝∈繧薙〒縺上□さい');
    return;
  }
  // 迴ｾ蝨ｨ縺ｮ諠・勹繧定｡ｨ遉ｺ
  const scene = scenes[currentSceneIndex];
  $('footprintSceneIndicator').textContent = `、E{scene.jp}縲阪↓て`;
  footprintMessage.value = '';
  footprintAuthor.value = localStorage.getItem('hmix_footprint_author') || '';
  footprintCharCount.textContent = '0';
  footprintFormError.style.display = 'none';
  footprintFormModal.classList.add('visible');
  setTimeout(() => footprintMessage.focus(), 100);
}
function closeFootprintForm() {
  footprintFormModal.classList.remove('visible');
}
$('footprintFormClose').addEventListener('click', closeFootprintForm);
$('footprintFormCancel').addEventListener('click', closeFootprintForm);

// 譁・ｭ玲焚繧ｫ繧ｦ繝ｳ繝・foo
tprintMessage.addEventListener('input', () => {
  const len = footprintMessage.value.length;
  footprintCharCount.textContent = len;
  const countEl = footprintCharCount.parentElement;
  countEl.classList.remove('warning', 'over');
  if (len > 50) countEl.classList.add('warning');
  if (len > 60) countEl.classList.add('over');
});

// NGワードフィルタ (螳牙・陬・ｽｮ2)
const NG_PATTERNS = [
  /https?:\/\//i,  // URL
  /www\./i,         // URL
  /[\w.+-]+@[\w-]+\.[\w.-]+/,  // メアチE  /\b\d{2,4}[- ]?\d{2,4}[- ]?\d{3,4}\b/,  // 電話番号
  /死ね|谿ｺ縺處豌上・|縺薙ｍ縺處縺励・/,  // 證ｴ險
  /バカ|縺ｰ縺弓繧｢繝斈縺ゅ⊇|クソ|縺上◎|馬鹿|阿呁E/,  // 證ｴ險(軽度)
  /[ア-ンア-ン]{15,}/,  // 繧ｫ繧ｿ繧ｫ繝企聞騾｣邯・繧ｹ繝代Β)
  /(.)\1{6,}/,  // 蜷後§譁・ｭ・蝗樔ｻ･荳翫・郢ｰ繧願ｿ斐＠
];
function filterMessage(msg) {
  for (const pat of NG_PATTERNS) {
    if (pat.test(msg)) return false;
  }
  return true;
}

// レート制陁E(螳牙・陬・ｽｮ1): 60遘偵↓1件
const RATE_LIMIT_KEY = 'hmix_footprint_last_post';
function checkRateLimit() {
  const last = parseInt(localStorage.getItem(RATE_LIMIT_KEY) || '0', 10);
  const now = Date.now();
  if (now - last < 60000) {
    return Math.ceil((60000 - (now - last)) / 1000);
  }
  return 0;
}
function markRateLimit() {
  localStorage.setItem(RATE_LIMIT_KEY, Date.now().toString());
}

// 謚慕ｨｿ騾∽ｿ｡
$('footprintFormSubmit').addEventListener('click', async () => {
  footprintFormError.style.display = 'none';
  const msg = footprintMessage.value.trim();
  const author = footprintAuthor.value.trim() || null;

  // 繝舌Μ繝・・繧ｷ繝ｧ繝ｳ
  if (!msg) {
    showFormError('險闡峨ｒ譖ｸ縺肴ｮ九＠縺ｦ縺上□さい');
    return;
  }
  if (msg.length > 60) {
    showFormError('60譁・ｭ嶺ｻ･蜀・↓縺励※縺上□さい');
    return;
  }
  if (author && author.length > 20) {
    showFormError('遲・錐縺ｯ20譁・ｭ嶺ｻ･蜀・↓縺励※縺上□さい');
    return;
  }
  // NGワード判宁E(螳牙・陬・ｽｮ2)
  if (!filterMessage(msg)) {
    showFormError('縺薙・蜀・ｮｹ縺ｯ騾∽ｿ｡縺ｧ縺阪∪縺帙ｓ縲り｡ｨ迴ｾ繧貞､峨∴てお試しください、E');
    return;
  }
  // レート制陁E(螳牙・陬・ｽｮ1)
  const wait = checkRateLimit();
  if (wait > 0) {
    showFormError(`次の投稿まで ${wait} 遘偵♀征E■縺上□さい`);
    return;
  }

  const scene = scenes[currentSceneIndex];

  // 騾∽ｿ｡繝懊ち繝ｳ繧剃ｸ譎ら┌効匁E
const submitBtn = $('footprintFormSubmit');
  submitBtn.disabled = true;
  submitBtn.textContent = '騾∽ｿ｡荳ｭ...';

  try {
    const result = await submitFootprint({
      message: msg,
      author: author,
      sceneId: scene.id,
      sceneName: scene.jp,
    });

    // 閾ｪ蛻・・雜ｳ霍｡繧貞叉蠎ｧ縺ｫ逕ｻ髱｢縺ｫ霑ｽ蜉 (Firestore反映を征E◆なぁE
    const localFootprint = new Footprint({
      id: result && result.id ? result.id : 'local_' + Date.now(),
      message: msg,
      author: author,
      sceneId: scene.id,
      sceneName: scene.jp,
      createdAt: new Date()
    });
    // 逶ｮ遶九▽繧医≧に近景(深度高め)に
    localFootprint.depth = 0.85 + Math.random() * 0.15;
    localFootprint.fontSize = 10 + localFootprint.depth * 38;
    localFootprint.colorWarmth = localFootprint.depth;
    localFootprint.baseOpacity = 0.75;
    localFootprint.targetOpacity = 0.75;
    // 画面右側1/3の位置に配置 (縺吶＄隕九∴縺ｦ縲∝ｷｦ縺ｸ繧・▲縺上ｊ豬√ｌ繧・
    localFootprint.x = innerWidth * 0.65 + Math.random() * (innerWidth * 0.2);
    localFootprint.y = innerHeight * 0.3 + Math.random() * (innerHeight * 0.4);
    // 蜃ｺ迴ｾ譎ゅ↓蜈峨ｋ貍泌・縺ｮ縺溘ａ縲∫音蛻･縺ｪ繝輔Λ繧ｰ繧堤ｫ九※めE    localFootprint.justBorn = 2.0; // 2秒間光る
    footprints.push(localFootprint);

    // 遲・錐繧定ｨ俶・
    if (author) localStorage.setItem('hmix_footprint_author', author);

    markRateLimit();
    closeFootprintForm();
    showFootprintToast();
  } catch (e) {
    console.error('[footprint] submit failed:', e);
    showFormError('騾∽ｿ｡縺ｫ螟ｱ謨励＠縺ｾ縺励◆: ' + (e.message || e.code || '荳肴・縺ｪ繧ｨ繝ｩ繝ｼ'));
  } finally {
    submitBtn.disabled = false;
    submitBtn.textContent = '遨ｺ縺ｸ騾√ｋ';
  }
});

function showFormError(msg) {
  footprintFormError.textContent = msg;
  footprintFormError.style.display = 'block';
}

function showFootprintToast() {
  const toast = $('footprintToast');
  toast.classList.add('visible');
  setTimeout(() => toast.classList.remove('visible'), 2800);
}

// ESC縺ｧ髢峨§めE
addEventListener('keydown', e => {
  if (e.key === 'Escape' && footprintFormModal.classList.contains('visible')) {
    closeFootprintForm();
  }
});

// 通報
function reportFootprint(fpId) {
  if (typeof window.fbReportFootprint === 'function') {
    window.fbReportFootprint(fpId).then(() => {
      showFormError = () => {};
      const toast = $('footprintToast');
      toast.querySelector('span').textContent = '騾壼ｱ繧貞女縺台ｻ倥￠縺ｾ縺励◆';
      toast.classList.add('visible');
      setTimeout(() => {
        toast.classList.remove('visible');
        toast.querySelector('span').textContent = '雜ｳ霍｡繧貞､懃ｩｺ縺ｫ谿九＠縺ｾ縺励◆';
      }, 2500);
    });
  }
}

// ============ Firebase接綁E(險ｭ螳壹′あれば有効匁E ============
// 投稿関数のスタチE Firebase縺瑚ｨｭ螳壹＆繧後※縺・ｌ縺ｰ縺昴■らを呼ぶ
async function submitFootprint(data) {
  if (typeof window.fbSubmitFootprint === 'function') {
    return window.fbSubmitFootprint(data);
  }
  // Firebase未設定時: ローカルで仮想皁E↓豬√☆ (開発用)
  const demo = {
    id: 'demo_' + Date.now(),
    ...data,
    createdAt: new Date()
  };
  footprints.unshift(new Footprint(demo));
  while (footprints.length > 20) footprints.pop();
}

