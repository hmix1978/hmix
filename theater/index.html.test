<!DOCTYPE html>
<html lang="ja">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
<script>
// モバイル端末は新シアターと相性が悪ぁE◆繧√∝ｰら畑縺ｮ譌ｧ繧ｷ繧｢繧ｿ繝ｼ襍ｷ蜍輔・繝ｼ繧ｸ縺ｸ驕ｷ遘ｻ
(function() {
  try {
    var isTouch = window.matchMedia && window.matchMedia('(hover: none) and (pointer: coarse)').matches;
    var isSmall = window.innerWidth <= 768;
    if (isTouch && isSmall) {
      location.replace('/theater-mobile/');
    }
  } catch(e) {}
})();
</script>
<title>音の劇場 - H/MIX GALLERY | 和風・ファンタジーBGMを旅する音楽シアター</title>
